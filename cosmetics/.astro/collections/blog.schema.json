{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "skincare",
        "ingredients",
        "reviews",
        "how-tos"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "hub",
        "guide",
        "listicle",
        "review",
        "routine"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "affiliateProduct": {
      "type": "string"
    },
    "hub": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "category",
    "type"
  ]
}