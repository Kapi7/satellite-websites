---
import '../styles/global.css';
import type { Locale } from '../i18n/locales';
import { isRtl, locales } from '../i18n/locales';
import { localePath, defaultLocale } from '../i18n/utils';
import TabBar from '../components/TabBar.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  jsonLd?: string[];
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  robots?: string;
  locale?: Locale;
}

const {
  title, description,
  image = '/images/og-default.jpg',
  canonicalUrl, type = 'website', jsonLd = [],
  articlePublishedTime, articleModifiedTime, articleSection, articleTags = [],
  robots = 'index, follow',
  locale = 'en',
} = Astro.props;

const siteTitle = 'Glow Coded';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

// Locale-aware canonical: use localePath when locale != default
const pagePath = Astro.url.pathname;
const canonical = canonicalUrl || (locale !== defaultLocale
  ? new URL(localePath(pagePath.replace(new RegExp(`^/${locale}`), '') || '/', locale), Astro.site).href
  : Astro.url.href);

// Build the base path without locale prefix for hreflang generation
const pathWithoutLocale = pagePath.replace(new RegExp(`^/${locale}(?=/|$)`), '') || '/';
---

<!doctype html>
<html lang={locale} dir={isRtl(locale) ? 'rtl' : 'ltr'}>
  <head>
    <!-- Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LNYVF6BHTN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-LNYVF6BHTN");
    </script>
    <script is:inline src="/js/tracking.js">
    </script>
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#4a2040" />
    <meta name="robots" content={robots} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="llms-txt" href="/llms.txt" />

    <!-- Font preloads: Rozha One, DM Sans, Cutive Mono -->
    <link rel="preload" href="/fonts/rozha-one-regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/dm-sans-variable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/cutive-mono-regular.woff2" as="font" type="font/woff2" crossorigin>

    {/* Arabic font preload — only when locale is 'ar' */}
    {locale === 'ar' && (
      <link rel="preload" href="https://fonts.gstatic.com/s/notosansarabic/v18/nwpxtLGrOAZMl5nJ_wfgRg3DrWFZWsnVBJ_sS6tlqHHGpMUIx5Y.woff2" as="font" type="font/woff2" crossorigin />
    )}

    {/* Hreflang tags for all locales */}
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(localePath(pathWithoutLocale, l), Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localePath(pathWithoutLocale, defaultLocale), Astro.site).href} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content={siteTitle} />

    {type === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {type === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {type === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {type === 'article' && articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href={localePath('/rss.xml', locale)} />

    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={schema} />
    ))}

    {/* RTL / Arabic font styles */}
    {locale === 'ar' && (
      <style is:inline>
        [dir="rtl"] body {
          font-family: 'Noto Sans Arabic', 'Inter', system-ui, sans-serif;
        }
      </style>
    )}
  </head>
  <body class="min-h-screen flex flex-col paper-bg">
    <slot />
    <TabBar locale={locale} />
  </body>
</html>
