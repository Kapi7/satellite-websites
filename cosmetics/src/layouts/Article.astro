---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';
import type { Locale } from '../i18n/locales';
import { t, localePath, formatDate } from '../i18n/utils';

interface Props {
  title: string; description: string; date: Date; updated?: Date;
  category: string; tags?: string[]; image?: string; imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
  routine?: string;
  type?: string;
  locale?: Locale;
  author?: string;
}

const { title, description, date, updated, category, tags = [], image, imageAlt, headings, slug, rawContent, routine, type, locale = 'en', author } = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];
const readingTime = rawContent ? Math.max(1, Math.ceil(rawContent.split(/\s+/).length / 200)) : null;

const categoryLabels: Record<string, string> = {
  'skincare': t(locale, 'categories.skincare'),
  'ingredients': t(locale, 'categories.ingredients'),
  'reviews': t(locale, 'categories.reviews'),
  'how-tos': t(locale, 'categories.howTos'),
};
const categoryLabel = categoryLabels[category] || category;

const formattedDate = formatDate(date, locale);
const formattedUpdated = updated ? formatDate(updated, locale) : undefined;
const articleUrl = new URL(localePath(`/${slug}`, locale), Astro.site).href;

const authorObj = author
  ? { '@type': 'Person', name: author }
  : { '@type': 'Organization', name: 'Glow Coded Editorial' };

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image, url: articleUrl,
  datePublished: date.toISOString(), dateModified: updated?.toISOString() || date.toISOString(),
  author: authorObj,
  publisher: { '@type': 'Organization', name: 'Glow Coded', url: 'https://glow-coded.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  inLanguage: locale,
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(localePath(`/category/${category}`, locale), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
  ],
});

const schemas = [articleSchema, breadcrumbSchema];

if (type === 'guide' && headings) {
  const stepHeadings = headings.filter(
    (h) => h.depth === 3 && /^(\d+[\.\)]\s|step\s|day\s)/i.test(h.text)
  );
  if (stepHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const steps = stepHeadings.map((h) => {
      const headingPattern = h.text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let text = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (text) break; continue; }
          text = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return { '@type': 'HowToStep', name: h.text, text: text || h.text };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'HowTo',
      name: title, description, step: steps, inLanguage: locale,
    }));
  }
}

// FAQ schema — auto-detect question headings
if (headings) {
  const questionHeadings = headings.filter(
    (h) => (h.depth === 2 || h.depth === 3) && h.text.trim().endsWith('?')
  );
  if (questionHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const faqEntries = questionHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let answer = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (answer) break; continue; }
          answer = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return {
        '@type': 'Question', name: h.text,
        acceptedAnswer: { '@type': 'Answer', text: answer || h.text },
      };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: faqEntries, inLanguage: locale,
    }));
  }
}

// ItemList schema — auto-detect for listicle type
if (type === 'listicle' && headings) {
  const listHeadings = headings.filter(
    (h) => h.depth === 2 && /^(\d+[\.\)]\s|best|top|\w+\s#?\d)/i.test(h.text)
  );
  if (listHeadings.length >= 3) {
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'ItemList',
      name: title, numberOfItems: listHeadings.length,
      itemListElement: listHeadings.map((h, i) => ({
        '@type': 'ListItem', position: i + 1, name: h.text,
        url: `${articleUrl}#${h.slug}`,
      })),
    }));
  }
}

let RoutineTimeline: any = null;
let routineData: any = null;
if (routine) {
  try {
    const mod = await import('../components/RoutineTimeline.astro');
    RoutineTimeline = mod.default;
    const routinesFile = await import('../data/routines.json');
    routineData = routinesFile.default.find((r: any) => r.id === routine);
  } catch {}
}

/* Split title on colon for italic accent treatment */
const titleParts = title.includes(':') ? [title.split(':')[0], ':' + title.split(':').slice(1).join(':')] : [title, ''];
const authorInitial = author ? author[0].toUpperCase() : 'G';
const authorDisplay = author || t(locale, 'article.editorial');
---

<Base
  title={title} description={description} image={image} type="article"
  jsonLd={schemas}
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={(updated || date).toISOString()}
  articleSection={categoryLabel}
  articleTags={tags}
  locale={locale}
>
  <ReadingProgress />
  <Header locale={locale} />
  <main class="flex-1">
    <div class="gc-article-page">
      {/* ===== Two-column grid: main + sidebar ===== */}
      <div class="article-wrap">
        {/* ===== Main column ===== */}
        <article data-pagefind-body class="article-main">
          {/* Kicker */}
          <div class="gc-kicker animate-fade-in">
            <span>&#10022;</span>
            <span>{categoryLabel}</span>
            <span>&middot;</span>
            {readingTime && <span>{readingTime} {t(locale, 'common.minRead')}</span>}
          </div>

          {/* Title — split on colon for italic coral accent */}
          <h1 class="gc-title animate-fade-in-up">
            {titleParts[0]}{titleParts[1] && <em>{titleParts[1]}</em>}
          </h1>

          {/* Lede */}
          <p class="gc-lede animate-fade-in-up stagger-1">{description}</p>

          {/* Byline */}
          <div class="gc-byline animate-fade-in-up stagger-1">
            <div class="gc-avatar">{authorInitial}</div>
            <div>{t(locale, 'common.by')} {authorDisplay.toUpperCase()} &middot; {formattedDate}
              {formattedUpdated && <> &middot; {t(locale, 'common.updated')} {formattedUpdated}</>}
            </div>
          </div>

          {/* Hero image */}
          {image && (
            <div class="gc-hero animate-fade-in-up stagger-2">
              <img src={image} alt={imageAlt || title} loading="eager" width="1200" height="675" />
            </div>
          )}

          {/* TOC */}
          <div class="animate-fade-in-up stagger-2">
            <TableOfContents headings={headings} locale={locale} />
          </div>

          {/* Body text — slot renders MDX content */}
          <div class="prose body-text animate-fade-in-up stagger-3">
            <slot />
          </div>

          {/* Routine timeline */}
          {RoutineTimeline && routineData && (
            <RoutineTimeline routine={routineData} currentSlug={slug} locale={locale} />
          )}

          {/* Tags */}
          {tags.length > 0 && (
            <div class="gc-tags">
              <span class="gc-tags-label">{t(locale, 'common.tagged')}</span>
              <div class="gc-tags-list">
                {tags.map((tag) => (
                  <span class="gc-tag">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <ShareButtons title={title} url={articleUrl} locale={locale} />
        </article>

        {/* ===== Sidebar ===== */}
        <aside class="gc-aside">
          {/* Mentioned products */}
          {products.length > 0 && (
            <div class="aside-box">
              <h5>{t(locale, 'common.featuredProducts')}</h5>
              <div class="aside-list">
                {products.slice(0, 3).map((product) => (
                  <a href={product.url} target="_blank" rel="noopener noreferrer" class="aside-item">
                    <div class="aside-thumb">
                      <img src={product.image} alt={product.name} loading="lazy" />
                    </div>
                    <div>
                      <h6>{product.name}</h6>
                      <small>{t(locale, 'common.shopNow')} &rarr;</small>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Keep reading */}
          <div class="aside-box aside-keep-reading">
            <h5>{t(locale, 'article.keepReading') || 'KEEP READING'}</h5>
            {/* RelatedArticles rendered inline in sidebar */}
          </div>

          {/* Newsletter CTA */}
          <div class="aside-box aside-newsletter">
            <h5>{t(locale, 'newsletter.titleShort') || 'THE LETTER'}</h5>
            <p>{t(locale, 'newsletter.tagline') || 'Thursdays. One honest email. One routine we\'d actually use.'}</p>
            <NewsletterSignup locale={locale} compact />
          </div>
        </aside>
      </div>

      {/* Full-width related articles below the grid */}
      <div class="gc-below-fold">
        <RelatedArticles currentSlug={slug} category={category} locale={locale} />
      </div>
    </div>
  </main>
  <Footer locale={locale} />
  <BackToTop locale={locale} />

  <style>
    /* ===== Article page layout ===== */
    .gc-article-page {
      max-width: 1360px;
      margin: 0 auto;
      padding: 0 32px 80px;
    }

    /* Two-column grid: content + sidebar */
    .article-wrap {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 60px;
      padding-top: 40px;
    }

    /* ===== Kicker ===== */
    .gc-kicker {
      display: flex;
      gap: 10px;
      align-items: center;
      font-family: 'Cutive Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-rose-600);
      margin-bottom: 20px;
    }

    /* ===== Title ===== */
    .gc-title {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 72px;
      line-height: 0.95;
      letter-spacing: -0.015em;
      margin: 0 0 22px;
      color: var(--color-charcoal);
    }
    .gc-title em {
      font-style: italic;
      color: var(--color-rose-500);
    }

    /* ===== Lede ===== */
    .gc-lede {
      font-size: 20px;
      line-height: 1.5;
      color: var(--color-charcoal-light);
      max-width: 700px;
      margin: 0 0 30px;
    }

    /* ===== Byline ===== */
    .gc-byline {
      display: flex;
      gap: 14px;
      align-items: center;
      padding: 16px 0;
      border-top: 1.5px solid var(--color-charcoal);
      border-bottom: 1.5px solid var(--color-charcoal);
      font-family: 'Cutive Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .gc-avatar {
      width: 36px;
      height: 36px;
      border-radius: 999px;
      background: var(--butter);
      border: 1.5px solid var(--color-charcoal);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Rozha One', serif;
      font-size: 16px;
      flex-shrink: 0;
    }

    /* ===== Hero image ===== */
    .gc-hero {
      margin: 36px 0 30px;
      height: 460px;
      border: 1.5px solid var(--color-charcoal);
      border-radius: 8px;
      overflow: hidden;
      position: relative;
    }
    .gc-hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ===== Body text (wraps <slot/> prose) ===== */
    .body-text {
      color: var(--color-charcoal-light);
    }
    .body-text :global(p) {
      font-size: 17px;
      line-height: 1.8;
      margin: 0 0 1.3em;
      max-width: 720px;
    }
    .body-text :global(h2) {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 32px;
      letter-spacing: -0.01em;
      margin: 2em 0 0.6em;
      color: var(--color-charcoal);
      padding-top: 12px;
      border-top: 1px dashed rgba(26, 21, 19, 0.15);
    }
    .body-text :global(h3) {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 22px;
      margin: 1.5em 0 0.4em;
      color: var(--color-charcoal);
    }
    .body-text :global(ul) {
      padding-left: 24px;
      margin: 0 0 1.3em;
      max-width: 720px;
    }
    .body-text :global(li) {
      font-size: 16px;
      line-height: 1.75;
      margin-bottom: 10px;
      color: var(--color-charcoal-light);
    }
    .body-text :global(img) {
      max-width: 480px;
      width: 100%;
      border-radius: 10px;
      border: 1.5px solid var(--color-charcoal);
      margin: 24px 0;
      display: block;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.08);
    }
    .body-text :global(a) {
      color: var(--color-plum-700);
      text-decoration: underline;
      text-decoration-color: rgba(109, 46, 110, 0.3);
      text-underline-offset: 3px;
      transition: text-decoration-color 0.15s;
    }
    .body-text :global(a:hover) {
      text-decoration-color: var(--color-plum-700);
    }
    .body-text :global(strong) {
      font-weight: 600;
      color: var(--color-charcoal);
    }
    .body-text :global(blockquote) {
      font-family: 'Rozha One', serif;
      font-size: 34px;
      line-height: 1.15;
      border-left: 4px solid var(--color-rose-500);
      padding: 6px 0 6px 22px;
      margin: 30px 0;
      max-width: 640px;
      font-style: normal;
      color: var(--color-charcoal);
    }
    .body-text :global(blockquote p) {
      font-size: inherit;
      line-height: inherit;
      margin: 0;
      max-width: none;
    }

    /* ===== Tags ===== */
    .gc-tags {
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1.5px solid var(--color-charcoal);
    }
    .gc-tags-label {
      font-family: 'Cutive Mono', ui-monospace, monospace;
      font-size: 10.5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--color-charcoal-light);
      margin-right: 12px;
    }
    .gc-tags-list {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }
    .gc-tag {
      padding: 4px 12px;
      background: var(--color-cream-dark);
      color: var(--color-plum-600);
      font-size: 12px;
      font-weight: 500;
      border-radius: 999px;
      border: 1px solid var(--color-charcoal);
    }

    /* ===== Sidebar ===== */
    .gc-aside {
      position: sticky;
      top: 40px;
      align-self: start;
      padding-top: 20px;
    }
    .aside-box {
      border: 1.5px solid var(--color-charcoal);
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 20px;
      background: var(--color-cream);
    }
    .aside-box h5 {
      font-family: 'Cutive Mono', ui-monospace, monospace;
      font-size: 10.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin: 0 0 14px;
      padding-bottom: 10px;
      border-bottom: 1.5px solid var(--color-charcoal);
    }
    .aside-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .aside-item {
      display: flex;
      gap: 12px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
    }
    .aside-thumb {
      width: 64px;
      height: 64px;
      flex: none;
      border: 1.3px solid var(--color-charcoal);
      border-radius: 4px;
      overflow: hidden;
      position: relative;
    }
    .aside-thumb img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .aside-item h6 {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-weight: 600;
      font-size: 13px;
      line-height: 1.3;
      margin: 0 0 3px;
    }
    .aside-item small {
      font-family: 'Cutive Mono', ui-monospace, monospace;
      font-size: 9.5px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--color-charcoal-light);
    }

    /* Newsletter sidebar variant */
    .aside-newsletter {
      background: var(--color-rose-500);
      color: #fff;
      border-color: var(--color-charcoal);
    }
    .aside-newsletter h5 {
      border-color: rgba(255, 255, 255, 0.3);
      color: #fff;
    }
    .aside-newsletter p {
      font-size: 13px;
      line-height: 1.5;
      margin: 0 0 12px;
    }

    /* ===== Below-fold full width ===== */
    .gc-below-fold {
      margin-top: 60px;
    }

    /* ===== Responsive: single column below 1100px ===== */
    @media (max-width: 1100px) {
      .article-wrap {
        grid-template-columns: 1fr;
      }
      .gc-aside {
        position: static;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        padding-top: 40px;
        border-top: 1.5px solid var(--color-charcoal);
        margin-top: 40px;
      }
      .aside-newsletter {
        grid-column: 1 / -1;
      }
    }

    @media (max-width: 768px) {
      .gc-article-page {
        padding: 0 16px 60px;
      }
      .gc-title {
        font-size: 40px;
        line-height: 1.0;
        letter-spacing: -0.02em;
      }
      .gc-lede {
        font-size: 17px;
      }
      .gc-hero {
        height: 280px;
        margin: 24px 0 20px;
      }
      .gc-aside {
        grid-template-columns: 1fr;
      }
      .body-text :global(blockquote) {
        font-size: 24px;
      }
      .body-text :global(h2) {
        font-size: 26px;
      }
    }
  </style>

  <script>
    document.querySelectorAll(".prose table").forEach((table) => {
      const wrapper = document.createElement("div");
      wrapper.className = "table-expand-wrapper";
      const header = document.createElement("div");
      header.className = "table-expand-header";
      const btn = document.createElement("button");
      btn.className = "table-expand-btn";
      const expandSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>';
      const collapseSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14h6v6M14 10h6V4M3 21l7-7M21 3l-7 7"/></svg>';
      btn.textContent = 'Expand Full Screen';
      btn.insertAdjacentHTML('afterbegin', expandSvg + ' ');
      btn.addEventListener("click", () => {
        const isExpanded = wrapper.classList.toggle("expanded");
        btn.textContent = isExpanded ? ' Collapse' : ' Expand Full Screen';
        btn.insertAdjacentHTML('afterbegin', isExpanded ? collapseSvg : expandSvg);
        if (isExpanded) { document.body.style.overflow = "hidden"; }
        else { document.body.style.overflow = ""; }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && wrapper.classList.contains("expanded")) btn.click();
      });
      header.appendChild(btn);
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(header);
      wrapper.appendChild(table);
    });
  </script>
</Base>
