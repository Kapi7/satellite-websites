---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';
import type { Locale } from '../i18n/locales';
import { t, localePath, formatDate } from '../i18n/utils';

interface Props {
  title: string; description: string; date: Date; updated?: Date;
  category: string; tags?: string[]; image?: string; imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
  routine?: string;
  type?: string;
  locale?: Locale;
}

const { title, description, date, updated, category, tags = [], image, imageAlt, headings, slug, rawContent, routine, type, locale = 'en' } = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];
const readingTime = rawContent ? Math.max(1, Math.ceil(rawContent.split(/\s+/).length / 200)) : null;

const categoryLabels: Record<string, string> = {
  'skincare': t(locale, 'categories.skincare'),
  'ingredients': t(locale, 'categories.ingredients'),
  'reviews': t(locale, 'categories.reviews'),
  'how-tos': t(locale, 'categories.howTos'),
};
const categoryLabel = categoryLabels[category] || category;

const formattedDate = formatDate(date, locale);
const formattedUpdated = updated ? formatDate(updated, locale) : undefined;
const articleUrl = new URL(localePath(`/${slug}`, locale), Astro.site).href;

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image,
  datePublished: date.toISOString(), dateModified: updated?.toISOString() || date.toISOString(),
  author: { '@type': 'Organization', name: 'Glow Coded Editorial' },
  publisher: { '@type': 'Organization', name: 'Glow Coded' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  inLanguage: locale,
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(localePath(`/category/${category}`, locale), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
});

// HowTo schema — auto-detect for guide type
const schemas = [articleSchema, breadcrumbSchema];

if (type === 'guide' && headings) {
  const stepHeadings = headings.filter(
    (h) => h.depth === 3 && /^(\d+[\.\)]\s|step\s|day\s)/i.test(h.text)
  );
  if (stepHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const steps = stepHeadings.map((h) => {
      const headingPattern = h.text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let text = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (text) break; continue; }
          text = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return { '@type': 'HowToStep', name: h.text, text: text || h.text };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'HowTo',
      name: title, description, step: steps, inLanguage: locale,
    }));
  }
}

// FAQ schema — auto-detect question headings
if (headings) {
  const questionHeadings = headings.filter(
    (h) => (h.depth === 2 || h.depth === 3) && h.text.trim().endsWith('?')
  );
  if (questionHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const faqEntries = questionHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let answer = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (answer) break; continue; }
          answer = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return {
        '@type': 'Question', name: h.text,
        acceptedAnswer: { '@type': 'Answer', text: answer || h.text },
      };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: faqEntries, inLanguage: locale,
    }));
  }
}

let RoutineTimeline: any = null;
let routineData: any = null;
if (routine) {
  try {
    const mod = await import('../components/RoutineTimeline.astro');
    RoutineTimeline = mod.default;
    const routinesFile = await import('../data/routines.json');
    routineData = routinesFile.default.find((r: any) => r.id === routine);
  } catch {}
}
---

<Base
  title={title} description={description} image={image} type="article"
  jsonLd={schemas}
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={(updated || date).toISOString()}
  articleSection={categoryLabel}
  articleTags={tags}
  locale={locale}
>
  <ReadingProgress />
  <Header locale={locale} />
  <main class="flex-1">
    <div class="animate-fade-in">
      {image && (
        <div class="max-w-[1400px] mx-auto px-4 sm:px-8 pt-4 sm:pt-8">
          <div class="aspect-[5/2] max-h-[40vh] overflow-hidden rounded-xl sm:rounded-2xl bg-rose-50">
            <img src={image} alt={imageAlt || title} class="w-full h-full object-cover" loading="eager" width="1200" height="675" />
          </div>
        </div>
      )}
    </div>

    <div class={`max-w-[1400px] mx-auto px-4 sm:px-8 py-6 sm:py-10 ${products.length > 0 ? "xl:flex xl:gap-8" : ""}`}>
      <article data-pagefind-body class={`flex-1 min-w-0 ${products.length === 0 ? "mx-auto" : ""}`}>
        <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.1em] text-charcoal-light/50 mb-8 animate-fade-in-up" aria-label="Breadcrumb">
          <a href={localePath('/', locale)} class="hover:text-plum-700 transition-colors">{t(locale, 'common.home')}</a>
          <svg class="w-3 h-3 text-rose-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <a href={localePath(`/category/${category}`, locale)} class="hover:text-plum-700 transition-colors">{categoryLabel}</a>
        </nav>
        <header class="mb-8 animate-fade-in-up stagger-1">
          <h1 class="font-heading text-4xl sm:text-[2.75rem] text-charcoal leading-[1.1] tracking-tight mb-5">{title}</h1>
          <p class="text-lg text-charcoal-light/60 leading-relaxed mb-6 max-w-2xl">{description}</p>
          <div class="flex items-center gap-4 text-[11px] uppercase tracking-[0.1em] text-charcoal-light/50">
            <div class="flex items-center gap-2">
              <img src="/logo.svg" alt="" class="w-5 h-5" />
              <span class="font-medium">{t(locale, 'article.editorial')}</span>
            </div>
            <span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {formattedUpdated && (<><span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span><span>{t(locale, 'common.updated')} {formattedUpdated}</span></>)}
            {readingTime && (
              <>
                <span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span>
                <span>{readingTime} {t(locale, 'common.minRead')}</span>
              </>
            )}
          </div>
        </header>
        <div class="animate-fade-in-up stagger-2"><TableOfContents headings={headings} locale={locale} /></div>
        <div class="prose animate-fade-in-up stagger-3"><slot /></div>
        {RoutineTimeline && routineData && (
          <RoutineTimeline routine={routineData} currentSlug={slug} locale={locale} />
        )}
        {tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-rose-200/60">
            <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mr-3">{t(locale, 'common.tagged')}</span>
            <div class="inline-flex flex-wrap gap-2 mt-2">
              {tags.map((tag) => (<span class="px-3 py-1 bg-rose-100/60 text-plum-600 text-xs font-medium rounded-full">{tag}</span>))}
            </div>
          </div>
        )}
        <ShareButtons title={title} url={articleUrl} locale={locale} />
      </article>

      {products.length > 0 && (
        <aside class="hidden xl:block w-44 shrink-0">
          <div class="">
            <h3 class="font-heading text-sm text-charcoal mb-3 tracking-tight">{t(locale, 'common.featuredProducts')}</h3>
            <div class="space-y-4">
              {products.slice(0, 3).map((product) => (
                <a href={product.url} target="_blank" rel="noopener noreferrer" class="block border border-rose-200/60 rounded-lg p-2 bg-white/80 shadow-sm hover:shadow hover:-translate-y-0.5 transition-all">
                  <img src={product.image} alt={product.name} class="w-full rounded-md mb-1.5" loading="lazy" />
                  <p class="text-xs font-medium text-charcoal leading-snug mb-1">{product.name}</p>
                  <span class="text-[11px] font-semibold text-rose-600 hover:text-rose-800 transition-colors">{t(locale, 'common.shopNow')} &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>

    <div class="max-w-[1400px] mx-auto px-4 sm:px-8">
      <RelatedArticles currentSlug={slug} category={category} locale={locale} />
      <NewsletterSignup locale={locale} />
    </div>
  </main>
  <Footer locale={locale} />
  <BackToTop locale={locale} />

  <script>
    document.querySelectorAll(".prose table").forEach((table) => {
      const wrapper = document.createElement("div");
      wrapper.className = "table-expand-wrapper";
      const header = document.createElement("div");
      header.className = "table-expand-header";
      const btn = document.createElement("button");
      btn.className = "table-expand-btn";
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';
      btn.addEventListener("click", () => {
        const isExpanded = wrapper.classList.toggle("expanded");
        btn.innerHTML = isExpanded
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14h6v6M14 10h6V4M3 21l7-7M21 3l-7 7"/></svg> Collapse'
          : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';
        if (isExpanded) { document.body.style.overflow = "hidden"; }
        else { document.body.style.overflow = ""; }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && wrapper.classList.contains("expanded")) btn.click();
      });
      header.appendChild(btn);
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(header);
      wrapper.appendChild(table);
    });
  </script>
</Base>
