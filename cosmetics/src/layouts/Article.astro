---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';

interface Props {
  title: string; description: string; date: Date; updated?: Date;
  category: string; tags?: string[]; image?: string; imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
}

const { title, description, date, updated, category, tags = [], image, imageAlt, headings, slug, rawContent } = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];

const categoryLabels: Record<string, string> = {
  'skincare': 'Skincare', 'ingredients': 'Ingredients', 'reviews': 'Reviews', 'how-tos': 'How-Tos',
};

const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updated?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const articleUrl = new URL(`/${slug}`, Astro.site).href;

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image,
  datePublished: date.toISOString(), dateModified: updated?.toISOString() || date.toISOString(),
  author: { '@type': 'Organization', name: 'Glow Coded Editorial' },
  publisher: { '@type': 'Organization', name: 'Glow Coded' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabels[category] || category, item: new URL(`/category/${category}`, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
});
---

<Base title={title} description={description} image={image} type="article" jsonLd={[articleSchema, breadcrumbSchema]}>
  <ReadingProgress />
  <Header />
  <main class="flex-1">
    <div class="animate-fade-in">
      {image && (
        <div class="max-w-5xl mx-auto px-4 sm:px-8 pt-4 sm:pt-8">
          <div class="aspect-[16/10] sm:aspect-[2.2/1] overflow-hidden rounded-xl sm:rounded-2xl bg-rose-50">
            <img src={image} alt={imageAlt || title} class="w-full h-full object-cover" loading="eager" />
          </div>
        </div>
      )}
    </div>

    <div class={`max-w-6xl mx-auto px-4 sm:px-8 py-6 sm:py-10 ${products.length > 0 ? "lg:flex lg:gap-10" : ""}`}>
      <article class={`max-w-3xl min-w-0 ${products.length === 0 ? "mx-auto" : ""}`}>
        <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.1em] text-plum-300 mb-8 animate-fade-in-up" aria-label="Breadcrumb">
          <a href="/" class="hover:text-plum-700 transition-colors">Home</a>
          <svg class="w-3 h-3 text-rose-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <a href={`/category/${category}`} class="hover:text-plum-700 transition-colors">{categoryLabels[category] || category}</a>
        </nav>
        <header class="mb-10 animate-fade-in-up stagger-1">
          <h1 class="font-heading text-4xl sm:text-[2.75rem] text-charcoal leading-[1.1] tracking-tight mb-5">{title}</h1>
          <p class="text-lg text-plum-400 leading-relaxed mb-6 max-w-2xl">{description}</p>
          <div class="flex items-center gap-4 text-[11px] uppercase tracking-[0.1em] text-plum-300">
            <div class="flex items-center gap-2">
              <img src="/logo.svg" alt="" class="w-5 h-5" />
              <span class="font-medium">Glow Coded Editorial</span>
            </div>
            <span class="w-1 h-1 rounded-full bg-rose-300"></span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {formattedUpdated && (<><span class="w-1 h-1 rounded-full bg-rose-300"></span><span>Updated {formattedUpdated}</span></>)}
          </div>
        </header>
        <div class="animate-fade-in-up stagger-2"><TableOfContents headings={headings} /></div>
        <div class="prose animate-fade-in-up stagger-3"><slot /></div>
        {tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-rose-200/60">
            <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-plum-300 mr-3">Tagged</span>
            <div class="inline-flex flex-wrap gap-2 mt-2">
              {tags.map((tag) => (<span class="px-3 py-1 bg-rose-100/60 text-plum-600 text-xs font-medium rounded-full">{tag}</span>))}
            </div>
          </div>
        )}
        <ShareButtons title={title} url={articleUrl} />
      </article>

      {products.length > 0 && (
        <aside class="hidden lg:block w-72 shrink-0">
          <div class="sticky top-8">
            <h3 class="font-heading text-lg text-charcoal mb-4 tracking-tight">Featured Products</h3>
            <div class="space-y-4">
              {products.map((product) => (
                <a href={product.url} target="_blank" rel="noopener noreferrer" class="block border border-rose-200 rounded-xl p-3 bg-white shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all">
                  <img src={product.image} alt={product.name} class="w-full rounded-lg mb-2" loading="lazy" />
                  <p class="text-sm font-medium text-charcoal leading-snug mb-1.5">{product.name}</p>
                  <span class="text-xs font-semibold text-rose-600 hover:text-rose-800 transition-colors">Shop Now &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-8">
      <RelatedArticles currentSlug={slug} category={category} />
      <NewsletterSignup />
    </div>
  </main>
  <Footer />
  <BackToTop />
</Base>
