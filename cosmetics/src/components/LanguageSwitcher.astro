---
import { locales, localeNativeNames, type Locale } from '../i18n/locales';
import { getPathWithoutLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = getPathWithoutLocale(Astro.url);
---

<div class="gcd-lang" id="lang-switcher">
  <button id="lang-trigger" class="lang-trigger" aria-label="Change language">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="9"/>
      <path d="M3.6 9h16.8M3.6 15h16.8M12 3c2.2 2.5 3.5 5.5 3.5 9s-1.3 6.5-3.5 9m0-18c-2.2 2.5-3.5 5.5-3.5 9s1.3 6.5 3.5 9"/>
    </svg>
    <span class="name">{localeNativeNames[locale]}</span>
    <svg id="lang-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
  </button>
  <div id="lang-panel" class="lang-panel hidden">
    {locales.map((l) => {
      const href = l === 'en' ? (currentPath || '/') : `/${l}${currentPath}`;
      return (
        <a
          href={href}
          class={`lang-option ${l === locale ? 'active' : ''}`}
          style={l === 'ar' ? 'font-family: system-ui;' : ''}
        >{localeNativeNames[l]}</a>
      );
    })}
  </div>
</div>

<style>
  .gcd-lang {
    position: relative;
    display: inline-block;
  }
  .lang-trigger {
    display: flex; align-items: center; gap: 6px;
    cursor: pointer; border: none; background: none; padding: 4px 6px;
    font-family: 'Cutive Mono', monospace;
    font-size: 11px; letter-spacing: 0.08em;
    color: var(--color-charcoal-light);
    text-transform: uppercase;
  }
  .lang-trigger:hover { color: var(--color-charcoal); }
  .lang-trigger .name { display: inline-flex; }
  .lang-trigger #lang-chevron { transition: transform 0.2s; }
  .lang-trigger.open #lang-chevron { transform: rotate(180deg); }

  .lang-panel {
    position: absolute;
    top: 100%; right: 0;
    margin-top: 8px;
    background: var(--color-paper);
    border: 1.5px solid var(--color-charcoal);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--color-charcoal);
    z-index: 200;
    min-width: 160px;
    overflow: hidden;
  }
  .hidden { display: none; }

  .lang-option {
    display: block; padding: 8px 16px;
    cursor: pointer; font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    color: var(--color-charcoal);
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: background 0.15s;
  }
  .lang-option:last-child { border-bottom: none; }
  .lang-option:hover { background: var(--color-rose-50); }
  .lang-option.active {
    background: var(--color-rose-500);
    color: #fff;
  }
</style>

<script>
  const trigger = document.getElementById('lang-trigger');
  const panel = document.getElementById('lang-panel');
  let open = false;

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    open = !open;
    panel?.classList.toggle('hidden', !open);
    trigger?.classList.toggle('open', open);
  });

  document.addEventListener('click', (e) => {
    if (open && !document.getElementById('lang-switcher')?.contains(e.target as Node)) {
      open = false;
      panel?.classList.add('hidden');
      trigger?.classList.remove('open');
    }
  });
</script>
