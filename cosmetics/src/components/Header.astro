---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const navItems = [
  { label: t(locale, 'nav.skincare'), href: localePath('/category/skincare/', locale) },
  { label: t(locale, 'nav.ingredients'), href: localePath('/category/ingredients/', locale) },
  { label: t(locale, 'nav.reviews'), href: localePath('/category/reviews/', locale) },
  { label: t(locale, 'nav.howTos'), href: localePath('/category/how-tos/', locale) },
  { label: t(locale, 'nav.about'), href: localePath('/about/', locale) },
];

const tools = [
  { label: t(locale, 'nav.ingredientChecker'), href: localePath('/ingredient-checker/', locale), desc: t(locale, 'nav.ingredientCheckerDesc'), icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016Z"/></svg>' },
  { label: t(locale, 'nav.skinQuiz'), href: localePath('/quiz/', locale), desc: t(locale, 'nav.skinQuizDesc'), icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z"/></svg>' },
  { label: t(locale, 'nav.ingredientGlossary'), href: localePath('/ingredients/', locale), desc: t(locale, 'nav.ingredientGlossaryDesc'), icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>' },
  { label: t(locale, 'nav.shadeMatcher'), href: localePath('/shade-matcher/', locale), desc: t(locale, 'nav.shadeMatcherDesc'), icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/></svg>' },
];
---
<header class="bg-cream/80 backdrop-blur-xl sticky top-0 z-50 transition-all duration-300" id="site-header">
  <div class="max-w-[1400px] mx-auto px-6 sm:px-10">
    <div class="flex items-center justify-between py-5">
      <!-- Logo -->
      <a href={localePath('/', locale)} class="group shrink-0">
        <img src="/logo.svg" alt="Glow Coded" class="h-10 sm:h-11 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-7">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-[16px] font-heading italic tracking-tight text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200 relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-[0.5px] after:bg-rose-500 after:transition-all after:duration-300 hover:after:w-full"
          >
            {item.label}
          </a>
        ))}

        <!-- Tools Dropdown -->
        <div class="relative" id="tools-dropdown">
          <button
            id="tools-trigger"
            class="text-[16px] font-heading italic tracking-tight text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200 flex items-center gap-1 cursor-pointer"
          >
            {t(locale, 'nav.tools')}
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="tools-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </button>
          <div id="tools-panel" class="hidden absolute top-full right-0 mt-3 w-72 bg-white rounded-xl shadow-lg border border-rose-100/60 overflow-hidden z-50">
            {tools.map((tool) => (
              <a
                href={tool.href}
                class="group flex items-start gap-3 px-5 py-3.5 hover:bg-rose-50/60 transition-colors border-b border-rose-50 last:border-0"
              >
                <div class="w-9 h-9 rounded-lg bg-rose-50 flex items-center justify-center text-rose-500 group-hover:bg-rose-100 group-hover:text-rose-600 transition-colors shrink-0 mt-0.5" set:html={tool.icon} />
                <div>
                  <span class="block text-sm font-medium text-charcoal group-hover:text-rose-700 transition-colors">{tool.label}</span>
                  <span class="block text-xs text-charcoal-light/60 leading-snug">{tool.desc}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <LanguageSwitcher locale={locale} />
        <!-- Dark Mode Toggle -->
        <button id="dark-mode-toggle" class="p-2 text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200 rounded-full hover:bg-rose-50/60" aria-label={t(locale, 'common.toggleDarkMode')}>
          <svg class="w-[18px] h-[18px] block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
          <svg class="w-[18px] h-[18px] hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
        </button>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2 text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200" aria-label={t(locale, 'common.openMenu')}>
          <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" /></svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Subtle bottom rule -->
  <div class="h-[0.5px] bg-gradient-to-r from-transparent via-rose-300/50 to-transparent"></div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-cream/95 backdrop-blur-xl border-t border-rose-100/60">
    <nav class="max-w-[1400px] mx-auto px-6 py-6 flex flex-col gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="py-2.5 text-[16px] font-heading italic tracking-tight text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200 border-b border-rose-100/40 last:border-0"
        >
          {item.label}
        </a>
      ))}
      <!-- Tools section in mobile -->
      <div class="pt-3 mt-2 border-t border-rose-200/40">
        <span class="block text-[10px] font-bold uppercase tracking-widest text-charcoal-light/40 mb-2 px-0">{t(locale, 'nav.tools')}</span>
        {tools.map((tool) => (
          <a
            href={tool.href}
            class="flex items-center gap-3 py-2.5 text-[16px] font-heading italic tracking-tight text-charcoal-light/60 hover:text-rose-600 transition-colors duration-200"
          >
            <span class="text-rose-400 w-5 h-5 shrink-0" set:html={tool.icon} />
            {tool.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  // Tools dropdown
  const toolsTrigger = document.getElementById('tools-trigger');
  const toolsPanel = document.getElementById('tools-panel');
  const toolsChevron = document.getElementById('tools-chevron');
  let toolsOpen = false;

  toolsTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    toolsOpen = !toolsOpen;
    toolsPanel?.classList.toggle('hidden', !toolsOpen);
    toolsChevron?.classList.toggle('rotate-180', toolsOpen);
  });

  document.addEventListener('click', (e) => {
    if (toolsOpen && !document.getElementById('tools-dropdown')?.contains(e.target as Node)) {
      toolsOpen = false;
      toolsPanel?.classList.add('hidden');
      toolsChevron?.classList.remove('rotate-180');
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
  });

  // Scroll shadow
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
  }, { passive: true });

  // Dark mode toggle
  const toggle = document.getElementById('dark-mode-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
