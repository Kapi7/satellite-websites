---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
  mobileTitle?: string; /* e.g. "GLOW CODED", "THE EDIT", "FREE TOOLS" */
}

const { locale = 'en', mobileTitle = 'GLOW CODED' } = Astro.props;

/* Prototype-locked desktop nav */
const navItems = [
  { key: 'home', label: 'Home', href: localePath('/', locale) },
  { key: 'category', label: 'Categories', href: localePath('/category/skincare/', locale) },
  { key: 'shop', label: 'Shop', href: localePath('/shop/', locale) },
  { key: 'tools', label: 'Free Tools', href: localePath('/tools/', locale) },
  { key: 'newsletter', label: 'The Letter', href: localePath('/#newsletter', locale) },
  { key: 'about', label: 'About', href: localePath('/about/', locale) },
];

/* Mobile drawer menu (matches prototype's slide-out menu) */
const drawerItems = [
  { key: 'home', label: 'Home', icon: '\u{1F3E0}', href: localePath('/', locale) },
  { key: 'category', label: 'All Articles', icon: '\u{1F4D6}', href: localePath('/category/skincare/', locale) },
  { key: 'tools', label: 'Free Tools', icon: '\u{1F527}', href: localePath('/tools/', locale) },
  { key: 'shop', label: 'Shop', icon: '\u{1F6CD}', href: localePath('/shop/', locale) },
  { key: 'newsletter', label: 'Newsletter', icon: '\u2709', href: localePath('/#newsletter', locale) },
  { key: 'about', label: 'About Us', icon: '\u2726', href: localePath('/about/', locale) },
];

/* Date stamp for desktop */
const now = new Date();
const monthNames = ['JANUARY', 'FEBRUARY', 'MARCH', 'APRIL', 'MAY', 'JUNE', 'JULY', 'AUGUST', 'SEPTEMBER', 'OCTOBER', 'NOVEMBER', 'DECEMBER'];
const dateStamp = `${monthNames[now.getMonth()]} ${now.getDate()} \u00b7 ${now.getFullYear()} \u00b7 ISSUE NO. 12`;
---

<header class="gcd-header" id="site-header">
  {/* =================== DESKTOP TOP BAR =================== */}
  <div class="gcd-header-wrap desktop-only">
    <div class="gcd-top">
      <div class="gcd-date"><span class="dot"></span>{dateStamp}</div>
      <nav class="links">
        {navItems.map((item) => {
          const external = item.href.startsWith('http');
          return (
            <a
              href={item.href}
              class="gcd-top-link"
              data-nav-key={item.key}
              {...(external ? { target: '_blank', rel: 'noopener' } : {})}
            >{item.label}</a>
          );
        })}
      </nav>
      <div class="right">
        <LanguageSwitcher locale={locale} />
        <a href={localePath('/', locale)} class="handle">@GLOW.CODED</a>
      </div>
    </div>
  </div>

  {/* =================== MOBILE TOP BAR (prototype GCHeader) =================== */}
  <div class="gcm-top mobile-only">
    <button id="gcm-menu-btn" class="gcm-menu-trigger" aria-label="Menu">
      <svg width="24" height="18" viewBox="0 0 24 18">
        <path d="M2 3 Q 12 0 22 3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M2 9 Q 12 6 22 9" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M2 15 Q 12 12 22 15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="gcm-title">
      {mobileTitle}
      <svg width="10" height="10" viewBox="0 0 24 24" class="gcm-spark"><path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z" fill="var(--color-rose-500)"/></svg>
    </div>
    <div class="gcm-right">
      <LanguageSwitcher locale={locale} />
      <a href={localePath('/category/skincare/', locale)} aria-label="Search" class="gcm-search">
        <svg width="18" height="18" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" fill="none"/><path d="M16 16 L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>

  {/* =================== MOBILE DRAWER =================== */}
  <div id="gcm-drawer" class="gcm-drawer hidden" aria-hidden="true">
    <div id="gcm-drawer-overlay" class="gcm-overlay"></div>
    <aside class="gcm-panel">
      <div class="gcm-brand">
        <div class="mark">Glow Coded</div>
        <div class="sub">K-BEAUTY DECODED</div>
      </div>
      <ul class="gcm-list">
        {drawerItems.map((d) => (
          <li>
            <a href={d.href}>
              <span class="ico">{d.icon}</span>
              <span>{d.label}</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="gcm-foot">
        <a href={localePath('/shop/', locale)} class="gcm-cta">SHOP THE EDIT &rarr;</a>
      </div>
    </aside>
  </div>
</header>

<style>
  .gcd-header { background: var(--color-paper); }
  .gcd-header-wrap { max-width: 1360px; margin: 0 auto; padding: 0 32px; }

  /* Desktop / Mobile show toggles */
  .desktop-only { display: block; }
  .mobile-only { display: none; }

  /* ===== Desktop top bar ===== */
  .gcd-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0 18px;
    border-bottom: 1.5px solid var(--color-charcoal);
    font-family: 'Cutive Mono', monospace;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em;
  }
  .gcd-top .links { display: flex; gap: 20px; }
  .gcd-top a.gcd-top-link {
    color: var(--color-charcoal); text-decoration: none;
    padding: 4px 6px; border-radius: 3px;
    transition: background 0.15s, color 0.15s;
  }
  .gcd-top a.gcd-top-link:hover { background: var(--color-charcoal); color: var(--color-cream); }
  .gcd-top a.gcd-top-link.active { background: var(--color-rose-500); color: #fff; }
  .gcd-date { color: var(--color-charcoal); white-space: nowrap; }
  .gcd-date .dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 999px;
    background: var(--color-rose-500); margin-right: 8px; vertical-align: 2px;
  }
  .right { display: flex; align-items: center; gap: 16px; color: var(--color-charcoal); }
  .handle {
    color: var(--color-charcoal); text-decoration: none; white-space: nowrap;
    font-family: 'Cutive Mono', monospace;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em;
  }

  /* ===== Mobile top bar ===== */
  .gcm-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: calc(env(safe-area-inset-top, 12px) + 12px) 18px 14px;
    border-bottom: 1.5px solid var(--color-charcoal);
    background: var(--color-paper);
    position: sticky; top: 0; z-index: 40;
  }
  .gcm-menu-trigger {
    background: transparent; border: none; cursor: pointer;
    padding: 4px; color: var(--color-charcoal);
    display: flex; align-items: center; justify-content: center;
  }
  .gcm-title {
    display: flex; align-items: center; gap: 4px;
    font-family: 'Rozha One', serif;
    font-size: 20px; letter-spacing: 0.02em;
    color: var(--color-charcoal);
  }
  .gcm-title .gcm-spark { transform: rotate(20deg); }
  .gcm-right { display: flex; align-items: center; gap: 12px; color: var(--color-charcoal); }
  .gcm-search {
    color: var(--color-charcoal); display: flex; align-items: center;
  }

  /* ===== Mobile drawer ===== */
  .gcm-drawer { position: fixed; inset: 0; z-index: 200; }
  .gcm-drawer.hidden { display: none; }
  .gcm-overlay { position: absolute; inset: 0; background: rgba(26,21,19,0.5); }
  .gcm-panel {
    position: absolute; top: 0; left: 0; bottom: 0; width: 80%; max-width: 320px;
    background: var(--color-paper);
    box-shadow: 4px 0 20px rgba(0,0,0,0.15);
    display: flex; flex-direction: column;
    animation: gcm-slide-in 0.2s ease-out;
  }
  @keyframes gcm-slide-in {
    from { transform: translateX(-100%); }
    to   { transform: translateX(0); }
  }
  .gcm-brand {
    padding: 40px 24px 20px;
    border-bottom: 1.5px solid var(--color-charcoal);
  }
  .gcm-brand .mark {
    font-family: 'Rozha One', serif; font-size: 28px;
    color: var(--color-charcoal);
  }
  .gcm-brand .sub {
    font-family: 'Cutive Mono', monospace; font-size: 10px;
    letter-spacing: 0.12em; color: var(--color-rose-500);
    margin-top: 4px; text-transform: uppercase;
  }
  .gcm-list {
    flex: 1; padding: 12px 0; margin: 0; list-style: none;
  }
  .gcm-list li a {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 24px;
    font-size: 16px; font-family: 'DM Sans', sans-serif;
    color: var(--color-charcoal); text-decoration: none;
    border-bottom: 1px solid rgba(26,21,19,0.08);
  }
  .gcm-list li a .ico {
    width: 24px; text-align: center; font-size: 18px;
  }
  .gcm-foot {
    padding: 20px 24px;
    border-top: 1.5px solid var(--color-charcoal);
  }
  .gcm-cta {
    display: flex; align-items: center; justify-content: center;
    width: 100%; padding: 12px 16px;
    background: var(--color-rose-500); color: #fff;
    border: 1.5px solid var(--color-charcoal); border-radius: 999px;
    font-family: 'Cutive Mono', monospace; font-size: 12px;
    letter-spacing: 0.14em; text-transform: uppercase;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--color-charcoal);
  }

  @media (max-width: 900px) {
    .desktop-only { display: none; }
    .mobile-only { display: flex; }
  }
</style>

<script>
  /* Desktop active-nav highlight */
  (function() {
    const path = window.location.pathname;
    document.querySelectorAll('[data-nav-key]').forEach((el) => {
      const key = el.getAttribute('data-nav-key');
      const href = el.getAttribute('href') || '';
      const pathPart = href.replace(/#.*$/, '').replace(/\/$/, '');
      let isActive = false;
      if (key === 'home') isActive = path === '/' || /^\/[a-z]{2}\/?$/.test(path);
      else if (!href.startsWith('http') && !href.startsWith('mailto:') && pathPart && !/^\/[a-z]{2}$/.test(pathPart)) {
        isActive = path.startsWith(pathPart);
      }
      if (isActive) el.classList.add('active');
    });
  })();

  /* Mobile drawer */
  const drawer = document.getElementById('gcm-drawer');
  const openBtn = document.getElementById('gcm-menu-btn');
  const overlay = document.getElementById('gcm-drawer-overlay');
  const close = () => { drawer?.classList.add('hidden'); drawer?.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; };
  const open = () => { drawer?.classList.remove('hidden'); drawer?.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; };
  openBtn?.addEventListener('click', open);
  overlay?.addEventListener('click', close);
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
</script>
