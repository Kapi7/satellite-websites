---
const year = new Date().getFullYear();
const exploreLinks = [
  { label: 'Skincare', href: '/category/skincare' },
  { label: 'Ingredients', href: '/category/ingredients' },
  { label: 'Reviews', href: '/category/reviews' },
  { label: 'How-Tos', href: '/category/how-tos' },
  { label: 'Skin Quiz', href: '/quiz' },
];
const toolsLinks = [
  { label: 'Glossary', href: '/ingredients' },
  { label: 'Conflict Checker', href: '/ingredient-checker' },
  { label: 'About', href: '/about' },
  { label: 'Privacy', href: '/privacy' },
];
---

<footer class="bg-rose-50/50 rounded-t-[2rem] mt-16">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-10 sm:gap-12 px-6 sm:px-12 py-12 sm:py-16 max-w-[1400px] mx-auto">

    <!-- Col 1: Brand -->
    <div class="md:pr-4">
      <a href="/" class="inline-block mb-4">
        <img src="/logo.svg" alt="Glow Coded" class="h-10 w-auto" />
        <span class="font-heading text-2xl italic text-charcoal block mt-2">Glow Coded</span>
      </a>
      <p class="text-sm text-charcoal-light/60 leading-relaxed">
        We test everything before we write about it. If it didn't work on our skin, it's not on this site.
      </p>
      <div class="mt-6 flex items-center gap-1">
        <span class="inline-block w-8 h-[0.5px] bg-charcoal-light/20"></span>
        <span class="text-[11px] font-heading italic text-charcoal-light/50 tracking-wide">Beauty, decoded.</span>
      </div>
    </div>

    <!-- Col 2: Explore -->
    <div>
      <h4 class="text-[11px] font-heading uppercase tracking-wide text-charcoal-light/50 mb-5">Explore</h4>
      <ul class="space-y-3">
        {exploreLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-charcoal-light/60 hover:text-plum-700 transition-colors duration-200">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Tools & Info -->
    <div>
      <h4 class="text-[11px] font-heading uppercase tracking-wide text-charcoal-light/50 mb-5">Tools & Info</h4>
      <ul class="space-y-3">
        {toolsLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-charcoal-light/60 hover:text-plum-700 transition-colors duration-200">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Newsletter -->
    <div>
      <h4 class="text-[11px] font-heading uppercase tracking-wide text-charcoal-light/50 mb-5">Get the Glow</h4>
      <p class="text-sm text-charcoal-light/60 leading-relaxed mb-4">
        Weekly skincare breakdowns & honest reviews. No spam, just glow.
      </p>
      <form class="flex flex-col gap-3" onsubmit="return false;">
        <input
          type="email"
          placeholder="your@email.com"
          class="w-full px-4 py-2.5 text-sm bg-white/70 border border-rose-200/60 rounded-lg text-charcoal placeholder:text-charcoal-light/50 focus:outline-none focus:ring-1 focus:ring-rose-400 focus:border-rose-400 transition-all duration-200"
        />
        <button
          type="submit"
          class="w-full px-4 py-2.5 text-sm font-heading tracking-wide bg-rose-600 text-cream rounded-lg hover:bg-rose-700 transition-colors duration-200"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-rose-200/40">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-12 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-charcoal-light/50">&copy; {year} Glow Coded. All rights reserved.</span>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-charcoal-light/50 hover:text-rose-600 transition-colors duration-200" aria-label="Instagram">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://pinterest.com" target="_blank" rel="noopener noreferrer" class="text-charcoal-light/50 hover:text-rose-600 transition-colors duration-200" aria-label="Pinterest">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="text-charcoal-light/50 hover:text-rose-600 transition-colors duration-200" aria-label="TikTok">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
