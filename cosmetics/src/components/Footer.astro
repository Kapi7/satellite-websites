---
import { localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

/* Prototype-locked footer — 4 columns: brand | READ | TOOLS | HOUSE */
const readLinks = [
  { label: 'Routines',  href: localePath('/category/skincare/', locale) },
  { label: 'Ingredients', href: localePath('/category/ingredients/', locale) },
  { label: 'Reviews', href: localePath('/category/reviews/', locale) },
  { label: 'How-Tos', href: localePath('/category/how-tos/', locale) },
];

const toolsLinks = [
  { label: 'Skin Quiz', href: localePath('/quiz/', locale) },
  { label: 'Shelf Builder', href: localePath('/shade-matcher/', locale) },
  { label: 'Ingredient Checker', href: localePath('/ingredient-checker/', locale) },
  { label: 'Ingredient Matrix', href: localePath('/ingredient-matrix/', locale) },
];

const houseLinks = [
  { label: 'About',  href: localePath('/about/', locale) },
  { label: 'The Letter', href: localePath('/newsletter/', locale) },
  { label: 'Ethics & disclosure', href: localePath('/privacy/', locale) },
  { label: 'Contact', href: 'mailto:hello@glow-coded.com' },
];
---

<footer class="gcd-footer">
  <div>
    <a href={localePath('/', locale)} class="brand-link">
      <div class="brand-mark">glow<em>coded</em>.</div>
    </a>
    <p class="brand-desc">Skin science, honestly. K-Beauty without the gatekeeping. Founded 2024.</p>
  </div>
  <div>
    <h5>READ</h5>
    <ul>
      {readLinks.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </div>
  <div>
    <h5>TOOLS</h5>
    <ul>
      {toolsLinks.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </div>
  <div>
    <h5>HOUSE</h5>
    <ul>
      {houseLinks.map((l) => {
        const external = l.href.startsWith('http') || l.href.startsWith('mailto:');
        return (
          <li>
            <a href={l.href} {...(external && !l.href.startsWith('mailto:') ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a>
          </li>
        );
      })}
    </ul>
  </div>
</footer>

<style>
  .gcd-footer {
    max-width: 1360px; margin: 80px auto 0;
    padding: 50px 32px 30px;
    border-top: 1.5px solid var(--color-charcoal);
    display: grid; grid-template-columns: 1.2fr repeat(3, 1fr); gap: 40px;
    background: var(--color-paper);
  }
  .brand-link { text-decoration: none; color: inherit; }
  .brand-mark {
    font-family: 'Rozha One', serif; font-size: 48px; line-height: 1;
    margin-bottom: 10px; color: var(--color-charcoal);
  }
  .brand-mark em { font-style: italic; color: var(--color-rose-500); }
  .brand-desc {
    font-size: 13px; color: var(--color-charcoal-light); line-height: 1.6;
    margin: 0; font-family: 'DM Sans', sans-serif;
  }

  .gcd-footer h5 {
    font-family: 'Cutive Mono', monospace; font-size: 10.5px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-charcoal-light); margin: 0 0 14px;
  }
  .gcd-footer ul {
    list-style: none; padding: 0; margin: 0;
    font-size: 13.5px; line-height: 2;
    font-family: 'DM Sans', sans-serif;
  }
  .gcd-footer ul a {
    color: var(--color-charcoal); text-decoration: none;
    transition: color 0.15s;
  }
  .gcd-footer ul a:hover { color: var(--color-rose-500); }

  @media (max-width: 1100px) {
    .gcd-footer {
      grid-template-columns: 1fr 1fr;
      padding: 40px 32px 24px;
    }
  }
  @media (max-width: 600px) {
    .gcd-footer {
      grid-template-columns: 1fr;
      padding: 36px 20px 24px; gap: 28px;
    }
    .brand-mark { font-size: 40px; }
  }
</style>
