---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  type?: string;
  featured?: boolean;
}

const { title, description, date, category, slug, image, type, featured = false } = Astro.props;

const categoryLabels: Record<string, string> = {
  'skincare': 'Skincare',
  'ingredients': 'Ingredients',
  'reviews': 'Reviews',
  'how-tos': 'How-Tos',
};

const typeLabels: Record<string, string> = {
  hub: 'Essential Guide',
  guide: 'Guide',
  listicle: 'List',
  review: 'Review',
  routine: 'Routine',
};

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class={`group flex flex-col ${featured ? 'md:col-span-2' : ''}`}>
  <a href={`/${slug}`} class="flex flex-col h-full">
    {image && (
      <div class={`overflow-hidden rounded-2xl mb-6 bg-rose-50 ${featured ? 'aspect-[16/9]' : 'aspect-[3/2]'}`}>
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          width="600"
          height="400"
        />
      </div>
    )}
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs tracking-wide uppercase text-charcoal-light/60">
        {categoryLabels[category] || category}
      </span>
      {type && (
        <>
          <span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span>
          <span class="text-xs tracking-wide uppercase text-charcoal-light/40">
            {typeLabels[type] || type}
          </span>
        </>
      )}
    </div>
    <h3 class={`font-heading group-hover:text-charcoal-light transition-colors leading-snug text-charcoal tracking-tight ${featured ? 'text-3xl' : 'text-xl'}`}>
      {title}
    </h3>
    <p class="text-charcoal-light/70 text-sm mb-4 line-clamp-2 flex-grow">
      {description}
    </p>
    <time class="text-xs text-charcoal-light/40 uppercase tracking-wide" datetime={date.toISOString()}>
      {formattedDate}
    </time>
  </a>
</article>
