---
import { t, localePath, formatDateShort, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  type?: string;
  featured?: boolean;
  locale?: Locale;
}

const { title, description, date, category, slug, image, type, featured = false, locale = 'en' } = Astro.props;

const categoryKeyMap: Record<string, string> = {
  'skincare': 'categories.skincare',
  'ingredients': 'categories.ingredients',
  'reviews': 'categories.reviews',
  'how-tos': 'categories.howTos',
};

const typeKeyMap: Record<string, string> = {
  hub: 'types.hub',
  guide: 'types.guide',
  listicle: 'types.listicle',
  review: 'types.review',
  routine: 'types.routine',
};

const categoryLabel = categoryKeyMap[category] ? t(locale, categoryKeyMap[category]) : category;
const typeLabel = type && typeKeyMap[type] ? t(locale, typeKeyMap[type]) : type;
const formattedDate = formatDateShort(date, locale);
---

<article class={`edit-card ${featured ? 'feat' : ''}`}>
  <a href={localePath('/' + slug + '/', locale)} class="edit-card-link">
    {image ? (
      <div class={`edit-card-img ${featured ? '' : 'small'}`}>
        <span class="edit-card-cat">{categoryLabel}</span>
        <img
          src={image}
          alt={title}
          class="edit-card-image"
          loading="lazy"
          width="600"
          height="400"
        />
      </div>
    ) : (
      <div class={`edit-card-img edit-card-img-placeholder ${featured ? '' : 'small'}`}>
        <span class="edit-card-cat">{categoryLabel}</span>
      </div>
    )}
    <div class="edit-card-body">
      <h3 class={featured ? 'xl' : ''}>{title}</h3>
      <p>{description}</p>
      <div class="edit-card-foot">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {typeLabel && <span>{typeLabel}</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .edit-card {
    background: #fdfbf9;
    border: 1.5px solid #1a1513;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 4px 4px 0 #1a1513;
    cursor: pointer;
    transition: transform 0.18s, box-shadow 0.18s;
    display: flex;
    flex-direction: column;
  }

  .edit-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 #1a1513;
  }

  .edit-card.feat {
    grid-column: span 2;
  }

  .edit-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .edit-card-img {
    position: relative;
    border-bottom: 1.5px solid #1a1513;
    overflow: hidden;
  }

  .edit-card.feat .edit-card-img {
    height: 420px;
  }

  .edit-card-img.small {
    height: 220px;
  }

  .edit-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .edit-card-img-placeholder {
    background: repeating-linear-gradient(45deg, #ffb9b0 0 10px, #ffd4c0 10px 20px);
  }

  .edit-card-cat {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    background: #1a1513;
    color: #fdfbf9;
    font-family: 'Cutive Mono', monospace;
    font-size: 10px;
    padding: 4px 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .edit-card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .edit-card-body h3 {
    font-family: 'Rozha One', serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 1.05;
    letter-spacing: -0.005em;
    margin: 0;
    color: #1a1513;
  }

  .edit-card-body h3.xl {
    font-size: 42px;
    line-height: 0.98;
  }

  .edit-card-body p {
    font-size: 13.5px;
    line-height: 1.55;
    color: #4a3f3a;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .edit-card-foot {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px dashed rgba(26, 21, 19, 0.22);
    display: flex;
    justify-content: space-between;
    font-family: 'Cutive Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4a3f3a;
  }

  @media (max-width: 768px) {
    .edit-card.feat {
      grid-column: span 1;
    }

    .edit-card.feat .edit-card-img {
      height: 240px;
    }

    .edit-card-img.small {
      height: 180px;
    }

    .edit-card-body h3.xl {
      font-size: 28px;
    }
  }
</style>
