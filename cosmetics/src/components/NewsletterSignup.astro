<section class="relative my-16 overflow-hidden">
  <div class="rounded-2xl bg-plum-800 px-8 py-12 sm:px-12 sm:py-14 text-center relative overflow-hidden">
    <div class="absolute -top-20 -right-20 w-60 h-60 rounded-full bg-rose-700/15"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 rounded-full bg-plum-700/30"></div>

    <div class="relative z-10">
      <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.2em] text-rose-300 mb-4">Newsletter</span>
      <h3 class="font-heading text-2xl sm:text-3xl text-cream mb-3 tracking-tight">
        Get the Glow
      </h3>
      <p class="text-sm text-plum-300 mb-8 max-w-md mx-auto leading-relaxed">
        Weekly skincare breakdowns, ingredient deep-dives, and honest reviews. straight to your inbox.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-5 py-3 rounded-xl border-0 bg-plum-900/50 text-cream text-sm placeholder:text-plum-500 focus:outline-none focus:ring-2 focus:ring-rose-400/50"
        />
        <button
          type="submit"
          class="px-7 py-3 bg-cream text-plum-800 text-sm font-semibold rounded-xl hover:bg-white transition-colors duration-200"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
</section>
