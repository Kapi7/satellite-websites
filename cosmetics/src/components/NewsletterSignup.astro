---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
  compact?: boolean;
}

const { locale = 'en', compact = false } = Astro.props;
---
{compact ? (
  <div class="newsletter-compact">
    <p class="newsletter-compact-tagline">{t(locale, 'newsletter.tagline') || "Thursdays. One honest email. One routine we'd actually use."}</p>
    <form class="newsletter-form newsletter-compact-form" data-locale={locale}>
      <input type="email" placeholder={t(locale, 'footer.emailPlaceholder')} required class="newsletter-compact-input" />
      <button type="submit" class="newsletter-compact-button">{t(locale, 'common.subscribe')}</button>
      <p class="newsletter-msg newsletter-compact-msg"></p>
    </form>
    <style>
      .newsletter-compact { width: 100%; box-sizing: border-box; }
      .newsletter-compact-tagline { font-size: 12.5px; line-height: 1.5; margin: 0 0 14px; color: rgba(255,255,255,0.92); }
      .newsletter-compact-form { display: flex; flex-direction: column; gap: 10px; }
      .newsletter-compact-input { width: 100%; box-sizing: border-box; background: rgba(255,255,255,0.95); border: 1.5px solid var(--color-charcoal, #1a1513); border-radius: 999px; padding: 9px 14px; font-size: 12.5px; color: var(--color-charcoal, #1a1513); outline: none; }
      .newsletter-compact-input::placeholder { color: rgba(26,21,19,0.5); }
      .newsletter-compact-button { width: 100%; background: var(--color-charcoal, #1a1513); color: #fff; border: 1.5px solid var(--color-charcoal, #1a1513); border-radius: 999px; padding: 9px 14px; font-family: 'Cutive Mono', ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; cursor: pointer; }
      .newsletter-compact-button:hover { opacity: 0.85; }
      .newsletter-compact-msg { font-size: 11px; margin: 4px 0 0; }
      .newsletter-compact-msg:empty { display: none; }
    </style>
  </div>
) : (
<section class="relative my-16 overflow-hidden">
  <div class="bg-rose-50/60 rounded-2xl sm:rounded-[3rem] p-6 sm:p-8 md:p-14 border border-rose-200/30 relative overflow-hidden">
    <!-- Decorative circles -->
    <div class="absolute -top-24 -right-24 w-72 h-72 rounded-full bg-charcoal-light/20 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-56 h-56 rounded-full bg-rose-400/15 blur-3xl"></div>

    <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
      <!-- Text column -->
      <div class="flex-1 text-center md:text-left">
        <span class="text-xs tracking-widest text-rose-600 font-semibold uppercase block mb-4">{t(locale, 'newsletter.preTitle')}</span>
        <h3 class="font-heading text-3xl md:text-4xl italic text-plum-900 mb-3 tracking-tight">
          {t(locale, 'newsletter.title')}
        </h3>
        <p class="text-sm text-charcoal-light/60 leading-relaxed max-w-md">
          {t(locale, 'newsletter.description')}
        </p>
      </div>

      <!-- Form column -->
      <div class="flex-1 w-full max-w-md">
        <form class="newsletter-form flex flex-col gap-5" data-locale={locale}>
          <input
            type="email"
            placeholder={t(locale, 'footer.emailPlaceholder')}
            required
            class="w-full bg-transparent border-b-2 border-rose-300 focus:border-rose-600 px-1 py-3 text-base text-plum-900 placeholder:text-charcoal-light/50 focus:outline-none transition-colors duration-200"
          />
          <button
            type="submit"
            class="bg-rose-600 text-cream px-10 py-4 rounded-full text-sm font-semibold hover:bg-rose-700 transition-colors duration-200 self-start"
          >
            {t(locale, 'common.subscribe')}
          </button>
          <p class="newsletter-msg text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>
)}
