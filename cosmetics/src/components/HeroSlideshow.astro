---
interface Slide { image: string; title: string; subtitle: string; link?: string; category?: string; }
interface Props { slides: Slide[]; }
const { slides } = Astro.props;
---
<section class="relative overflow-hidden rounded-2xl mx-5 sm:mx-8 max-w-6xl lg:mx-auto" id="hero-slideshow">
  <div class="relative aspect-[2.2/1] sm:aspect-[2.5/1] bg-rose-50">
    {slides.map((slide, i) => (
      <div class={`slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
        <img src={slide.image} alt={slide.title} class="w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/40 to-transparent"></div>
        <div class="absolute inset-0 flex items-center">
          <div class="px-8 sm:px-12 lg:px-16 max-w-xl">
            {slide.category && (
              <span class="inline-block text-[10px] sm:text-[11px] font-semibold uppercase tracking-[0.2em] text-rose-300 mb-3">{slide.category}</span>
            )}
            <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl text-white leading-[1.15] tracking-tight mb-3">{slide.title}</h2>
            <p class="text-sm sm:text-base text-white/70 leading-relaxed mb-5 line-clamp-2">{slide.subtitle}</p>
            {slide.link && (
              <a href={slide.link} class="inline-flex items-center gap-2 text-sm font-medium text-white border border-white/30 rounded-full px-5 py-2 hover:bg-white/10 transition-all duration-300">
                Read article
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="absolute bottom-4 sm:bottom-6 right-6 sm:right-10 flex items-center gap-2.5 z-10">
    {slides.map((_, i) => (
      <button class={`dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-6' : 'bg-white/40 hover:bg-white/70'}`} data-dot={i} aria-label={`Go to slide ${i + 1}`} />
    ))}
  </div>
  <button id="slideshow-toggle" class="absolute bottom-4 sm:bottom-6 left-6 sm:left-10 z-10 text-white/50 hover:text-white/80 transition-colors" aria-label="Pause slideshow">
    <svg id="pause-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6zM14 4h4v16h-4z"/></svg>
    <svg id="play-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
  </button>
</section>
<script>
  const slideshow = document.getElementById('hero-slideshow');
  if (slideshow) {
    const slides = slideshow.querySelectorAll('.slide');
    const dots = slideshow.querySelectorAll('.dot');
    const toggle = document.getElementById('slideshow-toggle');
    const pauseIcon = document.getElementById('pause-icon');
    const playIcon = document.getElementById('play-icon');
    let current = 0, playing = true;
    let interval: ReturnType<typeof setInterval>;
    function goTo(index: number) {
      slides.forEach((s, i) => { (s as HTMLElement).classList.toggle('opacity-100', i === index); (s as HTMLElement).classList.toggle('opacity-0', i !== index); });
      dots.forEach((d, i) => { (d as HTMLElement).classList.toggle('bg-white', i === index); (d as HTMLElement).classList.toggle('w-6', i === index); (d as HTMLElement).classList.toggle('bg-white/40', i !== index); (d as HTMLElement).classList.toggle('w-2', i !== index); });
      current = index;
    }
    function next() { goTo((current + 1) % slides.length); }
    function startAutoplay() { interval = setInterval(next, 5000); }
    function stopAutoplay() { clearInterval(interval); }
    dots.forEach((dot) => { dot.addEventListener('click', () => { goTo(parseInt((dot as HTMLElement).dataset.dot || '0')); if (playing) { stopAutoplay(); startAutoplay(); } }); });
    toggle?.addEventListener('click', () => { playing = !playing; if (playing) { startAutoplay(); pauseIcon?.classList.remove('hidden'); playIcon?.classList.add('hidden'); } else { stopAutoplay(); pauseIcon?.classList.add('hidden'); playIcon?.classList.remove('hidden'); } });
    slideshow.addEventListener('mouseenter', () => { if (playing) stopAutoplay(); });
    slideshow.addEventListener('mouseleave', () => { if (playing) startAutoplay(); });
    startAutoplay();
  }
</script>
