---
import { t, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  url: string;
  locale?: Locale;
}

const { title, url, locale = 'en' } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---
<div class="flex items-center gap-3 mt-8 pt-6 border-t border-rose-200/60">
  <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mr-1">{t(locale, 'common.share')}</span>
  <a href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-rose-50 flex items-center justify-center text-charcoal-light/60 hover:bg-rose-100 hover:text-plum-700 transition-all duration-200" aria-label="Share on X">
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </a>
  <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-rose-50 flex items-center justify-center text-charcoal-light/60 hover:bg-rose-100 hover:text-plum-700 transition-all duration-200" aria-label="Share on Facebook">
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
  </a>
  <button class="copy-link w-8 h-8 rounded-full bg-rose-50 flex items-center justify-center text-charcoal-light/60 hover:bg-rose-100 hover:text-plum-700 transition-all duration-200" data-url={url} aria-label="Copy link">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
  </button>
</div>
<script>
  document.querySelectorAll('.copy-link').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url || window.location.href;
      await navigator.clipboard.writeText(url);
      const orig = btn.innerHTML;
      btn.innerHTML = '<svg class="w-3.5 h-3.5 text-plum-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
      setTimeout(() => { btn.innerHTML = orig; }, 2000);
    });
  });
</script>
