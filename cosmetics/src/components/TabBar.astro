---
import { localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const tabs = [
  {
    id: 'home', label: 'HOME', href: localePath('/', locale),
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12 L12 3 L21 12 M5 10 V20 H19 V10"/></svg>',
  },
  {
    id: 'category', label: 'READ', href: localePath('/category/skincare/', locale),
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 5 Q 12 3 20 5 V19 Q 12 17 4 19 Z M12 4 V18"/></svg>',
  },
  {
    id: 'tools', label: 'TOOLS', href: localePath('/tools/', locale),
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94L6.73 20.15a2.1 2.1 0 0 1-3-3l6.75-6.75a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  },
  {
    id: 'shop', label: 'SHOP', href: localePath('/shop/', locale),
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7 H19 L17 20 H7 Z M9 7 V5 Q 12 3 15 5 V7"/></svg>',
  },
  {
    id: 'about', label: 'MORE', href: localePath('/about/', locale),
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="6" cy="12" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="18" cy="12" r="1.5" fill="currentColor"/></svg>',
  },
];
---

<nav class="gcm-tab-bar" aria-label="Mobile primary navigation">
  {tabs.map((t) => (
    <a href={t.href} class="tab" data-tab={t.id}>
      <span class="icon" set:html={t.icon} />
      <span class="label">{t.label}</span>
      <span class="dot"></span>
    </a>
  ))}
</nav>

<style>
  .gcm-tab-bar {
    display: none;
    justify-content: space-around;
    background: var(--color-paper);
    border-top: 1.5px solid var(--color-charcoal);
    padding: 10px 12px calc(14px + env(safe-area-inset-bottom, 0px));
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 100;
  }
  .gcm-tab-bar .tab {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px;
    font-family: 'Cutive Mono', monospace; font-size: 9.5px;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-charcoal-light);
    text-decoration: none; padding: 6px 10px; border-radius: 8px;
    min-width: 44px; min-height: 44px;
  }
  .gcm-tab-bar .tab.active { color: var(--color-rose-500); }
  .gcm-tab-bar .tab .icon { display: flex; }
  .gcm-tab-bar .tab .dot {
    width: 6px; height: 6px; border-radius: 999px;
    background: var(--color-rose-500); opacity: 0; margin-top: 2px;
  }
  .gcm-tab-bar .tab.active .dot { opacity: 1; }

  @media (max-width: 900px) {
    .gcm-tab-bar { display: flex; }
    body { padding-bottom: 70px; }
  }
</style>

<script>
  const path = window.location.pathname;
  document.querySelectorAll('.gcm-tab-bar .tab').forEach((el) => {
    const id = el.getAttribute('data-tab');
    let active = false;
    if (id === 'home') active = /^\/(?:[a-z]{2}\/?)?$/.test(path);
    else if (id === 'category') active = /\/category\//.test(path);
    else if (id === 'tools') active = /\/(?:tools|quiz|ingredient-checker|ingredient-matrix|ingredients|shade-matcher)\/?/.test(path);
    else if (id === 'shop') active = /\/shop\//.test(path);
    else if (id === 'about') active = /\/(?:about|privacy|newsletter)\//.test(path);
    if (active) el.classList.add('active');
  });
</script>
