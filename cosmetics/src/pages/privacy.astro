---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Privacy Policy" description="How Glow Coded handles your data.">
  <Header />
  <main class="flex-1">
    <article class="max-w-6xl mx-auto px-5 sm:px-8 py-16">
      <div class="max-w-3xl">
        <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.2em] text-plum-300 mb-5">Legal</span>
        <h1 class="font-heading text-4xl text-charcoal tracking-tight leading-[1.1] mb-8">Privacy Policy</h1>
      </div>
      <div class="max-w-3xl prose">
        <p><em>Last updated: March 2026</em></p>
        <h2>Analytics</h2>
        <p>We use Cloudflare Web Analytics. a privacy-first, cookieless analytics tool. We see aggregate traffic data. We cannot identify individual visitors.</p>
        <h2>Email</h2>
        <p>Newsletter subscribers: we store your email only for sending our content. Unsubscribe anytime. We never sell or share email addresses.</p>
        <h2>Affiliate Disclosure</h2>
        <p>Some articles contain affiliate links. If you purchase through these links, we may earn a commission at no extra cost to you. Affiliate relationships never influence our editorial opinions or recommendations.</p>
        <h2>Cookies</h2>
        <p>This site does not use tracking cookies. Cloudflare Web Analytics is cookieless by design.</p>
        <h2>Contact</h2>
        <p>Questions? Email <strong>hello@glow-coded.com</strong>.</p>
      </div>
    </article>
  </main>
  <Footer />
</Base>
