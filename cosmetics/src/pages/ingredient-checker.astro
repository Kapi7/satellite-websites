---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import conflictData from '../data/ingredient-conflicts.json';

const dataJSON = JSON.stringify(conflictData);
---

<Base title="Ingredient Conflict Checker" description="Check if your skincare ingredients play well together. Find conflicts, safe pairings, and how to layer your routine.">
  <Header />
  <main class="flex-1">
    <section class="max-w-3xl mx-auto px-5 sm:px-8 py-12">
      <div class="mb-10 animate-fade-in-up">
        <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-plum-300 mb-2">Tool</span>
        <h1 class="font-heading text-4xl text-charcoal tracking-tight mb-3">Ingredient Conflict Checker</h1>
        <p class="text-plum-400 max-w-xl">Select the ingredients in your routine and we'll check for conflicts, cautions, and great pairings.</p>
      </div>

      <div class="bg-white border border-rose-200/40 rounded-2xl p-6 sm:p-8 shadow-sm mb-8 animate-fade-in-up stagger-1">
        <label class="block text-[11px] font-semibold uppercase tracking-[0.15em] text-plum-300 mb-3">Add Ingredients</label>
        <div class="relative">
          <select id="ingredient-select" class="w-full px-4 py-2.5 rounded-xl border border-rose-200 bg-white text-charcoal text-sm focus:outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            <option value="">Choose an ingredient...</option>
            {conflictData.ingredients.map(ing => (
              <option value={ing}>{ing}</option>
            ))}
          </select>
        </div>

        <div id="selected-chips" class="flex flex-wrap gap-2 mt-4 min-h-[2rem]"></div>
      </div>

      <div id="results-section" class="hidden animate-fade-in-up">
        <div class="mb-4">
          <h2 class="font-heading text-2xl text-charcoal tracking-tight">Results</h2>
        </div>

        <div id="conflict-red" class="hidden mb-4">
          <h3 class="flex items-center gap-2 text-sm font-semibold text-red-700 mb-2">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            Conflicts — Avoid Combining
          </h3>
          <div id="conflict-red-list" class="space-y-2"></div>
        </div>

        <div id="conflict-yellow" class="hidden mb-4">
          <h3 class="flex items-center gap-2 text-sm font-semibold text-amber-700 mb-2">
            <span class="w-3 h-3 rounded-full bg-amber-400"></span>
            Caution — Use Carefully
          </h3>
          <div id="conflict-yellow-list" class="space-y-2"></div>
        </div>

        <div id="conflict-green" class="hidden mb-4">
          <h3 class="flex items-center gap-2 text-sm font-semibold text-emerald-700 mb-2">
            <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
            Great Pairings
          </h3>
          <div id="conflict-green-list" class="space-y-2"></div>
        </div>

        <div id="no-interactions" class="hidden text-center py-8">
          <p class="text-plum-400">No known interactions between these ingredients.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <BackToTop />
</Base>

<script define:vars={{ dataJSON }}>
  const data = JSON.parse(dataJSON);
  const selected = new Set();

  const selectEl = document.getElementById('ingredient-select');
  const chipsEl = document.getElementById('selected-chips');
  const resultsEl = document.getElementById('results-section');

  selectEl?.addEventListener('change', () => {
    const val = selectEl.value;
    if (!val || selected.has(val)) { selectEl.value = ''; return; }
    selected.add(val);
    selectEl.value = '';
    render();
  });

  function render() {
    // Render chips
    chipsEl.innerHTML = '';
    selected.forEach(ing => {
      const chip = document.createElement('span');
      chip.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 bg-rose-50 text-rose-700 text-sm font-medium rounded-full';
      chip.innerHTML = `${ing}<button class="hover:text-rose-900 transition-colors" aria-label="Remove ${ing}">&times;</button>`;
      chip.querySelector('button').addEventListener('click', () => {
        selected.delete(ing);
        render();
      });
      chipsEl.appendChild(chip);
    });

    // Check conflicts
    if (selected.size < 2) {
      resultsEl.classList.add('hidden');
      return;
    }

    resultsEl.classList.remove('hidden');
    const selectedArr = [...selected];
    const found = { red: [], yellow: [], green: [] };

    for (let i = 0; i < selectedArr.length; i++) {
      for (let j = i + 1; j < selectedArr.length; j++) {
        const a = selectedArr[i];
        const b = selectedArr[j];
        const match = data.conflicts.find(c =>
          (c.a === a && c.b === b) || (c.a === b && c.b === a)
        );
        if (match) {
          found[match.severity].push({ a, b, explanation: match.explanation });
        }
      }
    }

    ['red', 'yellow', 'green'].forEach(sev => {
      const section = document.getElementById(`conflict-${sev}`);
      const list = document.getElementById(`conflict-${sev}-list`);
      if (found[sev].length > 0) {
        section.classList.remove('hidden');
        list.innerHTML = '';
        found[sev].forEach(f => {
          const colors = {
            red: 'border-red-200 bg-red-50/50',
            yellow: 'border-amber-200 bg-amber-50/50',
            green: 'border-emerald-200 bg-emerald-50/50',
          };
          const div = document.createElement('div');
          div.className = `p-4 rounded-xl border ${colors[sev]}`;
          div.innerHTML = `
            <span class="block text-sm font-medium text-charcoal mb-1">${f.a} + ${f.b}</span>
            <span class="block text-xs text-charcoal-light leading-relaxed">${f.explanation}</span>
          `;
          list.appendChild(div);
        });
      } else {
        section.classList.add('hidden');
      }
    });

    const total = found.red.length + found.yellow.length + found.green.length;
    document.getElementById('no-interactions').classList.toggle('hidden', total > 0);
  }
</script>
