---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

/* ===== Real content — all articles from MDX collection ===== */
const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getSlug = (post: any) => {
  const id = post.id as string;
  const s = id.includes('/') ? id.split('/').slice(1).join('/') : id;
  return s.replace(/\.mdx?$/, '');
};

/* Hero = most recent post; Editorial grid = next 5 */
const hero = sortedPosts[0];
const editorial = sortedPosts.slice(1, 6);
const [featured, ...rest] = editorial;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();

const readMinutes = (post: any) => {
  const body = (post.body as string) || '';
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
};

const categoryLabelOf = (c: string) => {
  const m: Record<string, string> = {
    'skincare': 'SKINCARE',
    'ingredients': 'INGREDIENTS',
    'reviews': 'REVIEWS',
    'how-tos': 'HOW-TOS',
  };
  return m[c] || c.toUpperCase();
};

/* ===== Categories — real counts from collection ===== */
const cats = [
  { slug: 'skincare', label: 'Skincare', tint: 'coral', tagline: 'From barrier to glow.' },
  { slug: 'ingredients', label: 'Ingredients', tint: 'butter', tagline: "What's actually in the bottle." },
  { slug: 'reviews', label: 'Reviews', tint: 'mint', tagline: 'We bought it. We tested it. We told you.' },
  { slug: 'how-tos', label: 'How-Tos', tint: 'sky', tagline: 'Less confusing, more glowing.' },
  { slug: 'routines', label: 'Routines', tint: 'plum', tagline: 'Morning, night, and the in-between.' },
];
const GC_CATEGORIES = cats.map((c) => {
  if (c.slug === 'routines') {
    const n = sortedPosts.filter((p) => {
      if (p.data.type === 'routine') return true;
      const title = (p.data.title || '').toLowerCase();
      const tags = (p.data.tags || []).map((t: string) => t.toLowerCase());
      return title.includes('routine') || tags.some((t: string) => t.includes('routine'));
    }).length;
    return { ...c, count: n };
  }
  return { ...c, count: sortedPosts.filter((p) => p.data.category === c.slug).length };
});

/* ===== Shop products (curated — matches prototype exactly) ===== */
const GC_PRODUCTS = [
  { slug: 'anua-cleansing-oil', name: 'Heartleaf Pore Control Cleansing Oil', brand: 'Anua', price: '$28', rating: 4.9, tag: 'STAFF PICK', image: '/images/products/anua-cleansing-oil.jpg', url: 'https://mirai-skin.com/products/anua-heartleaf-pore-control-cleansing-oil-200ml' },
  { slug: 'beauty-of-joseon-sunscreen', name: 'Relief Sun: Rice + Probiotics SPF50+', brand: 'Beauty of Joseon', price: '$18', rating: 4.8, tag: 'BESTSELLER', image: '/images/products/beauty-of-joseon-sunscreen.jpg', url: 'https://mirai-skin.com/products/beauty-joseon-relief-sun-ricex1' },
  { slug: 'cosrx-snail-essence', name: 'Advanced Snail 96 Mucin Power Essence', brand: 'COSRX', price: '$25', rating: 4.7, tag: 'CULT FAVE', image: '/images/products/cosrx-snail-essence.jpg', url: 'https://mirai-skin.com/products/cosrx-advanced-snail-96-mucin-power-essence-100ml' },
  { slug: 'laneige-lip-mask', name: 'Lip Sleeping Mask', brand: 'Laneige', price: '$24', rating: 4.6, tag: 'NEW', image: '/images/products/laneige-lip-mask.jpg', url: 'https://mirai-skin.com/products/laneige-lip-sleeping-mask-20g' },
  { slug: 'some-by-mi-toner', name: 'AHA BHA PHA 30 Days Miracle Toner', brand: 'Some By Mi', price: '$22', rating: 4.5, image: '/images/products/some-by-mi-toner.jpg', url: 'https://mirai-skin.com/products/some-by-mi-aha-bha-pha-30-days-miracle-toner' },
  { slug: 'innisfree-serum', name: 'Green Tea Ceramide Milk Barrier Essence', brand: 'Innisfree', price: '$30', rating: 4.7, image: '/images/products/innisfree-serum.jpg', url: 'https://mirai-skin.com/products/innisfree-green-tea-ceramide-milk-barrier-essence-160ml' },
];

const tintBg: Record<string, string> = {
  coral:  'repeating-linear-gradient(45deg, #ff8a7a 0 10px, #ffb0a3 10px 20px)',
  butter: 'repeating-linear-gradient(45deg, #ffd964 0 10px, #ffe89a 10px 20px)',
  mint:   'repeating-linear-gradient(45deg, #b8e0c8 0 10px, #d0eadb 10px 20px)',
  sky:    'repeating-linear-gradient(45deg, #c5dfff 0 10px, #dce9ff 10px 20px)',
  plum:   'repeating-linear-gradient(45deg, #d9bfd9 0 10px, #e6d3e6 10px 20px)',
};

const marqueeItems = [
  'NEW · Snail Mucin, Ranked',
  '14 Sunscreens Tested',
  'Free Skin Quiz',
  'K-Beauty 101',
  'Mirai Drop · April',
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Glow Coded', url: 'https://glow-coded.com',
  logo: 'https://glow-coded.com/logo.svg',
  description: 'Skincare education, honest reviews, K-Beauty picks, and ingredient breakdowns.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Glow Coded', url: 'https://glow-coded.com',
});
---

<Base
  title="Glow Coded"
  description="Skincare education, honest reviews, K-Beauty picks, and ingredient breakdowns."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} mobileTitle="GLOW CODED" />

  <div class="gcd-page desktop-home">
    {/* ===== MASTHEAD ===== */}
    <section class="gcd-masthead">
      <div>
        <div class="gcd-kicker">
          <span class="pill">K-Beauty</span>
          <span class="pill">Ingredient Science</span>
          <span class="pill">No Gatekeeping</span>
        </div>
        <h1 class="gcd-title">glow<br/><span class="i">coded</span>.</h1>
        <p class="gcd-sub">Skin science, honestly. Real routines, real reviews, and the K-beauty shelf tours you wish your friends would send you. We test before we recommend; we disclose when we get paid.</p>
      </div>
      {hero && (
        <a href={localePath(`/${getSlug(hero)}/`, locale)} class="gcd-hero-card">
          <div class="gcd-hero-ph">
            {hero.data.image ? (
              <img src={hero.data.image} alt={hero.data.title} />
            ) : (
              <div class="big">{hero.data.title[0]}</div>
            )}
          </div>
          <div class="gcd-hero-body">
            <div class="tag">THIS WEEK &middot; {categoryLabelOf(hero.data.category)}</div>
            <h3>{hero.data.title}</h3>
            <div class="meta"><span>{readMinutes(hero)} MIN READ</span><span>{(hero.data.author || formatDate(hero.data.date)).toUpperCase()}</span></div>
          </div>
        </a>
      )}
    </section>

    {/* ===== MARQUEE ===== */}
    <div class="gcd-marquee">
      <div class="track">
        {[0, 1, 2].map(() => (
          <span>
            {marqueeItems.map((t) => (
              <>
                <span>{t}</span>
                <span class="star">&#10022;</span>
              </>
            ))}
          </span>
        ))}
      </div>
    </div>

    {/* ===== EDITORIAL GRID ===== */}
    <div class="section-head">
      <h2>This week <em>in the feed</em></h2>
      <div class="meta">05 stories &middot; updated daily</div>
    </div>
    <div class="edit-grid">
      {featured && (
        <a href={localePath(`/${getSlug(featured)}/`, locale)} class="edit-card feat">
          <div class="img" style="height:420px;">
            <span class="cat">{categoryLabelOf(featured.data.category)}</span>
            {featured.data.image
              ? <img src={featured.data.image} alt={featured.data.title} />
              : <div class="ph">{featured.data.title[0]}</div>
            }
          </div>
          <div class="body">
            <h3 class="xl">{featured.data.title}</h3>
            <p>{featured.data.description}</p>
            <div class="foot"><span>{formatDate(featured.data.date)}</span><span>{readMinutes(featured)} MIN READ</span></div>
          </div>
        </a>
      )}

      {rest.slice(0, 4).map((p) => (
        <a href={localePath(`/${getSlug(p)}/`, locale)} class="edit-card">
          <div class="img small">
            <span class="cat">{categoryLabelOf(p.data.category)}</span>
            {p.data.image
              ? <img src={p.data.image} alt={p.data.title} />
              : <div class="ph">{p.data.title[0]}</div>
            }
          </div>
          <div class="body">
            <h3>{p.data.title}</h3>
            <p style="font-size:13px;">{p.data.description}</p>
            <div class="foot"><span>{formatDate(p.data.date)}</span><span>{readMinutes(p)} MIN READ</span></div>
          </div>
        </a>
      ))}
    </div>

    {/* ===== CATEGORIES STRIP ===== */}
    <div class="section-head">
      <h2>By category</h2>
      <div class="meta">{sortedPosts.length} articles &middot; {GC_CATEGORIES.length} sections</div>
    </div>
    <div class="cats-strip">
      {GC_CATEGORIES.map((c) => (
        <a href={localePath(`/category/${c.slug}/`, locale)} class="cat-tile">
          <div class="swatch" style={`background:${tintBg[c.tint] || tintBg.coral};`}>{c.label[0]}</div>
          <div class="body">
            <h4>{c.label}</h4>
            <small>{c.count} &middot; {c.tagline}</small>
          </div>
        </a>
      ))}
    </div>

    {/* ===== SHOP RAIL — THE EDIT ===== */}
    <div class="section-head" id="the-edit">
      <h2>The <em>Edit</em></h2>
      <div class="meta">K-Beauty picks &middot; via Mirai Skin</div>
    </div>
    <div class="shop-rail">
      <div class="intro">
        <h3>Curated, tested, never pushy.</h3>
        <p>Six bottles we're keeping on our shelf this month. Every product is stocked at Mirai Skin — we earn a small cut only when you shop, and never when we review.</p>
        <a href={localePath('/shop/', locale)} class="btn btn-coral">Shop the full edit &rarr;</a>
      </div>
      <div class="products">
        {GC_PRODUCTS.map((p) => (
          <a href={localePath(`/shop/#${p.slug}`, locale)} class="prod">
            <div class="img">
              {p.tag && <span class="tag-pill">{p.tag}</span>}
              <img src={p.image} alt={p.name} />
            </div>
            <div class="body">
              <div class="brand">{p.brand}</div>
              <div class="name">{p.name}</div>
              <div class="row">
                <span class="price">{p.price}</span>
                <span>&#9733; {p.rating}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    {/* ===== QUIZ + NEWSLETTER PROMO ===== */}
    <div class="quiz-promo" id="newsletter">
      <div class="quiz-big">
        <div class="label">Interactive &middot; 2 minutes</div>
        <h3>What does your <em>skin</em><br/>actually need?</h3>
        <p>Eight questions, a no-guilt routine, and honest product picks — matched to your skin type, budget, and how much effort you're willing to commit. No email required.</p>
        <a href={localePath('/quiz/', locale)} class="cta">Take the quiz <span>&rarr;</span></a>
        <div class="sticker-float">free &middot; no<br/>email<br/>required</div>
      </div>
      <div class="newsletter-block">
        <div class="label">Thursdays &middot; 10k readers</div>
        <h3>The Letter.</h3>
        <p>One honest email, every Thursday. One routine, one ingredient, one product we'd recommend to a friend. Unsubscribe anytime.</p>
        <form class="form newsletter-form" data-locale={locale}>
          <input type="email" placeholder="your@email.com" required />
          <button type="submit">Sign up</button>
        </form>
      </div>
    </div>

  </div>

  {/* ====================================================================
     MOBILE HOMEPAGE — matches prototype/index.html GCHomeScreen pixel-for-pixel
     ==================================================================== */}
  <div class="gcm-home">
    {/* Hero */}
    <section class="hero">
      <div class="issue">
        <svg width="10" height="10" viewBox="0 0 24 24"><path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z" fill="var(--color-rose-500)"/></svg>
        ISSUE NO. 042 &middot; APRIL 2026
      </div>
      <h1 class="title">
        Skincare,<br/>
        <span class="scribble">decoded.</span>
      </h1>
      <p class="tagline">
        Ingredient deep-dives, routine guides, and <span class="highlight">honest reviews</span> from people who test what they write about. No gatekeeping.
      </p>
      <span class="star1">
        <svg width="26" height="26" viewBox="0 0 24 24"><path d="M12 2 L13.5 9.5 L21 10.5 L15 15 L17 22 L12 18 L7 22 L9 15 L3 10.5 L10.5 9.5 Z" fill="var(--color-rose-500)" stroke="var(--color-rose-500)" stroke-width="1.5" stroke-linejoin="round"/></svg>
      </span>
      <span class="star2">
        <svg width="14" height="14" viewBox="0 0 24 24"><path d="M12 2 L13.5 9.5 L21 10.5 L15 15 L17 22 L12 18 L7 22 L9 15 L3 10.5 L10.5 9.5 Z" fill="var(--color-plum-700)" stroke="var(--color-plum-700)" stroke-width="1.5" stroke-linejoin="round"/></svg>
      </span>
    </section>

    {/* Dark marquee */}
    <div class="m-marquee">
      <div class="track">
        {[0, 1].map(() => (
          <>
            <span>&#10022; NEW IN &middot; DOUBLE CLEANSING 101</span>
            <span>&#10022; INGREDIENT DECODE &middot; NIACINAMIDE</span>
            <span>&#10022; REVIEWED &middot; 14 SNAIL ESSENCES</span>
            <span>&#10022; QUIZ &middot; WHAT'S YOUR SKIN TYPE?</span>
            <span>&#10022; K-BEAUTY &middot; THE BASICS</span>
          </>
        ))}
      </div>
    </div>

    {/* Feature article */}
    {featured && (
      <section class="feature">
        <div class="pre">
          <span class="dash"></span>
          THIS WEEK'S DEEP-DIVE
        </div>
        <a href={localePath(`/${getSlug(featured)}/`, locale)} class="feat-card z-card">
          {featured.data.image && <img src={featured.data.image} alt={featured.data.title} />}
          <div class="body">
            <div class="meta">
              <span class="sticker sticker-coral">{categoryLabelOf(featured.data.category)}</span>
              <span class="rt">{readMinutes(featured)} MIN READ</span>
            </div>
            <h3>{featured.data.title}</h3>
            <p>{featured.data.description}</p>
          </div>
        </a>
        <div class="sticker sticker-coral rot-r4 wiggle sticker-float">READ ME &#9829;</div>
      </section>
    )}

    {/* Browse by vibe — tilted categories */}
    <section class="cats">
      <div class="head">
        <h2>Browse by vibe</h2>
        <small>{GC_CATEGORIES.length} TOPICS</small>
      </div>
      <div class="grid">
        {GC_CATEGORIES.map((c, i) => (
          <a
            href={localePath(`/category/${c.slug}/`, locale)}
            class={`tile${i === 4 ? ' tile-wide' : ''}`}
            style={`background: var(--${c.tint === 'coral' ? 'color-rose-500' : c.tint === 'butter' ? 'butter' : c.tint === 'mint' ? 'mint' : c.tint === 'plum' ? 'color-plum-300' : 'sky'}); transform: ${i % 2 ? 'rotate(-0.8deg)' : 'rotate(0.6deg)'};`}
          >
            <div class="num">{String(i + 1).padStart(2, '0')} / {c.count} POSTS</div>
            <div class="label">{c.label}</div>
            <div class="tag">{c.tagline}</div>
          </a>
        ))}
      </div>
    </section>

    {/* Quiz card */}
    <section class="quiz-card">
      <div class="inner">
        <div style="flex:1;">
          <div class="pre">&#9733; TAKE THE QUIZ</div>
          <h3>Find your<br/>skin type</h3>
          <div class="sub">6 quick questions. No email required.</div>
          <a href={localePath('/quiz/', locale)} class="btn">START QUIZ &rarr;</a>
        </div>
        <div class="face">
          <svg width="100" height="100" viewBox="0 0 120 120">
            <ellipse cx="60" cy="65" rx="42" ry="48" fill="#ffcfc8" stroke="var(--color-charcoal)" stroke-width="1.5"/>
            <circle cx="45" cy="58" r="2.5" fill="var(--color-charcoal)"/>
            <circle cx="75" cy="58" r="2.5" fill="var(--color-charcoal)"/>
            <path d="M48 78 Q 60 88 72 78" stroke="var(--color-charcoal)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <circle cx="37" cy="70" r="4" fill="var(--color-rose-500)" opacity="0.5"/>
            <circle cx="83" cy="70" r="4" fill="var(--color-rose-500)" opacity="0.5"/>
            <path d="M22 50 Q 28 20 60 18 Q 92 20 98 50" fill="var(--color-charcoal)" stroke="var(--color-charcoal)" stroke-width="1.5"/>
            <path d="M25 48 Q 40 40 55 52" stroke="#fdfbf9" stroke-width="1" fill="none"/>
            <path d="M105 35 L107 41 L113 43 L107 45 L105 51 L103 45 L97 43 L103 41 Z" fill="var(--color-rose-500)"/>
            <path d="M15 80 L16 83 L19 84 L16 85 L15 88 L14 85 L11 84 L14 83 Z" fill="var(--butter)" stroke="var(--color-charcoal)" stroke-width="0.5"/>
          </svg>
        </div>
      </div>
    </section>

    {/* Fresh off the press */}
    <section class="fresh">
      <div class="head">
        <h2>Fresh off the press</h2>
        <a href={localePath('/category/skincare/', locale)} class="all">SEE ALL &rarr;</a>
      </div>
      {rest.slice(0, 4).map((p) => (
        <a href={localePath(`/${getSlug(p)}/`, locale)} class="row">
          {p.data.image && <img src={p.data.image} alt={p.data.title} />}
          <div style="flex:1;min-width:0;">
            <div class="cat">{categoryLabelOf(p.data.category)}</div>
            <div class="tt">{p.data.title}</div>
            <div class="meta">{readMinutes(p)} MIN &bull; {formatDate(p.data.date)}</div>
          </div>
        </a>
      ))}
    </section>

    {/* Dark shop banner */}
    <section class="shop-banner-wrap">
      <a href={localePath('/shop/', locale)} class="shop-banner">
        <div class="pre">OUR CURATED SHOP</div>
        <h3>The shelf we'd<br/><span class="y">actually buy</span></h3>
        <p>Editor-tested K-beauty picks. Ships from Mirai Skin.</p>
        <span class="cta">SHOP THE EDIT <span>&rarr;</span></span>
        <svg class="bottle" width="110" height="154" viewBox="0 0 100 140">
          <rect x="38" y="4" width="24" height="14" rx="2" fill="#1a1513"/>
          <rect x="42" y="18" width="16" height="10" fill="#1a1513"/>
          <rect x="20" y="28" width="60" height="100" rx="8" fill="#ff5a4c" stroke="#1a1513" stroke-width="1.5"/>
          <rect x="22" y="52" width="56" height="42" fill="#fdfbf9" stroke="#1a1513" stroke-width="1.2"/>
          <text x="50" y="72" text-anchor="middle" font-family="Cutive Mono, monospace" font-size="8" fill="#1a1513">MIRAI</text>
          <text x="50" y="84" text-anchor="middle" font-family="Rozha One, serif" font-size="10" fill="#1a1513">SERUM</text>
        </svg>
        <svg class="tube" width="80" height="104" viewBox="0 0 100 130">
          <rect x="20" y="2" width="60" height="16" rx="2" fill="#1a1513"/>
          <path d="M18 20 L82 20 L74 124 Q 50 130 26 124 Z" fill="#ffd964" stroke="#1a1513" stroke-width="1.5"/>
          <rect x="26" y="44" width="48" height="50" fill="#fdfbf9" stroke="#1a1513" stroke-width="1.2"/>
          <text x="50" y="64" text-anchor="middle" font-family="Cutive Mono, monospace" font-size="7" fill="#1a1513">MIRAI</text>
          <text x="50" y="78" text-anchor="middle" font-family="Rozha One, serif" font-size="11" fill="#1a1513">GLOW</text>
        </svg>
      </a>
    </section>

    {/* Newsletter card */}
    <section class="nl-card">
      <a href={localePath('/newsletter/', locale)}>
        <div class="pre">&#9993; THE LETTER</div>
        <h3>One email a week.<br/>Zero filler.</h3>
        <p>Sunday mornings. New finds, honest takes, one ingredient explained.</p>
        <span class="cta">SUBSCRIBE &rarr;</span>
      </a>
    </section>

    {/* Centered footer (inside mobile) */}
    <div class="foot">
      <div class="brand">GLOW CODED</div>
      <div class="mono">EST. 2024 &middot; MADE WITH &#9829;</div>
      <div class="mono" style="margin-top:6px;">ABOUT &middot; SHOP &middot; CONTACT &middot; PRIVACY</div>
    </div>
  </div>

  <div class="desktop-footer"><Footer locale={locale} /></div>
  <BackToTop />
</Base>

<style is:global>
  /* ===== Page container ===== */
  .gcd-page {
    max-width: 1360px;
    width: 100%;
    margin: 0 auto;
    padding: 0 32px 120px;
    box-sizing: border-box;
    overflow-x: clip;
  }

  /* Hide desktop footer when mobile layout is active */
  @media (max-width: 900px) {
    .desktop-footer { display: none; }
  }

  /* ===== Masthead ===== */
  .gcd-masthead {
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 28px;
    padding: 34px 0 28px;
    border-bottom: 2.5px solid var(--color-charcoal);
    align-items: stretch;
  }
  .gcd-title {
    font-family: 'Rozha One', serif;
    font-size: clamp(78px, 11vw, 184px);
    line-height: 0.82;
    letter-spacing: -0.02em;
    margin: 0;
    font-weight: 400;
    color: var(--color-charcoal);
  }
  .gcd-title .i { color: var(--color-rose-500); font-style: italic; font-family: 'Rozha One', serif; }
  .gcd-masthead .gcd-kicker {
    display: flex; gap: 10px; align-items: center; margin-bottom: 14px;
    font-family: 'Cutive Mono', monospace; font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-charcoal);
  }
  .gcd-masthead .gcd-kicker .pill {
