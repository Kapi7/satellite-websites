---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroSlideshow from '../../components/HeroSlideshow.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = sortedPosts.slice(0, 6);

const slides = [
  {
    image: '/images/hero-slide-1.jpg',
    title: t(locale, 'home.slideSkincare'),
    subtitle: t(locale, 'home.slideSkincareDesc'),
    category: t(locale, 'nav.skincare'),
  },
  {
    image: '/images/korean-routine-hero.jpg',
    title: 'Korean Skincare Routine: The Complete Guide',
    subtitle: 'Everything you need to know, from the 10-step method to a realistic everyday approach.',
    link: localePath('/korean-skincare-routine-complete-guide/', locale),
    category: t(locale, 'nav.skincare'),
  },
  {
    image: '/images/hero-slide-2.jpg',
    title: t(locale, 'home.slideVanity'),
    subtitle: t(locale, 'home.slideVanityDesc'),
    category: t(locale, 'nav.reviews'),
  },
  {
    image: '/images/hero-slide-3.jpg',
    title: t(locale, 'home.slideIngredients'),
    subtitle: t(locale, 'home.slideIngredientsDesc'),
    link: localePath('/niacinamide-vs-vitamin-c/', locale),
    category: t(locale, 'nav.ingredients'),
  },
];

const categories = [
  { slug: 'skincare', label: t(locale, 'categories.skincare'), emoji: '✨', desc: t(locale, 'categoryDescriptions.skincare'), count: sortedPosts.filter(p => p.data.category === 'skincare').length },
  { slug: 'ingredients', label: t(locale, 'categories.ingredients'), emoji: '🧪', desc: t(locale, 'categoryDescriptions.ingredients'), count: sortedPosts.filter(p => p.data.category === 'ingredients').length },
  { slug: 'reviews', label: t(locale, 'categories.reviews'), emoji: '💎', desc: t(locale, 'categoryDescriptions.reviews'), count: sortedPosts.filter(p => p.data.category === 'reviews').length },
  { slug: 'how-tos', label: t(locale, 'categories.howTos'), emoji: '🌸', desc: t(locale, 'categoryDescriptions.howTos'), count: sortedPosts.filter(p => p.data.category === 'how-tos').length },
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Glow Coded', url: 'https://glow-coded.com',
  logo: 'https://glow-coded.com/logo.svg',
  description: 'Skincare education, honest reviews, K-Beauty picks, and ingredient breakdowns.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Glow Coded', url: 'https://glow-coded.com',
});
---

<Base
  title="Glow Coded"
  description="Skincare education, honest reviews, K-Beauty picks, and ingredient breakdowns."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <main class="flex-1">
    <!-- Hero -->
    <div class="pt-6 animate-fade-in">
      <HeroSlideshow slides={slides} />
    </div>

    <!-- Fresh from the Lab -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 mb-16 sm:mb-24">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.latest')}</span>
          <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">{t(locale, 'home.freshFromTheLab')}</h2>
        </div>
        <a href={localePath('/category/skincare/', locale)} class="hidden sm:inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/60 hover:text-plum-700 transition-colors">
          {t(locale, 'common.viewAll')}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id}
            image={post.data.image}
            type={post.data.type}
            locale={locale}
          />
        ))}
      </div>
    </section>

    <!-- Topics We Cover -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="border-t border-rose-200/40 pt-16">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.explore')}</span>
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">{t(locale, 'home.topicsWeCover')}</h2>
          </div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {categories.map((cat) => (
            <a
              href={localePath(`/category/${cat.slug}`, locale)}
              class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-rose-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-rose-600/0 to-rose-700/0 group-hover:from-rose-600/5 group-hover:to-rose-700/10 transition-all duration-500 rounded-2xl"></div>

              <div class="relative z-10 flex flex-col items-center">
                <span class="text-4xl mb-4" aria-hidden="true">{cat.emoji}</span>
                <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-rose-700 transition-colors">{cat.label}</h3>
                <p class="text-xs text-charcoal-light/60 leading-relaxed mb-4 max-w-[180px]">{cat.desc}</p>
                <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 group-hover:text-rose-500 transition-colors">
                  {cat.count} {cat.count === 1 ? t(locale, 'common.article') : t(locale, 'common.articles')}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tools -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.interactive')}</span>
          <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">{t(locale, 'home.toolsAndGuides')}</h2>
        </div>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        <a href={localePath('/quiz/', locale)} class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-rose-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-rose-600/0 to-rose-700/0 group-hover:from-rose-600/5 group-hover:to-rose-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-rose-50 flex items-center justify-center group-hover:bg-rose-100 transition-colors">
              <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-rose-700 transition-colors">{t(locale, 'home.skinQuizTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.skinQuizDesc')}</p>
          </div>
        </a>
        <a href={localePath('/ingredients/', locale)} class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-rose-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-rose-600/0 to-rose-700/0 group-hover:from-rose-600/5 group-hover:to-rose-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-rose-50 flex items-center justify-center group-hover:bg-rose-100 transition-colors">
              <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-rose-700 transition-colors">{t(locale, 'home.ingredientGlossaryTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.ingredientGlossaryDesc')}</p>
          </div>
        </a>
        <a href={localePath('/ingredient-checker/', locale)} class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-rose-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-rose-600/0 to-rose-700/0 group-hover:from-rose-600/5 group-hover:to-rose-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-rose-50 flex items-center justify-center group-hover:bg-rose-100 transition-colors">
              <svg class="w-7 h-7 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-rose-700 transition-colors">{t(locale, 'home.conflictCheckerTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.conflictCheckerDesc')}</p>
          </div>
        </a>
      </div>
    </section>

    <!-- Quiz CTA -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="relative rounded-2xl sm:rounded-[2.5rem] bg-gradient-to-br from-plum-700 via-plum-800 to-plum-900 p-10 sm:p-16 text-center overflow-hidden">
        <div class="absolute top-[-60px] left-[-40px] w-48 h-48 bg-rose-500/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-[-80px] right-[-40px] w-64 h-64 bg-rose-400/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-plum-400/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.25em] text-rose-300/80 mb-4">{t(locale, 'home.new')}</span>
          <h2 class="font-heading text-4xl sm:text-5xl italic text-cream mb-4 leading-tight" set:html={t(locale, 'home.discoverSkinArchetype').replace('\n', '<br />')} />
          <p class="text-sm sm:text-base text-rose-200 mb-8 max-w-lg mx-auto leading-relaxed">{t(locale, 'home.quizCtaDesc')}</p>
          <a href={localePath('/quiz/', locale)} class="inline-flex items-center gap-2.5 px-9 py-3.5 bg-cream text-plum-800 text-sm font-semibold rounded-full hover:bg-white hover:shadow-lg transition-all duration-300">
            {t(locale, 'home.takeTheQuiz')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-2xl bg-rose-50 p-10 sm:p-16">
        <div class="grid sm:grid-cols-2 gap-10 sm:gap-16 items-center">
          <div>
            <img src="/logo.svg" alt="Glow Coded" class="w-32 h-32 mb-6" />
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight mb-4">{t(locale, 'home.aboutTitle')}</h2>
          </div>
          <div>
            <p class="text-sm sm:text-base text-plum-500 leading-relaxed mb-6">
              {t(locale, 'home.aboutDesc')}
            </p>
            <a href={localePath('/about/', locale)} class="inline-flex items-center gap-2 text-sm font-medium text-plum-700 hover:text-plum-900 transition-colors group">
              {t(locale, 'home.learnMore')}
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="max-w-4xl mx-auto px-5 sm:px-8 mb-20">
      <NewsletterSignup locale={locale} />
    </div>
  </main>

  <Footer locale={locale} />
  <BackToTop />
</Base>
