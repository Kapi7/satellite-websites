---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import conflictData from '../../data/ingredient-conflicts.json';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const dataJSON = JSON.stringify(conflictData);
---

<Base title={t(locale, 'ingredientChecker.title')} description={t(locale, 'ingredientChecker.description')} locale={locale}>
  <Header locale={locale} />
  <main class="flex-1">
    <section class="max-w-4xl mx-auto px-5 sm:px-8 py-12">

      <!-- Header -->
      <div class="mb-10 animate-fade-in-up">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-rose-400 mb-2 block">{t(locale, 'ingredientChecker.toolLabel')}</span>
        <h1 class="font-heading text-4xl sm:text-5xl text-charcoal tracking-tight mb-4 leading-tight">
          {t(locale, 'ingredientChecker.title')}
        </h1>
        <p class="text-charcoal-light text-lg max-w-2xl leading-relaxed">
          {t(locale, 'ingredientChecker.description')}
        </p>
      </div>

      <!-- How It Works -->
      <div id="how-it-works" class="grid grid-cols-3 gap-3 sm:gap-4 mb-6 animate-fade-in-up stagger-1">
        <div class="hint-step flex flex-col items-center text-center p-4 rounded-xl bg-white shadow-sm border border-rose-100">
          <div class="w-9 h-9 rounded-full bg-rose-100 text-rose-600 flex items-center justify-center mb-2 text-sm font-bold">1</div>
          <span class="text-xs font-medium text-charcoal leading-tight">{t(locale, 'ingredientChecker.step1')}</span>
          <span class="text-[10px] text-charcoal-light/60 mt-0.5">{t(locale, 'ingredientChecker.step1Sub')}</span>
        </div>
        <div class="hint-step flex flex-col items-center text-center p-4 rounded-xl bg-white shadow-sm border border-rose-100">
          <div class="w-9 h-9 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center mb-2 text-sm font-bold">2</div>
          <span class="text-xs font-medium text-charcoal leading-tight">{t(locale, 'ingredientChecker.step2')}</span>
          <span class="text-[10px] text-charcoal-light/60 mt-0.5">{t(locale, 'ingredientChecker.step2Sub')}</span>
        </div>
        <div class="hint-step flex flex-col items-center text-center p-4 rounded-xl bg-white shadow-sm border border-rose-100">
          <div class="w-9 h-9 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center mb-2 text-sm font-bold">3</div>
          <span class="text-xs font-medium text-charcoal leading-tight">{t(locale, 'ingredientChecker.step3')}</span>
          <span class="text-[10px] text-charcoal-light/60 mt-0.5">{t(locale, 'ingredientChecker.step3Sub')}</span>
        </div>
      </div>

      <!-- Ingredient Selection Card -->
      <div class="bg-white rounded-2xl p-6 sm:p-8 mb-6 shadow-sm animate-fade-in-up stagger-2">

        <!-- Top bar: Presets + Counter + Reset -->
        <div class="flex flex-wrap items-center gap-2.5 mb-8">
          <span class="text-[10px] font-bold uppercase tracking-widest text-charcoal-light/50 mr-1">{t(locale, 'ingredientChecker.presets')}</span>
          <button data-preset="beginner" class="preset-btn px-4 py-1.5 rounded-full border border-rose-200 text-rose-700 text-xs font-medium hover:bg-rose-50 transition-all cursor-pointer">{t(locale, 'ingredientChecker.beginnerHydration')}</button>
          <button data-preset="antiaging" class="preset-btn px-4 py-1.5 rounded-full border border-rose-200 text-rose-700 text-xs font-medium hover:bg-rose-50 transition-all cursor-pointer">{t(locale, 'ingredientChecker.antiAgingPm')}</button>
          <button data-preset="acne" class="preset-btn px-4 py-1.5 rounded-full border border-rose-200 text-rose-700 text-xs font-medium hover:bg-rose-50 transition-all cursor-pointer">{t(locale, 'ingredientChecker.acneFighter')}</button>

          <div class="flex items-center gap-2 ml-auto">
            <span id="pill-counter" class="text-[11px] font-medium text-charcoal-light/50 hidden">0 / 16</span>
            <button id="reset-btn" class="hidden px-3 py-1 rounded-full bg-charcoal/5 text-charcoal-light text-xs font-medium hover:bg-charcoal/10 transition-all cursor-pointer items-center gap-1">
              <svg class="w-3 h-3 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
              {t(locale, 'ingredientChecker.clearAll')}
            </button>
          </div>
        </div>

        <!-- Categories Grid -->
        <div class="grid gap-8">
          {Object.entries(conflictData.categories).map(([category, ings]) => (
            <div>
              <label class="text-[10px] font-bold uppercase tracking-widest text-charcoal-light/50 mb-3 block">{category}</label>
              <div class="flex flex-wrap gap-2.5">
                {(ings as string[]).map(ing => (
                  <button
                    data-ing={ing}
                    title={conflictData.descriptions[ing as keyof typeof conflictData.descriptions]}
                    class="ingredient-pill relative px-5 py-2 rounded-full border-2 border-rose-200 text-charcoal-light font-medium text-sm hover:border-rose-400 transition-all duration-200 cursor-pointer select-none"
                  >
                    <span class="pill-label relative z-10">{ing}</span>
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Legend (appears after first selection) -->
        <div id="pill-legend" class="hidden mt-6 pt-5 border-t border-rose-100">
          <div class="flex flex-wrap gap-x-5 gap-y-1 justify-center">
            <span class="flex items-center gap-1.5 text-[10px] text-charcoal-light/60"><span class="w-2.5 h-2.5 rounded-full bg-rose-600"></span> {t(locale, 'ingredientChecker.selected')}</span>
            <span class="flex items-center gap-1.5 text-[10px] text-charcoal-light/60"><span class="w-2.5 h-2.5 rounded-full bg-emerald-400 ring-2 ring-emerald-200"></span> {t(locale, 'ingredientChecker.greatPairing')}</span>
            <span class="flex items-center gap-1.5 text-[10px] text-charcoal-light/60"><span class="w-2.5 h-2.5 rounded-full bg-amber-400 ring-2 ring-amber-200"></span> {t(locale, 'ingredientChecker.useWithCaution')}</span>
            <span class="flex items-center gap-1.5 text-[10px] text-charcoal-light/60"><span class="w-2.5 h-2.5 rounded-full bg-red-500 ring-2 ring-red-200"></span> {t(locale, 'ingredientChecker.conflict')}</span>
          </div>
        </div>
      </div>

      <!-- Score Summary -->
      <div id="score-summary" class="hidden mb-6">
        <div id="score-card" class="rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-colors duration-300">
          <div class="flex items-center gap-4">
            <div id="score-icon-wrap" class="w-12 h-12 rounded-full flex items-center justify-center shrink-0 transition-colors duration-300">
              <span id="score-icon-svg"></span>
            </div>
            <div>
              <h3 id="score-verdict" class="font-heading text-lg text-charcoal leading-tight"></h3>
              <p id="score-counts" class="text-sm text-charcoal-light mt-0.5"></p>
            </div>
          </div>
          <div id="score-bar" class="w-full sm:w-48 h-2.5 rounded-full bg-white/60 overflow-hidden flex">
            <!-- segments filled by JS -->
          </div>
        </div>
      </div>

      <!-- Results -->
      <div id="results-section" class="hidden">
        <div class="grid gap-5">

          <div id="conflict-red" class="hidden">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-red-600 mb-3 block flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              {t(locale, 'ingredientChecker.conflictsAvoid')}
            </span>
            <div id="conflict-red-list" class="grid gap-3"></div>
          </div>

          <div id="conflict-yellow" class="hidden">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-amber-600 mb-3 block flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              {t(locale, 'ingredientChecker.cautionUse')}
            </span>
            <div id="conflict-yellow-list" class="grid gap-3"></div>
          </div>

          <div id="conflict-green" class="hidden">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-emerald-600 mb-3 block flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              {t(locale, 'ingredientChecker.greatPairings')}
            </span>
            <div id="conflict-green-list" class="grid gap-3"></div>
          </div>

          <div id="no-interactions" class="hidden text-center py-8">
            <p class="text-charcoal-light">{t(locale, 'ingredientChecker.noInteractions')}</p>
          </div>
        </div>
      </div>

      <!-- CTA Links -->
      <div class="grid sm:grid-cols-2 gap-4 mt-14 border-t border-rose-100 pt-8 animate-fade-in-up stagger-3">
        <a href={localePath('/skincare-ingredient-compatibility-guide/', locale)} class="group p-6 bg-cream-dark rounded-xl flex items-center gap-5 hover:bg-rose-50 transition-colors">
          <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-rose-600 shadow-sm group-hover:scale-110 transition-transform shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <div>
            <span class="block font-heading text-charcoal font-medium">{t(locale, 'ingredientChecker.compatibilityGuide')}</span>
            <span class="block text-sm text-charcoal-light">{t(locale, 'ingredientChecker.compatibilityGuideDesc')}</span>
          </div>
        </a>
        <a href={localePath('/ingredients/', locale)} class="group p-6 bg-cream-dark rounded-xl flex items-center gap-5 hover:bg-rose-50 transition-colors">
          <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-rose-600 shadow-sm group-hover:scale-110 transition-transform shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>
          </div>
          <div>
            <span class="block font-heading text-charcoal font-medium">{t(locale, 'ingredientChecker.glossary')}</span>
            <span class="block text-sm text-charcoal-light">{t(locale, 'ingredientChecker.glossaryDesc')}</span>
          </div>
        </a>
      </div>

    </section>
  </main>
  <Footer locale={locale} />
  <BackToTop />
</Base>

<script define:vars={{ dataJSON }}>
  var data = JSON.parse(dataJSON);
  var selected = new Set();
  var activePreset = null;

  var presets = {
    beginner: ['Hyaluronic Acid', 'Niacinamide', 'Ceramides', 'Snail Mucin'],
    antiaging: ['Retinol', 'Hyaluronic Acid', 'Ceramides', 'Squalane'],
    acne: ['BHA (Salicylic Acid)', 'Niacinamide', 'Tea Tree Oil', 'Centella Asiatica'],
  };

  var svgIcons = {
    conflict: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
    caution: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>',
    check: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>',
  };

  function getRelationship(ing) {
    var worst = null;
    var rank = { green: 1, yellow: 2, red: 3 };
    selected.forEach(function(sel) {
      if (sel === ing) return;
      var match = data.conflicts.find(function(c) {
        return (c.a === sel && c.b === ing) || (c.a === ing && c.b === sel);
      });
      if (match && (!worst || rank[match.severity] > rank[worst])) {
        worst = match.severity;
      }
    });
    return worst;
  }

  document.querySelectorAll('.ingredient-pill').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var ing = btn.getAttribute('data-ing');
      if (selected.has(ing)) {
        selected.delete(ing);
      } else {
        selected.add(ing);
      }
      activePreset = null;
      updateAll();
    });
  });

  document.querySelectorAll('.preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = btn.getAttribute('data-preset');
      if (activePreset === key) {
        selected.clear();
        activePreset = null;
      } else {
        selected.clear();
        presets[key].forEach(function(i) { selected.add(i); });
        activePreset = key;
      }
      updateAll();
    });
  });

  document.getElementById('reset-btn').addEventListener('click', function() {
    selected.clear();
    activePreset = null;
    updateAll();
  });

  function updateAll() {
    updatePills();
    updatePresetHighlight();
    updateCounter();
    render();
  }

  function updateCounter() {
    var counter = document.getElementById('pill-counter');
    var resetBtn = document.getElementById('reset-btn');
    var legend = document.getElementById('pill-legend');
    var howItWorks = document.getElementById('how-it-works');
    if (selected.size > 0) {
      counter.textContent = selected.size + ' / 16';
      counter.classList.remove('hidden');
      resetBtn.classList.remove('hidden');
      resetBtn.classList.add('inline-flex');
      legend.classList.remove('hidden');
      howItWorks.style.maxHeight = '0';
      howItWorks.style.opacity = '0';
      howItWorks.style.marginBottom = '0';
    } else {
      counter.classList.add('hidden');
      resetBtn.classList.add('hidden');
      resetBtn.classList.remove('inline-flex');
      legend.classList.add('hidden');
      howItWorks.style.maxHeight = '';
      howItWorks.style.opacity = '';
      howItWorks.style.marginBottom = '';
    }
  }

  function updatePresetHighlight() {
    document.querySelectorAll('.preset-btn').forEach(function(btn) {
      var key = btn.getAttribute('data-preset');
      if (activePreset === key) {
        btn.classList.add('bg-rose-600', 'text-white', 'border-rose-600');
        btn.classList.remove('text-rose-700', 'border-rose-200');
      } else {
        btn.classList.remove('bg-rose-600', 'text-white', 'border-rose-600');
        btn.classList.add('text-rose-700', 'border-rose-200');
      }
    });
  }

  function updatePills() {
    document.querySelectorAll('.ingredient-pill').forEach(function(btn) {
      var ing = btn.getAttribute('data-ing');
      btn.className = 'ingredient-pill relative px-5 py-2 rounded-full border-2 font-medium text-sm transition-all duration-200 cursor-pointer select-none';
      if (selected.has(ing)) {
        btn.classList.add('bg-rose-600', 'text-white', 'border-rose-600', 'shadow-md', 'scale-105');
      } else if (selected.size > 0) {
        var rel = getRelationship(ing);
        if (rel === 'red') {
          btn.classList.add('border-red-300', 'bg-red-50', 'text-red-700', 'pill-glow-red');
        } else if (rel === 'yellow') {
          btn.classList.add('border-amber-300', 'bg-amber-50', 'text-amber-700', 'pill-glow-amber');
        } else if (rel === 'green') {
          btn.classList.add('border-emerald-300', 'bg-emerald-50', 'text-emerald-700', 'pill-glow-green');
        } else {
          btn.classList.add('border-rose-200', 'text-charcoal-light', 'hover:border-rose-400');
        }
      } else {
        btn.classList.add('border-rose-200', 'text-charcoal-light', 'hover:border-rose-400');
      }
    });
  }

  function render() {
    var resultsEl = document.getElementById('results-section');
    var scoreEl = document.getElementById('score-summary');

    if (selected.size < 2) {
      resultsEl.classList.add('hidden');
      scoreEl.classList.add('hidden');
      return;
    }

    resultsEl.classList.remove('hidden');
    var selectedArr = Array.from(selected);
    var found = { red: [], yellow: [], green: [] };

    for (var i = 0; i < selectedArr.length; i++) {
      for (var j = i + 1; j < selectedArr.length; j++) {
        var a = selectedArr[i];
        var b = selectedArr[j];
        var match = data.conflicts.find(function(c) {
          return (c.a === a && c.b === b) || (c.a === b && c.b === a);
        });
        if (match) {
          found[match.severity].push({ a: a, b: b, explanation: match.explanation });
        }
      }
    }

    var rc = found.red.length;
    var yc = found.yellow.length;
    var gc = found.green.length;
    var total = rc + yc + gc;

    scoreEl.classList.remove('hidden');
    var scoreCard = document.getElementById('score-card');
    var iconWrap = document.getElementById('score-icon-wrap');
    var iconSvg = document.getElementById('score-icon-svg');
    var verdictEl = document.getElementById('score-verdict');
    var countsEl = document.getElementById('score-counts');
    var scoreBar = document.getElementById('score-bar');

    if (rc > 0) {
      scoreCard.className = 'rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-colors duration-300 bg-red-50 border border-red-200/50';
      iconWrap.className = 'w-12 h-12 rounded-full flex items-center justify-center shrink-0 bg-red-100 text-red-600';
      iconSvg.innerHTML = svgIcons.conflict;
      verdictEl.textContent = rc === 1 ? '1 conflict found' : rc + ' conflicts found';
    } else if (yc > 0) {
      scoreCard.className = 'rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-colors duration-300 bg-amber-50 border border-amber-200/50';
      iconWrap.className = 'w-12 h-12 rounded-full flex items-center justify-center shrink-0 bg-amber-100 text-amber-600';
      iconSvg.innerHTML = svgIcons.caution;
      verdictEl.textContent = 'Minor cautions \u2014 overall looks good';
    } else if (gc > 0) {
      scoreCard.className = 'rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-colors duration-300 bg-emerald-50 border border-emerald-200/50';
      iconWrap.className = 'w-12 h-12 rounded-full flex items-center justify-center shrink-0 bg-emerald-100 text-emerald-600';
      iconSvg.innerHTML = svgIcons.check;
      verdictEl.textContent = 'Your routine looks great!';
    } else {
      scoreCard.className = 'rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-colors duration-300 bg-cream-dark';
      iconWrap.className = 'w-12 h-12 rounded-full flex items-center justify-center shrink-0 bg-plum-50 text-plum-400';
      iconSvg.innerHTML = svgIcons.check;
      verdictEl.textContent = 'No known interactions';
    }

    var parts = [];
    if (gc > 0) parts.push(gc + ' great pairing' + (gc > 1 ? 's' : ''));
    if (yc > 0) parts.push(yc + ' caution' + (yc > 1 ? 's' : ''));
    if (rc > 0) parts.push(rc + ' conflict' + (rc > 1 ? 's' : ''));
    countsEl.textContent = parts.length > 0 ? parts.join(' \u00B7 ') : 'No interactions found';

    if (total > 0) {
      var gPct = Math.round((gc / total) * 100);
      var yPct = Math.round((yc / total) * 100);
      var rPct = Math.round((rc / total) * 100);
      scoreBar.innerHTML =
        (gc > 0 ? '<div class="h-full bg-emerald-400 transition-all duration-500" style="width:' + gPct + '%"></div>' : '') +
        (yc > 0 ? '<div class="h-full bg-amber-400 transition-all duration-500" style="width:' + yPct + '%"></div>' : '') +
        (rc > 0 ? '<div class="h-full bg-red-400 transition-all duration-500" style="width:' + rPct + '%"></div>' : '');
      scoreBar.classList.remove('hidden');
    } else {
      scoreBar.classList.add('hidden');
    }

    var cardStyles = {
      red: { bg: 'bg-red-50/60 border-red-200/60', label: 'text-red-800', desc: 'text-red-900/70', iconColor: 'text-red-300' },
      yellow: { bg: 'bg-amber-50/60 border-amber-200/60', label: 'text-amber-800', desc: 'text-amber-900/70', iconColor: 'text-amber-300' },
      green: { bg: 'bg-emerald-50/60 border-emerald-200/60', label: 'text-emerald-800', desc: 'text-emerald-900/70', iconColor: 'text-emerald-300' },
    };

    var bgIcons = {
      red: '<svg class="w-28 h-28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
      yellow: '<svg class="w-28 h-28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>',
      green: '<svg class="w-28 h-28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>',
    };

    ['red', 'yellow', 'green'].forEach(function(sev) {
      var section = document.getElementById('conflict-' + sev);
      var list = document.getElementById('conflict-' + sev + '-list');
      var style = cardStyles[sev];

      if (found[sev].length > 0) {
        section.classList.remove('hidden');
        list.innerHTML = '';
        found[sev].forEach(function(f, idx) {
          var div = document.createElement('div');
          div.className = 'p-5 rounded-xl border ' + style.bg + ' relative overflow-hidden opacity-0';
          div.style.animation = 'cardFadeIn 0.35s ease-out ' + (idx * 0.07) + 's forwards';

          var learnMore = '';
          if (sev === 'red' || sev === 'yellow') {
            learnMore = '<a href="/skincare-ingredient-compatibility-guide/" class="inline-flex items-center gap-1 mt-2 text-xs font-semibold text-rose-600 hover:text-rose-800 transition-colors">Learn more <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>';
          }

          div.innerHTML =
            '<div class="absolute -top-3 -right-3 opacity-[0.06] ' + style.iconColor + '">' + bgIcons[sev] + '</div>' +
            '<div class="relative z-10">' +
            '<h4 class="font-heading text-lg font-medium ' + style.label + ' mb-2">' + f.a + ' + ' + f.b + '</h4>' +
            '<p class="text-sm ' + style.desc + ' leading-relaxed">' + f.explanation + '</p>' +
            learnMore +
            '</div>';
          list.appendChild(div);
        });
      } else {
        section.classList.add('hidden');
      }
    });

    document.getElementById('no-interactions').classList.toggle('hidden', total > 0);
  }
</script>

<style>
  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #how-it-works {
    max-height: 200px;
    opacity: 1;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin-bottom 0.4s ease;
  }

  .pill-glow-red {
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
  }
  .pill-glow-amber {
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
  }
  .pill-glow-green {
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
  }

  .ingredient-pill.scale-105 {
    transform: scale(1.05);
  }

  .hint-step {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
</style>
