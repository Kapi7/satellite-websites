---
import Pillar from '../../../layouts/Pillar.astro';
import { locales, defaultLocale, type Locale } from '../../../i18n/locales';
import { t } from '../../../i18n/utils';

export function getStaticPaths() {
  const categories = ['skincare', 'ingredients', 'reviews', 'how-tos'];
  const paths: { params: { locale?: string; cat: string }; props: { locale: Locale } }[] = [];

  for (const l of locales) {
    for (const cat of categories) {
      paths.push({
        params: { locale: l === defaultLocale ? undefined : l, cat },
        props: { locale: l },
      });
    }
  }

  return paths;
}

const { locale } = Astro.props as { locale: Locale };

const categoryMetaKeys: Record<string, { titleKey: string; descKey: string }> = {
  'skincare': { titleKey: 'categories.skincare', descKey: 'categoryDescriptions.skincare' },
  'ingredients': { titleKey: 'categories.ingredients', descKey: 'categoryDescriptions.ingredients' },
  'reviews': { titleKey: 'categories.reviews', descKey: 'categoryDescriptions.reviews' },
  'how-tos': { titleKey: 'categories.howTos', descKey: 'categoryDescriptions.howTos' },
};

const { cat } = Astro.params;
const meta = categoryMetaKeys[cat!] || { titleKey: cat, descKey: '' };
---

<Pillar
  title={t(locale, meta.titleKey)}
  description={t(locale, meta.descKey)}
  category={cat!}
  locale={locale}
/>
