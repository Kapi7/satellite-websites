---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

/* "Recent issues" list = 4 most-recent articles from the blog collection */
const now = new Date();
const all = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const recent = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 4);

const getSlug = (post: any) => {
  const id = post.id as string;
  const s = id.includes('/') ? id.split('/').slice(1).join('/') : id;
  return s.replace(/\.mdx?$/, '');
};
const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();

const schema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebPage',
  name: 'The Letter \u2014 Glow Coded newsletter',
  url: 'https://glow-coded.com/newsletter/',
  description: 'One honest email every Thursday. One routine, one ingredient, one product we would recommend to a friend.',
});
---

<Base
  title="The Letter \u2014 Glow Coded"
  description="One honest email every Thursday. One routine, one ingredient, one product we'd recommend to a friend."
  jsonLd={[schema]}
  locale={locale}
>
  <Header locale={locale} mobileTitle="THE LETTER" />
  <main class="gcd-newsletter">
    <div class="gcd-kicker">
      <span class="pill">&#10022; THE LETTER</span>
      <span>Thursdays &middot; 10,243 readers</span>
    </div>

    <h1>One honest <em>email</em>,<br/>every Thursday.</h1>

    <p class="lede">
      One routine we'd actually use. One ingredient we've been testing. One product we'd recommend to a friend \u2014 at a price we'd actually pay. No drops-every-day nonsense.
    </p>

    <div class="signup">
      <form class="form newsletter-form" data-locale={locale}>
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe &rarr;</button>
      </form>
      <p class="fine">NO SPAM. UNSUBSCRIBE ANY TIME. FREE FOREVER.</p>
    </div>

    <section class="recent">
      <h2>Recent issues</h2>
      <div class="list">
        {recent.map((p, i) => (
          <a href={localePath(`/${getSlug(p)}/`, locale)} class="row">
            <div class="num">&#8470;{String(i + 1).padStart(2, '0')}</div>
            <div class="body">
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
            </div>
            <div class="date">{formatDate(p.data.date)}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
  <BackToTop />
</Base>

<style is:global>
  .gcd-newsletter {
    max-width: 820px;
    margin: 60px auto;
    padding: 0 32px 80px;
  }
  .gcd-newsletter .gcd-kicker {
    display: flex; gap: 10px; align-items: center;
    margin-bottom: 18px;
    font-family: 'Cutive Mono', monospace; font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-charcoal);
  }
  .gcd-newsletter .gcd-kicker .pill {
    padding: 4px 10px; border: 1.3px solid var(--color-charcoal); border-radius: 999px;
  }

  .gcd-newsletter h1 {
    font-family: 'Rozha One', serif; font-weight: 400;
    font-size: clamp(64px, 10vw, 112px);
    line-height: 0.88; letter-spacing: -0.02em;
    margin: 18px 0 24px;
    color: var(--color-charcoal);
  }
  .gcd-newsletter h1 em {
    font-style: italic; color: var(--color-rose-500);
  }

  .gcd-newsletter .lede {
    font-family: 'DM Sans', sans-serif;
    font-size: 19px; line-height: 1.55;
    color: var(--color-charcoal-light);
    max-width: 680px; margin: 0 0 34px;
  }

  .gcd-newsletter .signup {
    background: var(--color-rose-500);
    border: 1.5px solid var(--color-charcoal);
    border-radius: 8px;
    padding: 30px;
    box-shadow: 6px 6px 0 var(--color-charcoal);
  }
  .gcd-newsletter .signup .form {
    display: flex; gap: 10px;
  }
  .gcd-newsletter .signup input {
    flex: 1; padding: 14px 18px;
    border: 1.5px solid var(--color-charcoal);
    border-radius: 999px;
    font-family: 'DM Sans', sans-serif; font-size: 15px;
    outline: none;
    background: var(--color-cream);
    color: var(--color-charcoal);
  }
  .gcd-newsletter .signup input::placeholder {
    color: rgba(26, 21, 19, 0.4);
  }
  .gcd-newsletter .signup button {
    background: var(--color-charcoal); color: #fff;
    border: 1.5px solid var(--color-charcoal);
    padding: 14px 26px;
    border-radius: 999px;
    font-family: 'Cutive Mono', monospace;
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    cursor: pointer;
  }
  .gcd-newsletter .signup .fine {
    color: #fff3e9; font-size: 12px; margin: 14px 0 0;
    font-family: 'Cutive Mono', monospace;
    letter-spacing: 0.1em; text-transform: uppercase;
  }

  .gcd-newsletter .recent { margin-top: 56px; }
  .gcd-newsletter .recent h2 {
    font-family: 'Rozha One', serif; font-size: 40px;
    letter-spacing: -0.01em; font-weight: 400;
    margin: 0 0 20px; color: var(--color-charcoal);
  }
  .gcd-newsletter .list { display: grid; gap: 0; }
  .gcd-newsletter .row {
    display: grid; grid-template-columns: 80px 1fr auto;
    gap: 20px; align-items: center;
    padding: 18px 0;
    border-top: 1.5px solid var(--color-charcoal);
    text-decoration: none; color: inherit;
    transition: background 0.15s;
  }
  .gcd-newsletter .row:hover { background: rgba(0,0,0,0.02); }
  .gcd-newsletter .row .num {
    font-family: 'Rozha One', serif; font-size: 44px;
    color: var(--color-rose-500);
  }
  .gcd-newsletter .row h3 {
    font-family: 'Rozha One', serif; font-weight: 400;
    font-size: 26px; line-height: 1.05; margin: 0 0 4px;
    color: var(--color-charcoal);
  }
  .gcd-newsletter .row p {
    font-size: 13.5px; color: var(--color-charcoal-light); margin: 0;
  }
  .gcd-newsletter .row .date {
    font-family: 'Cutive Mono', monospace; font-size: 10.5px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-charcoal-light);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .gcd-newsletter { margin: 24px auto; padding: 0 20px 80px; }
    .gcd-newsletter h1 { font-size: 48px; }
    .gcd-newsletter .signup { padding: 22px; }
    .gcd-newsletter .signup .form { flex-direction: column; }
    .gcd-newsletter .signup button { padding: 12px 18px; }
    .gcd-newsletter .recent h2 { font-size: 32px; }
    .gcd-newsletter .row { grid-template-columns: 60px 1fr; gap: 14px; }
    .gcd-newsletter .row .num { font-size: 32px; }
    .gcd-newsletter .row h3 { font-size: 20px; }
    .gcd-newsletter .row .date { display: none; }
  }
</style>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const input = f.querySelector('input[type="email"]') as HTMLInputElement;
      const btn = f.querySelector('button') as HTMLButtonElement;
      const email = input.value.trim();
      if (!email) return;
      btn.disabled = true;
      try {
        await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, locale: (f as HTMLElement).dataset.locale || 'en' }),
        });
        btn.textContent = 'Done';
      } catch {
        btn.textContent = 'Retry';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
</Base>
