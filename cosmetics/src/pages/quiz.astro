---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
---

<Base title="AI Skin Analysis | Glow Coded" description="Get a personalized skin analysis and product recommendations powered by AI.">
  <Header />
  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-4 sm:px-8 py-8 sm:py-12">
      <div class="text-center mb-8 animate-fade-in">
        <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-plum-300 mb-2">Personalized</span>
        <h1 class="font-heading text-4xl sm:text-5xl text-charcoal tracking-tight mb-4">AI Skin Analysis</h1>
        <p class="text-lg text-plum-500 max-w-xl mx-auto">Upload a photo or answer a few questions to get a personalized skincare routine and product recommendations.</p>
      </div>

      <div class="rounded-2xl overflow-hidden border border-rose-200/40 bg-white shadow-sm animate-fade-in-up stagger-1">
        <iframe
          id="quiz-iframe"
          src="https://mirai-skin-ai.onrender.com/?shop=9dkd2w-g3.myshopify.com&currency=USD&embedded=true&inline=true"
          style="width: 100%; min-height: 600px; height: 800px; border: none; display: block;"
          allow="camera"
          title="AI Skin Analysis"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </main>
  <Footer />
  <BackToTop />

  <script is:inline>
    window.addEventListener('message', function(event) {
      if (!event.data || !event.data.type) return;
      if (event.data.type === 'mirai:resize' && event.data.height) {
        var iframe = document.getElementById('quiz-iframe');
        if (iframe) iframe.style.height = Math.max(600, event.data.height) + 'px';
      }
      if (event.data.type === 'mirai:scroll-top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  </script>
</Base>
