---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
---

<Base title="AI Skin Analysis | Glow Coded" description="Get a personalized skin analysis and product recommendations powered by AI.">
  <Header />
  <main class="flex-1">
    <div id="quiz-wrapper" class="animate-fade-in">
      <iframe
        id="quiz-iframe"
        src="https://mirai-skin-ai.onrender.com/?shop=9dkd2w-g3.myshopify.com&currency=USD&embedded=true&inline=true"
        style="width: 100%; min-height: 100vh; height: 100vh; border: none; display: block; background: transparent;"
        allow="camera"
        title="AI Skin Analysis"
      ></iframe>
    </div>
  </main>
  <Footer />
  <BackToTop />

  <style>
    #quiz-wrapper {
      width: 100%;
      overflow: hidden;
    }
    #quiz-iframe {
      width: 100%;
      border: none;
      display: block;
    }
  </style>

  <script is:inline>
    (function() {
      var iframe = document.getElementById('quiz-iframe');
      window.addEventListener('message', function(e) {
        if (!e.data || !e.data.type) return;
        if (e.data.type === 'mirai:resize' && e.data.height) {
          iframe.style.height = Math.max(600, e.data.height) + 'px';
        }
        if (e.data.type === 'mirai:scroll-top') {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    })();
  </script>
</Base>
