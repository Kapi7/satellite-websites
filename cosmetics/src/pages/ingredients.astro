---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { getCollection } from 'astro:content';

const allIngredients = await getCollection('ingredients');
const ingredients = allIngredients.sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...new Set(ingredients.map(i => i.data.category))].sort();

const ingredientsData = JSON.stringify(ingredients.map(i => ({
  slug: i.data.slug,
  name: i.data.name,
  category: i.data.category,
  benefits: i.data.benefits,
  skinTypes: i.data.skinTypes,
  comedogenicRating: i.data.comedogenicRating,
  description: i.data.description,
  relatedProducts: i.data.relatedProducts,
  pairsWith: i.data.pairsWith,
  conflicts: i.data.conflicts,
})));
---

<Base
  title="Ingredient Glossary"
  description="A searchable guide to popular skincare ingredients: what they do, who they're for, and what they pair with."
>
  <Header />
  <main class="flex-1">
    <section class="max-w-6xl mx-auto px-5 sm:px-8 py-12">
      <div class="mb-10 animate-fade-in-up">
        <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-plum-300 mb-2">Reference</span>
        <h1 class="font-heading text-4xl text-charcoal tracking-tight mb-3">Ingredient Glossary</h1>
        <p class="text-plum-400 max-w-xl">Search and filter skincare ingredients. Learn what they do, which skin types benefit, and what products contain them.</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 mb-8 animate-fade-in-up stagger-1">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-plum-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <input
            type="text"
            id="ingredient-search"
            placeholder="Search ingredients..."
            class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-rose-200 bg-white text-charcoal text-sm placeholder:text-plum-300 focus:outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all"
          />
        </div>
        <select
          id="category-filter"
          class="px-4 py-2.5 rounded-xl border border-rose-200 bg-white text-charcoal text-sm focus:outline-none focus:border-rose-400 transition-all"
        >
          <option value="">All Categories</option>
          {categories.map(cat => (
            <option value={cat}>{cat.charAt(0).toUpperCase() + cat.slice(1)}</option>
          ))}
        </select>
      </div>

      <div id="ingredients-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 animate-fade-in-up stagger-2">
        {ingredients.map(ing => (
          <div
            class="ingredient-card group p-6 rounded-2xl border border-rose-200/40 bg-white hover:shadow-lg hover:border-rose-300 transition-all duration-300"
            data-name={ing.data.name.toLowerCase()}
            data-category={ing.data.category}
            data-skin-types={ing.data.skinTypes.join(',')}
          >
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-heading text-lg text-charcoal group-hover:text-rose-700 transition-colors">{ing.data.name}</h3>
              <span class="text-[10px] font-semibold uppercase tracking-[0.1em] text-plum-300 bg-plum-50 px-2 py-0.5 rounded-full shrink-0 ml-2">{ing.data.category}</span>
            </div>
            <p class="text-sm text-plum-400 leading-relaxed mb-4">{ing.data.description}</p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              {ing.data.benefits.slice(0, 3).map(b => (
                <span class="text-[10px] font-medium text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">{b}</span>
              ))}
            </div>
            <div class="flex items-center justify-between text-[10px] text-plum-300 uppercase tracking-[0.1em]">
              <span>Comedogenic: {ing.data.comedogenicRating}/5</span>
              <span>{ing.data.skinTypes.join(', ')}</span>
            </div>
            {ing.data.relatedProducts.length > 0 && (
              <div class="mt-4 pt-3 border-t border-rose-100/60">
                <span class="text-[10px] font-semibold uppercase tracking-[0.1em] text-plum-300 block mb-1.5">Found in</span>
                {ing.data.relatedProducts.map(p => (
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="block text-xs text-rose-600 hover:text-rose-800 transition-colors mb-0.5">{p.name} &rarr;</a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <p id="no-results" class="hidden text-center text-plum-400 py-12">No ingredients match your search.</p>
    </section>
  </main>
  <Footer />
  <BackToTop />
</Base>

<script>
  const search = document.getElementById('ingredient-search') as HTMLInputElement;
  const filter = document.getElementById('category-filter') as HTMLSelectElement;
  const cards = document.querySelectorAll('.ingredient-card');
  const noResults = document.getElementById('no-results');

  function filterCards() {
    const q = search.value.toLowerCase().trim();
    const cat = filter.value;
    let visible = 0;

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const matchName = !q || el.dataset.name!.includes(q);
      const matchCat = !cat || el.dataset.category === cat;
      const show = matchName && matchCat;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults!.classList.toggle('hidden', visible > 0);
  }

  search.addEventListener('input', filterCards);
  filter.addEventListener('change', filterCards);
</script>
