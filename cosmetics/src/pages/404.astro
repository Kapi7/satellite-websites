---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Browse our latest articles on Korean skincare, beauty ingredients, and product reviews."
>
  <Header />

  <main class="flex-1 flex items-center justify-center py-20 sm:py-28 px-5">
    <div class="max-w-xl mx-auto text-center animate-fade-in-up">
      <!-- 404 number -->
      <p class="text-8xl sm:text-9xl font-heading font-bold text-rose-200 leading-none mb-2 select-none">
        404
      </p>

      <!-- Heading -->
      <h1 class="text-3xl sm:text-4xl font-heading text-charcoal mb-4">
        Page Not Found
      </h1>

      <!-- Message -->
      <p class="text-base text-plum-400 leading-relaxed mb-8 max-w-md mx-auto">
        This page seems to have disappeared from our routine. Let's get you back on track with some great reads.
      </p>

      <!-- Back to Home button -->
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-rose-500 text-cream text-sm font-medium rounded-full hover:bg-rose-600 transition-colors duration-200 mb-14"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Home
      </a>

      <!-- Popular articles -->
      <div class="border-t border-rose-200/40 pt-10">
        <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-plum-300 mb-5">
          Popular Articles
        </h2>
        <ul class="space-y-3">
          <li>
            <a
              href="/korean-skincare-routine-complete-guide"
              class="text-sm text-plum-500 hover:text-charcoal transition-colors duration-200 underline decoration-rose-200 underline-offset-2 hover:decoration-rose-400"
            >
              Korean Skincare Routine: The Complete Guide
            </a>
          </li>
          <li>
            <a
              href="/best-korean-beauty-products-by-category"
              class="text-sm text-plum-500 hover:text-charcoal transition-colors duration-200 underline decoration-rose-200 underline-offset-2 hover:decoration-rose-400"
            >
              Best Korean Beauty Products by Category
            </a>
          </li>
          <li>
            <a
              href="/how-to-build-a-skincare-routine-from-scratch"
              class="text-sm text-plum-500 hover:text-charcoal transition-colors duration-200 underline decoration-rose-200 underline-offset-2 hover:decoration-rose-400"
            >
              How to Build a Skincare Routine From Scratch
            </a>
          </li>
        </ul>
      </div>
    </div>
  </main>

  <Footer />
</Base>
