    "heading": "\u0397 \u03a3\u03b5\u03bb\u03af\u03b4\u03b1 \u0394\u03b5\u03bd \u0392\u03c1\u03ad\u03b8\u03b7\u03ba\u03b5",
    "message": "\u0391\u03c5\u03c4\u03ae \u03b7 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03c6\u03b1\u03af\u03bd\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03ad\u03c7\u03b5\u03b9 \u03c7\u03b1\u03b8\u03b5\u03af \u03b1\u03c0\u03cc \u03c4\u03bf \u03b5\u03c1\u03b3\u03b1\u03c3\u03c4\u03ae\u03c1\u03b9\u03bf. \u0391\u03c2 \u03c3\u03b5 \u03b2\u03bf\u03b7\u03b8\u03ae\u03c3\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03b5\u03c0\u03b9\u03c3\u03c4\u03c1\u03ad\u03c8\u03b5\u03b9\u03c2 \u03c3\u03c4\u03bf \u03c3\u03c9\u03c3\u03c4\u03cc \u03b4\u03c1\u03cc\u03bc\u03bf \u03bc\u03b5 \u03bc\u03b5\u03c1\u03b9\u03ba\u03ad\u03c2 \u03c5\u03c0\u03ad\u03c1\u03bf\u03c7\u03b5\u03c2 \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ad\u03c2.",
