---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/locales';
import { t, localePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  category: string;
  locale?: Locale;
}

const { title, description, category, locale = 'en' } = Astro.props;

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => {
  return data.category === category && !data.draft && data.locale === locale && data.date <= now;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: title },
  ],
});
---

<Base title={title} description={description} jsonLd={[breadcrumbSchema]} locale={locale}>
  <Header locale={locale} />

  <main class="flex-1">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 py-16">
      <nav class="flex items-center gap-2 text-[11px] uppercase tracking-wide text-charcoal-light/50 mb-10" aria-label="Breadcrumb">
        <a href={localePath('/', locale)} class="hover:text-steel-700 transition-colors">{t(locale, 'common.home')}</a>
        <svg class="w-3 h-3 text-steel-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span class="font-medium">{title}</span>
      </nav>

      <header class="mb-14 max-w-3xl">
        <span class="inline-block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-4">{t(locale, 'common.category')}</span>
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl text-charcoal tracking-tight leading-[1.08] mb-5">
          {title}
        </h1>
        <p class="text-lg sm:text-xl text-charcoal-light/60 leading-relaxed max-w-2xl">{description}</p>
      </header>

      <div class="border-t border-steel-200/30 pt-12" data-pagefind-body>
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id}
              image={post.data.image}
              type={post.data.type}
              locale={locale}
            />
          ))}
        </div>
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-24">
          <p class="text-charcoal-light/60 font-heading text-2xl">Articles coming soon.</p>
          <p class="text-sm text-charcoal-light/50 mt-2">We're working on this section. Check back shortly.</p>
        </div>
      )}
    </div>
  </main>

  <Footer locale={locale} />
</Base>
