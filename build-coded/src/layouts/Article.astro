---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';
import type { Locale } from '../i18n/locales';
import { t, localePath, formatDate } from '../i18n/utils';

interface Props {
  title: string; description: string; date: Date; updated?: Date;
  category: string; tags?: string[]; image?: string; imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
  type?: string;
  difficulty?: string;
  estimatedTime?: string;
  estimatedCost?: string;
  author?: string;
  locale?: Locale;
}

const { title, description, date, updated, category, tags = [], image, imageAlt, headings, slug, rawContent, type, difficulty, estimatedTime, estimatedCost, author, locale = 'en' } = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];
const readingTime = rawContent ? Math.max(1, Math.ceil(rawContent.split(/\s+/).length / 200)) : null;

const categoryLabels: Record<string, string> = {
  'woodworking': t(locale, 'categories.woodworking'),
  'home-improvement': t(locale, 'categories.homeImprovement'),
  'electronics': t(locale, 'categories.electronics'),
  'crafts': t(locale, 'categories.crafts'),
};
const categoryLabel = categoryLabels[category] || category;

const tintByCategory: Record<string, string> = {
  'woodworking': 'wood',
  'home-improvement': 'steel',
  'electronics': 'electronics',
  'crafts': 'craft',
};
const tint = tintByCategory[category] || 'wood';

const formattedDate = formatDate(date, locale);
const formattedUpdated = updated ? formatDate(updated, locale) : undefined;
const articleUrl = new URL(localePath(`/${slug}`, locale), Astro.site).href;

const authorObj = author
  ? { '@type': 'Person', name: author }
  : { '@type': 'Organization', name: 'Build Coded Editorial' };

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image, url: articleUrl,
  datePublished: date.toISOString(), dateModified: updated?.toISOString() || date.toISOString(),
  author: authorObj,
  publisher: { '@type': 'Organization', name: 'Build Coded', url: 'https://build-coded.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  inLanguage: locale,
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(localePath(`/category/${category}`, locale), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
  ],
});

const schemas = [articleSchema, breadcrumbSchema];

if (type === 'guide' && headings) {
  const stepHeadings = headings.filter(
    (h) => h.depth === 3 && /^(\d+[\.\)]\s|step\s|day\s)/i.test(h.text)
  );
  if (stepHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const steps = stepHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let text = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (text) break; continue; }
          text = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return { '@type': 'HowToStep', name: h.text, text: text || h.text };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'HowTo',
      name: title, description, step: steps, inLanguage: locale,
    }));
  }
}

if (headings) {
  const questionHeadings = headings.filter(
    (h) => (h.depth === 2 || h.depth === 3) && h.text.trim().endsWith('?')
  );
  if (questionHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const faqEntries = questionHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let answer = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (answer) break; continue; }
          answer = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return {
        '@type': 'Question', name: h.text,
        acceptedAnswer: { '@type': 'Answer', text: answer || h.text },
      };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: faqEntries, inLanguage: locale,
    }));
  }
}

if (type === 'listicle' && headings) {
  const listHeadings = headings.filter(
    (h) => h.depth === 2 && /^(\d+[\.\)]\s|best|top|\w+\s#?\d)/i.test(h.text)
  );
  if (listHeadings.length >= 3) {
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'ItemList',
      name: title, numberOfItems: listHeadings.length,
      itemListElement: listHeadings.map((h, i) => ({
        '@type': 'ListItem', position: i + 1, name: h.text,
        url: `${articleUrl}#${h.slug}`,
      })),
    }));
  }
}

// Split title for italic accent treatment on last word
const titleWords = title.split(' ');
const titleLead = titleWords.slice(0, -1).join(' ');
const titleTail = titleWords[titleWords.length - 1];
const authorInitial = author ? author[0].toUpperCase() : 'B';
const authorDisplay = author || t(locale, 'article.editorial');
---

<Base
  title={title} description={description} image={image} type="article"
  jsonLd={schemas}
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={(updated || date).toISOString()}
  articleSection={categoryLabel}
  articleTags={tags}
  locale={locale}
>
  <ReadingProgress />
  <Header locale={locale} />
  <main class="flex-1">
    <div class="bcd-article-page">
      <nav class="bcd-crumbs" aria-label="Breadcrumb">
        <a href={localePath('/', locale)}>{t(locale, 'common.home')}</a>
        <span>&rsaquo;</span>
        <a href={localePath(`/category/${category}/`, locale)}>{categoryLabel}</a>
      </nav>

      <div class="article-wrap">
        <article data-pagefind-body class="article-main">
          <div class="bcd-kicker animate-fade-in">
            <span>&#9670;</span>
            <span>{categoryLabel.toUpperCase()}</span>
            {readingTime && (<><span>&middot;</span><span>{readingTime} {t(locale, 'common.minRead').toUpperCase()}</span></>)}
          </div>

          <h1 class="bcd-title animate-fade-in-up">
            {titleLead}{titleLead ? ' ' : ''}<em>{titleTail}</em>
          </h1>

          <p class="bcd-lede animate-fade-in-up stagger-1">{description}</p>

          <div class="bcd-byline animate-fade-in-up stagger-1">
            <div class="bcd-avatar">{authorInitial}</div>
            <div>BY {authorDisplay.toUpperCase()} &middot; {formattedDate}
              {formattedUpdated && (<> &middot; {t(locale, 'common.updated').toUpperCase()} {formattedUpdated}</>)}
            </div>
          </div>

          {(difficulty || estimatedTime || estimatedCost) && (
            <div class="bcd-specs-row animate-fade-in-up stagger-2">
              {difficulty && (<div class="cell"><small>{t(locale, 'common.difficulty').toUpperCase()}</small><b>{difficulty}</b></div>)}
              {estimatedCost && (<div class="cell"><small>{t(locale, 'common.estimatedCost').toUpperCase()}</small><b>{estimatedCost}</b></div>)}
              {estimatedTime && (<div class="cell"><small>{t(locale, 'common.estimatedTime').toUpperCase()}</small><b>{estimatedTime}</b></div>)}
              {readingTime && (<div class="cell"><small>READ</small><b>{readingTime} min</b></div>)}
            </div>
          )}

          {image && (
            <div class="bcd-hero-img animate-fade-in-up stagger-2">
              <img src={image} alt={imageAlt || title} loading="eager" width="1200" height="675" />
            </div>
          )}

          {!image && (
            <div class={`bcd-hero-img bc-ph bc-ph-${tint} animate-fade-in-up stagger-2`}>
              <span class="bcd-hero-big">{title[0]}</span>
            </div>
          )}

          <div class="animate-fade-in-up stagger-2">
            <TableOfContents headings={headings} locale={locale} />
          </div>

          <div class="prose body-text"><slot /></div>

          {tags.length > 0 && (
            <div class="bcd-tags">
              <span class="bcd-tags-label">{t(locale, 'common.tagged')}</span>
              <div class="bcd-tags-list">
                {tags.map((tag) => (<span class="bcd-tag">{tag}</span>))}
              </div>
            </div>
          )}

          <ShareButtons title={title} url={articleUrl} locale={locale} />
        </article>

        <aside class="bcd-aside">
          {products.length > 0 && (
            <div class="aside-box">
              <h5>{t(locale, 'common.featuredProducts').toUpperCase()}</h5>
              <div class="aside-list">
                {products.slice(0, 3).map((product) => (
                  <a href={product.url} target="_blank" rel="noopener noreferrer" class="aside-item">
                    <div class="aside-thumb">
                      <img src={product.image} alt={product.name} loading="lazy" />
                    </div>
                    <div>
                      <h6>{product.name}</h6>
                      <small>{t(locale, 'common.shopNow')} &rarr;</small>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="aside-box aside-newsletter">
            <h5>THE BLUEPRINT</h5>
            <p>{t(locale, 'newsletter.description') || 'Weekly project plans, free, in your inbox.'}</p>
            <NewsletterSignup locale={locale} compact />
          </div>
        </aside>
      </div>

      <div class="bcd-below-fold">
        <RelatedArticles currentSlug={slug} category={category} locale={locale} />
      </div>
    </div>
  </main>
  <Footer locale={locale} />
  <BackToTop locale={locale} />

  <style>
    .bcd-article-page {
      max-width: 1360px;
      margin: 0 auto;
      padding: 32px 32px 80px;
    }

    .bcd-crumbs {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 22px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--pencil);
    }
    .bcd-crumbs a {
      color: var(--pencil);
      text-decoration: none;
    }
    .bcd-crumbs a:hover { color: var(--safety); }

    .article-wrap {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 60px;
      padding-top: 20px;
    }

    .bcd-kicker {
      display: flex;
      gap: 10px;
      align-items: center;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--safety);
      margin-bottom: 18px;
    }

    .bcd-title {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: clamp(42px, 6vw, 72px);
      line-height: 0.95;
      letter-spacing: -0.015em;
      margin: 0 0 22px;
      color: var(--ink);
      text-transform: uppercase;
    }
    .bcd-title em {
      font-style: italic;
      color: var(--safety);
      font-weight: 500;
      text-transform: none;
    }

    .bcd-lede {
      font-size: 20px;
      line-height: 1.5;
      color: var(--ink-soft);
      max-width: 720px;
      margin: 0 0 26px;
    }

    .bcd-byline {
      display: flex;
      gap: 18px;
      align-items: center;
      padding: 14px 0;
      border-top: 1.5px solid var(--ink);
      border-bottom: 1.5px solid var(--ink);
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink);
    }
    .bcd-avatar {
      width: 38px;
      height: 38px;
      border: 1.5px solid var(--ink);
      background: var(--amber);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 16px;
      flex-shrink: 0;
    }

    .bcd-specs-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      padding: 22px 0;
      border-bottom: 1.5px solid var(--ink);
      margin-bottom: 30px;
    }
    .bcd-specs-row .cell small {
      display: block;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--pencil);
      margin-bottom: 4px;
    }
    .bcd-specs-row .cell b {
      font-family: var(--font-heading);
      font-size: 22px;
      font-weight: 700;
      color: var(--ink);
    }

    .bcd-hero-img {
      margin: 30px 0;
      height: 480px;
      border: 1.5px solid var(--ink);
      border-radius: 4px;
      position: relative;
      overflow: hidden;
    }
    .bcd-hero-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .bcd-hero-big {
      font-family: var(--font-heading);
      font-size: 260px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.3);
      text-shadow: 6px 6px 0 var(--ink);
      line-height: 0.9;
    }

    .body-text {
      color: var(--ink-soft);
    }
    .body-text :global(p) {
      font-size: 17px;
      line-height: 1.75;
      margin: 0 0 1.2em;
      max-width: 740px;
    }
    .body-text :global(h2) {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 36px;
      letter-spacing: -0.005em;
      margin: 1.4em 0 0.5em;
      color: var(--ink);
      text-transform: uppercase;
      padding-top: 12px;
      border-top: 1px dashed var(--rule);
    }
    .body-text :global(h3) {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 22px;
      letter-spacing: -0.005em;
      margin: 1.4em 0 0.4em;
      color: var(--ink);
    }
    .body-text :global(ul), .body-text :global(ol) {
      padding-left: 24px;
      margin: 0 0 1.3em;
      max-width: 740px;
    }
    .body-text :global(li) {
      font-size: 16px;
      line-height: 1.75;
      margin-bottom: 10px;
      color: var(--ink-soft);
    }
    .body-text :global(img) {
      max-width: 100%;
      width: 100%;
      border-radius: 4px;
      border: 1.5px solid var(--ink);
      margin: 24px 0;
      display: block;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.1);
    }
    .body-text :global(a) {
      color: var(--steel);
      text-decoration: underline;
      text-decoration-color: var(--steel-light);
      text-underline-offset: 3px;
    }
    .body-text :global(a:hover) {
      color: var(--ink);
      text-decoration-color: var(--safety);
    }
    .body-text :global(strong) {
      font-weight: 700;
      color: var(--ink);
    }
    .body-text :global(blockquote) {
      font-family: var(--font-heading);
      font-style: italic;
      font-size: 32px;
      line-height: 1.18;
      border-left: 4px solid var(--safety);
      padding: 6px 0 6px 22px;
      margin: 30px 0;
      max-width: 680px;
      color: var(--ink);
      font-weight: 500;
    }
    .body-text :global(blockquote p) {
      font-size: inherit;
      line-height: inherit;
      margin: 0;
      max-width: none;
    }

    .bcd-tags {
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1.5px solid var(--ink);
    }
    .bcd-tags-label {
      font-family: var(--font-mono);
      font-size: 10.5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--pencil);
      margin-right: 12px;
    }
    .bcd-tags-list {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }
    .bcd-tag {
      padding: 4px 12px;
      background: var(--paper-warm);
      color: var(--ink);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: 1px solid var(--ink);
      border-radius: 2px;
    }

    .bcd-aside {
      position: sticky;
      top: 40px;
      align-self: start;
      padding-top: 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .aside-box {
      border: 1.5px solid var(--ink);
      border-radius: 4px;
      padding: 20px;
      background: var(--paper-light);
    }
    .aside-box h5 {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin: 0 0 14px;
      padding-bottom: 10px;
      border-bottom: 1.5px solid var(--ink);
      color: var(--ink);
    }
    .aside-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .aside-item {
      display: flex;
      gap: 12px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      padding: 10px 0;
      border-bottom: 1px dashed var(--rule);
    }
    .aside-item:last-child { border-bottom: none; }
    .aside-thumb {
      width: 60px;
      height: 60px;
      flex: none;
      border: 1.3px solid var(--ink);
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    }
    .aside-thumb img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .aside-item h6 {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 14px;
      line-height: 1.2;
      margin: 0 0 3px;
    }
    .aside-item small {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--pencil);
    }

    .aside-newsletter {
      background: var(--ink);
      color: var(--paper-light);
      border-color: var(--ink);
    }
    .aside-newsletter h5 {
      color: var(--amber);
      border-color: rgba(243, 237, 225, 0.2);
    }
    .aside-newsletter p {
      font-size: 13px;
      line-height: 1.5;
      margin: 0 0 14px;
    }

    .bcd-below-fold { margin-top: 60px; }

    @media (max-width: 1100px) {
      .article-wrap { grid-template-columns: 1fr; }
      .bcd-aside {
        position: static;
        padding-top: 40px;
        border-top: 1.5px solid var(--ink);
        margin-top: 40px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      .aside-newsletter { grid-column: 1 / -1; }
    }
    @media (max-width: 768px) {
      .bcd-article-page { padding: 20px 18px 60px; }
      .bcd-title { font-size: 40px; line-height: 1.0; }
      .bcd-lede { font-size: 17px; }
      .bcd-hero-img { height: 260px; margin: 22px 0; }
      .bcd-hero-big { font-size: 140px; }
      .bcd-specs-row { grid-template-columns: 1fr 1fr; }
      .bcd-aside { grid-template-columns: 1fr; }
      .body-text :global(blockquote) { font-size: 22px; }
      .body-text :global(h2) { font-size: 26px; }
    }
  </style>

  <script>
    document.querySelectorAll('.prose table').forEach((table) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'table-expand-wrapper';
      const header = document.createElement('div');
      header.className = 'table-expand-header';
      const btn = document.createElement('button');
      btn.className = 'table-expand-btn';
      const expandSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>';
      const collapseSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14h6v6M14 10h6V4M3 21l7-7M21 3l-7 7"/></svg>';
      btn.textContent = 'Expand Full Screen';
      btn.insertAdjacentHTML('afterbegin', expandSvg + ' ');
      btn.addEventListener('click', () => {
        const isExpanded = wrapper.classList.toggle('expanded');
        btn.textContent = isExpanded ? ' Collapse' : ' Expand Full Screen';
        btn.insertAdjacentHTML('afterbegin', isExpanded ? collapseSvg : expandSvg);
        if (isExpanded) { document.body.style.overflow = 'hidden'; } else { document.body.style.overflow = ''; }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && wrapper.classList.contains('expanded')) btn.click();
      });
      header.appendChild(btn);
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(header);
      wrapper.appendChild(table);
    });
  </script>
</Base>
