---
import { t, type Locale } from '../i18n/utils';

interface Props {
  headings: { depth: number; slug: string; text: string }[];
  locale?: Locale;
}
const { headings, locale = 'en' } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

{filteredHeadings.length > 2 && (
  <nav class="border border-steel-200/60 rounded-2xl p-6 mb-10 bg-cream-dark/30">
    <h2 class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-4">{t(locale, 'common.inThisArticle')}</h2>
    <ul class="space-y-2">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-5' : ''}>
          <a
            href={`#${heading.slug}`}
            class={`text-sm transition-colors duration-200 hover:text-amber-800 ${
              heading.depth === 2 ? 'text-amber-600 font-medium' : 'text-charcoal-light/60'
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
