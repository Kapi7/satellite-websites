---
import { t, type Locale } from '../i18n/utils';

interface Props {
  name: string;
  url: string;
  tag?: string;
  locale?: Locale;
}

const { name, url, tag = 'buildcoded-20', locale = 'en' } = Astro.props;

// Append affiliate tag to Amazon URL if not already present
const affiliateUrl = url.includes('tag=') ? url : `${url}${url.includes('?') ? '&' : '?'}tag=${tag}`;
---

<aside class="my-8 border border-steel-200 rounded-xl p-6 bg-steel-50/60">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1">
      <p class="text-xs text-amber-600 uppercase tracking-wider font-semibold mb-1">{t(locale, 'product.recommended')}</p>
      <h4 class="font-heading font-semibold text-steel-900 mb-2">{name}</h4>
    </div>
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow sponsored"
      class="inline-flex items-center gap-2 px-6 py-3 bg-amber-500 text-steel-900 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-colors duration-200 shadow-sm hover:shadow-md shrink-0"
    >
      {t(locale, 'product.viewOnAmazon')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
    </a>
  </div>
  <p class="mt-3 text-[10px] text-steel-400">
    {t(locale, 'product.affiliateDisclosure')} <a href="/privacy/" class="underline hover:text-steel-600 transition-colors">{t(locale, 'product.disclosureLink')}</a>.
  </p>
</aside>
