---
import { locales, localeNativeNames, type Locale } from '../i18n/locales';
import { getPathWithoutLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = getPathWithoutLocale(Astro.url);
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-trigger"
    class="flex items-center gap-1.5 text-sm text-charcoal-light/60 hover:text-steel-600 transition-colors cursor-pointer px-2 py-1 rounded-lg hover:bg-steel-50/60"
    aria-label="Change language"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>
    <span class="text-xs font-medium">{localeNativeNames[locale]}</span>
    <svg class="w-3 h-3 transition-transform duration-200" id="lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
  </button>
  <div id="lang-panel" class="hidden absolute top-full right-0 mt-2 w-44 bg-white rounded-xl shadow-lg border border-steel-100/60 overflow-hidden z-50">
    {locales.map((l) => {
      const href = l === 'en' ? currentPath : `/${l}${currentPath}`;
      return (
        <a
          href={href}
          class={`block px-4 py-2.5 text-sm transition-colors ${l === locale ? 'bg-steel-50 text-steel-700 font-medium' : 'text-charcoal-light/70 hover:bg-steel-50/60 hover:text-steel-600'}`}
        >
          {localeNativeNames[l]}
        </a>
      );
    })}
  </div>
</div>

<script>
  const trigger = document.getElementById('lang-trigger');
  const panel = document.getElementById('lang-panel');
  const chevron = document.getElementById('lang-chevron');
  let open = false;

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    open = !open;
    panel?.classList.toggle('hidden', !open);
    chevron?.classList.toggle('rotate-180', open);
  });

  document.addEventListener('click', (e) => {
    if (open && !document.getElementById('lang-switcher')?.contains(e.target as Node)) {
      open = false;
      panel?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    }
  });
</script>
