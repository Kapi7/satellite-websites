---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const navItems = [
  { key: 'home', label: t(locale, 'nav.home'), href: localePath('/', locale) },
  { key: 'departments', label: t(locale, 'nav.departments'), href: localePath('/departments/', locale), match: ['/departments/', '/category/'] },
  { key: 'freeTools', label: t(locale, 'nav.freeTools'), href: localePath('/free-tools/', locale), match: ['/free-tools/', '/tool-finder/', '/cost-calculator/', '/idea-generator/'] },
  { key: 'newsletter', label: t(locale, 'nav.newsletter'), href: localePath('/#newsletter', locale) },
  { key: 'about', label: t(locale, 'nav.about'), href: localePath('/about/', locale) },
];

const departments = [
  { label: t(locale, 'nav.woodworking'), href: localePath('/category/woodworking/', locale) },
  { label: t(locale, 'nav.homeImprovement'), href: localePath('/category/home-improvement/', locale) },
  { label: t(locale, 'nav.electronics'), href: localePath('/category/electronics/', locale) },
  { label: t(locale, 'nav.crafts'), href: localePath('/category/crafts/', locale) },
];

const tools = [
  { label: t(locale, 'nav.toolFinder'), href: localePath('/tool-finder/', locale) },
  { label: t(locale, 'nav.costCalculator'), href: localePath('/cost-calculator/', locale) },
  { label: t(locale, 'nav.ideaGenerator'), href: localePath('/idea-generator/', locale) },
];

const now = new Date();
const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const issueStamp = `VOL. IV \u00b7 ${monthNames[now.getMonth()]} ${now.getFullYear()}`;
---
<header class="bcd-header sticky top-0 z-50" id="site-header">
  <div class="bcd-top-wrap">
    <!-- Desktop top bar -->
    <div class="bcd-top">
      <a href={localePath('/', locale)} class="brand" aria-label="Build Coded">
        <span class="sq"></span>
        <span class="brand-mark">BUILD CODED</span>
      </a>
      <nav class="links" aria-label="Primary">
        {navItems.map((item) => (
          item.external ? (
            <a href={item.href} class="bcd-top-link" data-nav-key={item.key} target="_blank" rel="noopener noreferrer">{item.label}</a>
          ) : (
            <a href={item.href} class="bcd-top-link" data-nav-key={item.key} data-match={Array.isArray(item.match) ? item.match.join(',') : (item.match || '')}>{item.label}</a>
          )
        ))}
      </nav>
      <div class="issue">
        <span class="dot"></span>{issueStamp}
      </div>
    </div>

    <!-- Mobile top bar (matches prototype phone header: hamburger left, centered brand, search right) -->
    <div class="bcd-top-mobile">
      <button id="mobile-menu-btn" class="bcd-menu-btn" aria-label={t(locale, 'common.openMenu')}>
        <span id="menu-icon-open" class="bcd-hamburger">
          <span style="width: 22px;"></span>
          <span style="width: 18px;"></span>
          <span style="width: 22px;"></span>
        </span>
        <svg id="menu-icon-close" class="hidden" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
      <a href={localePath('/', locale)} class="brand brand-centered" aria-label="Build Coded">
        <span class="sq-nested"><span class="sq-nested-inner"></span></span>
        <span class="brand-mark">BUILD CODED</span>
      </a>
      <button class="bcd-search-btn" aria-label="Search" onclick="window.location.href='/'; return false;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="M16 16 L21 21" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden bcd-mobile-menu">
    <nav>
      {navItems.map((item) => (
        item.external ? (
          <a href={item.href} class="bcd-mobile-link" data-nav-key={item.key} target="_blank" rel="noopener noreferrer">{item.label}</a>
        ) : (
          <a href={item.href} class="bcd-mobile-link" data-nav-key={item.key}>{item.label}</a>
        )
      ))}
      <div class="bcd-mobile-section">
        <span class="bcd-mobile-section-label">{t(locale, 'nav.departments')}</span>
        {departments.map((d) => (
          <a href={d.href} class="bcd-mobile-link">{d.label}</a>
        ))}
      </div>
      <div class="bcd-mobile-section">
        <span class="bcd-mobile-section-label">{t(locale, 'nav.tools')}</span>
        {tools.map((tool) => (
          <a href={tool.href} class="bcd-mobile-link">{tool.label}</a>
        ))}
      </div>
      <div class="bcd-mobile-section">
        <LanguageSwitcher locale={locale} />
      </div>
    </nav>
  </div>
</header>

<style>
  .bcd-header {
    background: var(--paper-light);
    border-bottom: 1.5px solid var(--ink);
  }
  .bcd-top-wrap {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .bcd-top {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 28px;
    padding: 16px 0 14px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
  }
  .brand .sq {
    width: 14px; height: 14px;
    background: var(--safety);
    border: 1.5px solid var(--ink);
    display: inline-block;
  }
  .brand .brand-mark {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .links {
    display: flex;
    gap: 4px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .bcd-top-link {
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
    padding: 6px 12px;
    border: 1.5px solid transparent;
    border-radius: 2px;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    transition: all 0.15s;
  }
  .bcd-top-link:hover { border-color: var(--ink); }
  .bcd-top-link.active {
    background: var(--ink);
    color: var(--paper-light);
  }
  .issue {
    text-align: right;
    color: var(--pencil);
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: flex-end;
  }
  .issue .dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    background: var(--safety);
    margin-right: 6px;
    vertical-align: 2px;
  }
  .bcd-header-actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-left: 8px;
  }
  .bcd-dark-btn {
    border: none;
    background: none;
    cursor: pointer;
    padding: 4px;
    color: var(--ink);
  }
  .bcd-top-mobile { display: none; }

  /* Mobile styles */
  @media (max-width: 960px) {
    .bcd-top { display: none; }
    .bcd-top-mobile {
      display: grid;
      grid-template-columns: 36px 1fr 36px;
      align-items: center;
      padding: 14px 0 12px;
    }
    .bcd-top-mobile .brand-centered {
      display: flex;
      align-items: center;
      gap: 7px;
      justify-self: center;
    }
    .bcd-top-mobile .brand-mark {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 16px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .sq-nested {
      width: 16px;
      height: 16px;
      background: var(--safety);
      position: relative;
      display: inline-block;
    }
    .sq-nested-inner {
      position: absolute;
      inset: 3px;
      background: var(--paper-light);
      display: block;
    }
    .bcd-hamburger {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    .bcd-hamburger span {
      height: 2px;
      background: var(--ink);
      display: block;
    }
    .bcd-menu-btn,
    .bcd-search-btn {
      border: none;
      background: transparent;
      padding: 6px 0;
      cursor: pointer;
      color: var(--ink);
      justify-self: start;
    }
    .bcd-search-btn { justify-self: end; }
    .bcd-top-wrap { padding: 0 18px; }
  }

  .bcd-mobile-menu {
    background: var(--paper-light);
    border-top: 1.5px solid var(--ink);
  }
  .bcd-mobile-menu nav {
    max-width: 1360px;
    margin: 0 auto;
    padding: 14px 18px 20px;
  }
  .bcd-mobile-link {
    display: block;
    padding: 12px 0;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dashed var(--rule);
  }
  .bcd-mobile-link.active { color: var(--safety); }
  .bcd-mobile-section {
    padding-top: 14px;
    margin-top: 8px;
    border-top: 1.5px solid var(--ink);
  }
  .bcd-mobile-section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--pencil);
    margin-bottom: 6px;
  }
  .hidden { display: none; }
</style>

<script>
  function setActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll('[data-nav-key]').forEach((el) => {
      const key = el.getAttribute('data-nav-key');
      const match = el.getAttribute('data-match') || '';
      let isActive = false;
      if (key === 'home') {
        isActive = path === '/' || !!path.match(/^\/[a-z]{2}\/?$/);
      } else if (match) {
        isActive = match.split(',').some((m) => m && path.startsWith(m));
      } else {
        const href = el.getAttribute('href') || '';
        isActive = href !== '/' && path.startsWith(href);
      }
      if (isActive) el.classList.add('active');
    });
  }
  setActiveNav();

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
  });

  const toggleDark = () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };
  document.getElementById('dark-mode-toggle')?.addEventListener('click', toggleDark);
</script>
