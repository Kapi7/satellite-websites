---
import DifficultyBadge from './DifficultyBadge.astro';
import { t, type Locale } from '../i18n/utils';

interface Props {
  difficulty?: 'beginner' | 'intermediate' | 'advanced';
  estimatedTime?: string;
  estimatedCost?: string;
  locale?: Locale;
}

const { difficulty, estimatedTime, estimatedCost, locale = 'en' } = Astro.props;
const hasContent = difficulty || estimatedTime || estimatedCost;
---

{hasContent && (
  <div class="flex flex-wrap items-center gap-4 sm:gap-6 px-5 py-4 rounded-xl bg-steel-50/60 border border-steel-200/40 mb-8">
    {difficulty && (
      <div class="flex items-center gap-2">
        <DifficultyBadge difficulty={difficulty} locale={locale} />
      </div>
    )}

    {estimatedTime && (
      <div class="flex items-center gap-2 text-sm text-charcoal-light/70">
        <svg class="w-4 h-4 text-steel-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="font-medium text-charcoal">{t(locale, 'project.time')}:</span>
        {estimatedTime}
      </div>
    )}

    {estimatedCost && (
      <div class="flex items-center gap-2 text-sm text-charcoal-light/70">
        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="font-medium text-charcoal">{t(locale, 'project.cost')}:</span>
        {estimatedCost}
      </div>
    )}
  </div>
)}
