---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t } from '../../i18n/utils';

export async function getStaticPaths() {
  const paths: { params: { locale?: string }; props: { locale: Locale } }[] = [];

  for (const l of locales) {
    paths.push({
      params: { locale: l === defaultLocale ? undefined : l },
      props: { locale: l },
    });
  }

  return paths;
}

const { locale } = Astro.props as { locale: Locale };

const allPages = await getCollection('pages');
const aboutPage = allPages.find(p => p.id.includes('about') && p.data.locale === locale)
  || allPages.find(p => p.id.includes('about') && p.data.locale === 'en');

let Content: any = null;
let pageTitle = t(locale, 'about.title');
let pageDesc = t(locale, 'about.description');

if (aboutPage) {
  const rendered = await render(aboutPage);
  Content = rendered.Content;
  pageTitle = aboutPage.data.title;
  pageDesc = aboutPage.data.description;
}
---

<Base title={pageTitle} description={pageDesc} locale={locale}>
  <Header locale={locale} />
  <main class="flex-1">
    <article class="bcd-tool-wrap">
      <div class="bcd-kicker">&sect; {t(locale, 'about.label').toUpperCase()} &middot; EST. 2024</div>
      <h1 class="bcd-tool-title">DIY, <em>honestly.</em></h1>
      <p class="bcd-tool-lede">{t(locale, 'about.description')}</p>
      <div class="prose" style="max-width: 760px; padding-top: 20px; border-top: 1.5px solid var(--ink); margin-top: 24px;">
        {Content ? <Content /> : (
          <p>{pageDesc}</p>
        )}
      </div>
    </article>
  </main>
  <Footer locale={locale} />
</Base>
