---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const slugOf = (p: any) => (p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id).replace('.mdx', '').replace('.md', '');

const departments = [
  {
    slug: 'woodworking', label: t(locale, 'categories.woodworking'), icon: 'saw',
    desc: t(locale, 'departments.descWoodworking'), tint: 'wood',
    recent: sortedPosts.filter(p => p.data.category === 'woodworking').slice(0, 3),
    count: sortedPosts.filter(p => p.data.category === 'woodworking').length,
  },
  {
    slug: 'home-improvement', label: t(locale, 'categories.homeImprovement'), icon: 'wrench',
    desc: t(locale, 'departments.descHome'), tint: 'steel',
    recent: sortedPosts.filter(p => p.data.category === 'home-improvement').slice(0, 3),
    count: sortedPosts.filter(p => p.data.category === 'home-improvement').length,
  },
  {
    slug: 'electronics', label: t(locale, 'categories.electronics'), icon: 'chip',
    desc: t(locale, 'departments.descElectronics'), tint: 'electronics',
    recent: sortedPosts.filter(p => p.data.category === 'electronics').slice(0, 3),
    count: sortedPosts.filter(p => p.data.category === 'electronics').length,
  },
  {
    slug: 'crafts', label: t(locale, 'categories.crafts'), icon: 'brush',
    desc: t(locale, 'departments.descCrafts'), tint: 'craft',
    recent: sortedPosts.filter(p => p.data.category === 'crafts').slice(0, 3),
    count: sortedPosts.filter(p => p.data.category === 'crafts').length,
  },
];
---

<Base title={t(locale, 'nav.departments')} description={t(locale, 'departments.description')} locale={locale}>
  <Header locale={locale} />
  <main class="flex-1">
    <!-- Masthead band -->
    <section class="bcdp-mast">
      <div class="bcdp-mast-inner">
        <div class="mono bcdp-mast-kicker">&sect; {t(locale, 'nav.departments').toUpperCase()} &middot; 04 {t(locale, 'departments.benches')}</div>
        <h1 class="bcdp-mast-title">
          {t(locale, 'home.fourBenches')}<br/>
          <em>{t(locale, 'home.oneHouse')}.</em>
        </h1>
        <p class="bcdp-mast-lede">{t(locale, 'departments.lede')}</p>
      </div>
    </section>

    <!-- Department rows — one editorial strip per dept -->
    <div class="bcdp-rows">
      {departments.map((cat, i) => (
        <section class={`bcdp-row bcdp-row-${cat.tint}`}>
          <div class="bcdp-row-inner">
            <div class="bcdp-row-head">
              <div class={`bcdp-icon-box bcdp-icon-${cat.tint}`}>
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  {cat.icon === 'saw' && (
                    <>
                      <path d="M3 8 L20 8 L21 11 L14 11"/>
                      <path d="M3 8 L4 14 L6 12 L7 14 L9 12 L10 14 L12 12 L13 14"/>
                      <rect x="14" y="7" width="2.5" height="5"/>
                    </>
                  )}
                  {cat.icon === 'wrench' && (<path d="M14 5 A4 4 0 1 0 19 10 L21 12 L12 21 L3 12 L12 3 Z"/>)}
                  {cat.icon === 'chip' && (
                    <>
                      <rect x="6" y="6" width="12" height="12"/>
                      <rect x="9" y="9" width="6" height="6"/>
                      <path d="M3 9 H6 M3 12 H6 M3 15 H6 M18 9 H21 M18 12 H21 M18 15 H21 M9 3 V6 M12 3 V6 M15 3 V6 M9 18 V21 M12 18 V21 M15 18 V21"/>
                    </>
                  )}
                  {cat.icon === 'brush' && (<path d="M9 15 L4 20 L6 22 L11 17 M9 15 L12 12 L18 6 A2 2 0 0 1 21 9 L15 15 L12 18 Z"/>)}
                </svg>
              </div>
              <div class="bcdp-row-headtext">
                <div class="mono bcdp-row-label">DEPT &middot; 0{i + 1}</div>
                <h2 class="bcdp-row-title">{cat.label}</h2>
                <div class="mono bcdp-row-meta">{cat.count} {t(locale, 'home.plansShort') || 'plans'} &middot; {cat.desc}</div>
              </div>
              <a href={localePath(`/category/${cat.slug}/`, locale)} class="bcdp-row-cta mono">{t(locale, 'departments.viewAll') || 'VIEW ALL'} &rarr;</a>
            </div>

            {cat.recent.length > 0 && (
              <div class="bcdp-recent">
                {cat.recent.map((post: any) => (
                  <a href={localePath('/' + slugOf(post) + '/', locale)} class="bcdp-recent-card">
                    <div class={`bcdp-recent-ph bc-ph bc-ph-${cat.tint}`}>
                      {post.data.image && (<img src={post.data.image} alt={post.data.title}  loading="lazy" decoding="async" />)}
                    </div>
                    <div class="bcdp-recent-body">
                      <h4 class="bcdp-recent-title">{post.data.title}</h4>
                      <div class="mono bcdp-recent-meta">
                        {Math.max(4, Math.ceil((post.body?.length || 3000) / 1200))} min &middot; {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </section>
      ))}
    </div>
  </main>
  <div class="bc-desktop-home">
    <Footer locale={locale} />
  </div>
</Base>

<style>
  main { background: var(--paper-light); }

  /* Masthead */
  .bcdp-mast {
    background: var(--paper-warm);
    border-bottom: 1.5px solid var(--ink);
    padding: 44px 0 36px;
  }
  .bcdp-mast-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .bcdp-mast-kicker {
    color: var(--pencil);
    margin-bottom: 14px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .bcdp-mast-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(44px, 7vw, 88px);
    line-height: 0.95;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 18px;
    text-transform: uppercase;
  }
  .bcdp-mast-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--safety);
    text-transform: none;
  }
  .bcdp-mast-lede {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 620px;
    margin: 0;
  }

  /* Department rows */
  .bcdp-rows { padding: 0; }
  .bcdp-row {
    border-bottom: 1.5px solid var(--ink);
    padding: 32px 0;
  }
  .bcdp-row-wood { background: var(--paper-light); }
  .bcdp-row-steel { background: var(--paper-warm); }
  .bcdp-row-electronics { background: var(--paper-light); }
  .bcdp-row-craft { background: var(--paper-warm); }

  .bcdp-row-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .bcdp-row-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: center;
    margin-bottom: 22px;
  }
  .bcdp-icon-box {
    width: 68px;
    height: 68px;
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .bcdp-icon-wood { background: #b48a5a; color: var(--ink); }
  .bcdp-icon-steel { background: var(--steel); color: #dce5ed; }
  .bcdp-icon-electronics { background: #2a3e29; color: #dce5ed; }
  .bcdp-icon-craft { background: #e9b89e; color: var(--ink); }

  .bcdp-row-label {
    color: var(--pencil);
    font-size: 10px;
    letter-spacing: 0.18em;
    margin-bottom: 4px;
  }
  .bcdp-row-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 28px;
    line-height: 1;
    color: var(--ink);
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: -0.005em;
  }
  .bcdp-row-meta {
    color: var(--pencil);
    font-size: 10.5px;
  }
  .bcdp-row-cta {
    color: var(--ink);
    text-decoration: none;
    font-size: 11px;
    padding: 10px 16px;
    border: 1.5px solid var(--ink);
    border-radius: 2px;
    background: var(--paper-light);
    transition: all 0.15s;
    white-space: nowrap;
  }
  .bcdp-row-cta:hover { background: var(--ink); color: var(--paper-light); }

  .bcdp-recent {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .bcdp-recent-card {
    display: flex;
    flex-direction: column;
    background: var(--paper-light);
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .bcdp-recent-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--ink);
  }
  .bcdp-recent-ph {
    position: relative;
    height: 120px;
    border-bottom: 1.5px solid var(--ink);
    overflow: hidden;
  }
  .bcdp-recent-ph img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bcdp-recent-body { padding: 12px 14px 14px; }
  .bcdp-recent-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 8px;
    text-transform: none;
    letter-spacing: -0.005em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bcdp-recent-meta {
    color: var(--pencil);
    font-size: 9.5px;
  }

  @media (max-width: 960px) {
    .bcdp-mast { padding: 24px 0 20px; }
    .bcdp-mast-inner { padding: 0 18px; }
    .bcdp-row { padding: 22px 0; }
    .bcdp-row-inner { padding: 0 18px; }
    .bcdp-row-head {
      grid-template-columns: auto 1fr;
      gap: 14px;
      margin-bottom: 16px;
    }
    .bcdp-row-cta {
      grid-column: 1 / -1;
      text-align: center;
    }
    .bcdp-icon-box { width: 52px; height: 52px; }
    .bcdp-row-title { font-size: 22px; }
    .bcdp-recent { grid-template-columns: 1fr; gap: 10px; }
    .bcdp-recent-ph { height: 100px; }
  }
</style>
