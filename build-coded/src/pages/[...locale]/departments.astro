---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);

const departments = [
  { slug: 'woodworking', label: t(locale, 'categories.woodworking'), icon: 'saw', desc: 'saw \u00b7 joinery \u00b7 finish', tint: 'wood', count: allPosts.filter(p => p.data.category === 'woodworking').length },
  { slug: 'home-improvement', label: t(locale, 'categories.homeImprovement'), icon: 'wrench', desc: 'repair \u00b7 paint \u00b7 tile', tint: 'steel', count: allPosts.filter(p => p.data.category === 'home-improvement').length },
  { slug: 'electronics', label: t(locale, 'categories.electronics'), icon: 'chip', desc: 'arduino \u00b7 solder \u00b7 pcb', tint: 'electronics', count: allPosts.filter(p => p.data.category === 'electronics').length },
  { slug: 'crafts', label: t(locale, 'categories.crafts'), icon: 'brush', desc: 'cast \u00b7 sew \u00b7 print', tint: 'craft', count: allPosts.filter(p => p.data.category === 'crafts').length },
];
---

<Base title={t(locale, 'nav.departments')} description={t(locale, 'departments.description')} locale={locale}>
  <Header locale={locale} />
  <main class="flex-1">
    <div class="bcd-tool-wrap wide">
      <div class="bcd-kicker">&sect; {t(locale, 'nav.departments').toUpperCase()} &middot; BROWSE BY CRAFT</div>
      <h1 class="bcd-tool-title">Four benches,<br/><em>one house.</em></h1>
      <p class="bcd-tool-lede">{t(locale, 'departments.lede')}</p>

      <div class="bcd-depts-grid">
        {departments.map((cat) => (
          <a href={localePath(`/category/${cat.slug}/`, locale)} class="bcd-dept">
            <div class="swatch">
              <div class={`bc-ph bc-ph-${cat.tint}`} style="position: absolute; inset: 0;"></div>
              <svg viewBox="0 0 40 40" width="56" height="56" style="position: absolute; inset: 0; margin: auto; z-index: 2;" fill="none" stroke={cat.tint === 'wood' || cat.tint === 'craft' ? '#1b2027' : '#f3ede1'} stroke-width="1.3" stroke-linecap="round">
                {cat.icon === 'saw' && (
                  <>
                    <path d="M5 18 L30 18 L30 22 L5 22 Z"/>
                    <path d="M30 20 L36 20"/>
                    <path d="M5 20 L8 16 M8 20 L11 16 M11 20 L14 16 M14 20 L17 16 M17 20 L20 16 M20 20 L23 16 M23 20 L26 16"/>
                  </>
                )}
                {cat.icon === 'wrench' && (
                  <path d="M26 8 A6 6 0 1 0 28 20 L36 28 L32 32 L24 24 A6 6 0 0 0 26 8 Z"/>
                )}
                {cat.icon === 'chip' && (
                  <>
                    <rect x="10" y="10" width="20" height="20" rx="1"/>
                    <path d="M6 14 H10 M6 18 H10 M6 22 H10 M6 26 H10 M30 14 H34 M30 18 H34 M30 22 H34 M30 26 H34 M14 6 V10 M18 6 V10 M22 6 V10 M26 6 V10 M14 30 V34 M18 30 V34 M22 30 V34 M26 30 V34"/>
                  </>
                )}
                {cat.icon === 'brush' && (
                  <>
                    <path d="M24 6 L34 16 L22 28 L12 18 Z"/>
                    <path d="M12 18 L6 24 Q 2 28 6 32 Q 10 36 14 32 L20 26"/>
                  </>
                )}
              </svg>
              <span class="lbl">{cat.count} plans</span>
            </div>
            <div class="body">
              <h4>{cat.label}</h4>
              <small>{cat.desc}</small>
              <span class="arrow">see the plans &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer locale={locale} />

  <style>
    .bcd-depts-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 20px;
    }
    .bcd-dept {
      position: relative;
      border: 1.5px solid var(--ink);
      border-radius: 4px;
      overflow: hidden;
      background: var(--paper-light);
      cursor: pointer;
      transition: transform 0.18s, box-shadow 0.18s;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
    }
    .bcd-dept:hover {
      transform: translate(-3px, -3px);
      box-shadow: 5px 5px 0 var(--ink);
    }
    .bcd-dept .swatch {
      height: 180px;
      border-bottom: 1.5px solid var(--ink);
      position: relative;
    }
    .bcd-dept .swatch .lbl {
      position: absolute;
      bottom: 12px;
      left: 14px;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      color: var(--paper-light);
      text-transform: uppercase;
      background: rgba(0, 0, 0, 0.35);
      padding: 3px 8px;
      z-index: 3;
    }
    .bcd-dept .body { padding: 18px 20px 20px; }
    .bcd-dept h4 {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 22px;
      margin: 0 0 6px;
      text-transform: uppercase;
      letter-spacing: 0.01em;
    }
    .bcd-dept small {
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--pencil);
    }
    .bcd-dept .arrow {
      font-family: var(--font-heading);
      font-style: italic;
      font-size: 22px;
      color: var(--safety);
      margin-top: 12px;
      display: block;
    }
    @media (max-width: 1100px) {
      .bcd-depts-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .bcd-depts-grid { grid-template-columns: 1fr; }
    }
  </style>
</Base>
