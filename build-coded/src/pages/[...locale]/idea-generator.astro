---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const spaces = [
  { id: 'garage', icon: '🏗️' },
  { id: 'backyard', icon: '🌿' },
  { id: 'bedroom', icon: '🛏️' },
  { id: 'kitchen', icon: '🍳' },
  { id: 'bathroom', icon: '🚿' },
  { id: 'living-room', icon: '🛋️' },
  { id: 'workshop', icon: '🔧' },
  { id: 'balcony', icon: '🌺' },
];

const skills = ['beginner', 'intermediate', 'advanced'];

const budgets = [
  { id: 'under-25', label: 'budgetUnder25' },
  { id: '25-50', label: 'budget25to50' },
  { id: '50-100', label: 'budget50to100' },
  { id: '100-250', label: 'budget100to250' },
  { id: '250-plus', label: 'budget250plus' },
];

const interests = [
  { id: 'woodworking', label: 'interestWoodworking' },
  { id: 'home-improvement', label: 'interestHomeImprovement' },
  { id: 'electronics', label: 'interestElectronics' },
  { id: 'crafts', label: 'interestCrafts' },
  { id: 'furniture', label: 'interestFurniture' },
  { id: 'decor', label: 'interestDecor' },
  { id: 'organization', label: 'interestOrganization' },
  { id: 'outdoor', label: 'interestOutdoor' },
];

const spaceLabels: Record<string, string> = {};
spaces.forEach(s => {
  const key = 'space' + s.id.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join('');
  spaceLabels[s.id] = t(locale, `ideaGenerator.${key}`);
});
---

<Base title={t(locale, 'ideaGenerator.title')} description={t(locale, 'ideaGenerator.description')} locale={locale}>
  <Header locale={locale} />
  <main class="flex-1">
    <div class="bcd-tool-wrap">
      <a href={localePath('/', locale)} class="tool-back">&larr; {t(locale, 'common.backToHome')}</a>
      <div class="bcd-kicker">&sect; TOOL 03 &middot; {t(locale, 'ideaGenerator.toolLabel').toUpperCase()}</div>
      <h1 class="bcd-tool-title">What should I <em>build?</em></h1>
      <p class="bcd-tool-lede">{t(locale, 'ideaGenerator.description')}</p>

      <div id="questionnaire" class="space-y-10">
        <!-- Step 1: Space -->
        <div>
          <label class="block text-sm font-semibold text-charcoal mb-3">1. {t(locale, 'ideaGenerator.stepSpace')}</label>
          <div class="grid gap-3 grid-cols-2 sm:grid-cols-4" id="space-grid">
            {spaces.map((s) => (
              <button
                data-space={s.id}
                class="space-btn relative text-left p-4 rounded-xl border-2 border-steel-200/60 bg-white hover:border-amber-400 hover:shadow-md transition-all duration-200 cursor-pointer flex flex-col items-center text-center"
              >
                <svg class="space-check absolute top-2 right-2 w-5 h-5 text-amber-500 hidden" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span class="text-2xl mb-2">{s.icon}</span>
                <span class="space-label block text-sm font-heading font-semibold text-charcoal">{spaceLabels[s.id]}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Step 2: Skill Level -->
        <div>
          <label class="block text-sm font-semibold text-charcoal mb-3">2. {t(locale, 'ideaGenerator.stepSkill')}</label>
          <div class="flex flex-wrap gap-3" id="skill-buttons">
            {skills.map(level => (
              <button data-skill={level} class="skill-btn px-5 py-2.5 rounded-full border border-steel-200/60 text-sm font-medium text-charcoal hover:border-amber-400 transition-all cursor-pointer capitalize">
                {t(locale, `common.${level}`)}
              </button>
            ))}
          </div>
        </div>

        <!-- Step 3: Budget -->
        <div>
          <label class="block text-sm font-semibold text-charcoal mb-3">3. {t(locale, 'ideaGenerator.stepBudget')}</label>
          <div class="flex flex-wrap gap-3" id="budget-buttons">
            {budgets.map(b => (
              <button data-budget={b.id} class="budget-btn px-5 py-2.5 rounded-full border border-steel-200/60 text-sm font-medium text-charcoal hover:border-amber-400 transition-all cursor-pointer">
                {t(locale, `ideaGenerator.${b.label}`)}
              </button>
            ))}
          </div>
        </div>

        <!-- Step 4: Interests -->
        <div>
          <label class="block text-sm font-semibold text-charcoal mb-1">4. {t(locale, 'ideaGenerator.stepInterests')}</label>
          <span class="block text-xs text-charcoal-light/50 mb-3">{t(locale, 'ideaGenerator.selectUpTo4')}</span>
          <div class="flex flex-wrap gap-2" id="interest-buttons">
            {interests.map(i => (
              <button data-interest={i.id} class="interest-btn px-4 py-2 rounded-full border border-steel-200/60 text-sm font-medium text-charcoal hover:border-amber-400 transition-all cursor-pointer">
                {t(locale, `ideaGenerator.${i.label}`)}
              </button>
            ))}
          </div>
        </div>

        <!-- Photo Upload (optional) -->
        <div>
          <label class="block text-sm font-semibold text-charcoal mb-1">{t(locale, 'ideaGenerator.photoUpload')}</label>
          <span class="block text-xs text-charcoal-light/50 mb-3">{t(locale, 'ideaGenerator.photoUploadDesc')}</span>
          <div id="drop-zone" class="relative border-2 border-dashed border-steel-200/60 rounded-xl p-8 text-center cursor-pointer hover:border-amber-400 hover:bg-amber-50/20 transition-all duration-200">
            <input type="file" id="photo-input" accept="image/jpeg,image/png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
            <div id="drop-placeholder">
              <svg class="w-8 h-8 mx-auto text-steel-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5 1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
              <p class="text-sm text-charcoal-light/60 mb-1">{t(locale, 'ideaGenerator.photoDrop')}</p>
              <p class="text-xs text-charcoal-light/40">{t(locale, 'ideaGenerator.photoMaxSize')}</p>
            </div>
            <div id="photo-preview" class="hidden">
              <img id="preview-img" class="max-h-40 mx-auto rounded-lg" alt="Space preview"  loading="lazy" decoding="async" />
              <button id="remove-photo" class="mt-3 text-xs text-red-500 hover:text-red-700 underline cursor-pointer">Remove</button>
            </div>
          </div>
        </div>

        <!-- Generate Button -->
        <div>
          <button id="generate-btn" disabled class="w-full sm:w-auto px-9 py-3.5 bg-amber-500 text-steel-900 text-sm font-semibold rounded-full hover:bg-amber-400 hover:shadow-lg transition-all duration-300 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-amber-500 disabled:hover:shadow-none cursor-pointer">
            {t(locale, 'ideaGenerator.generateBtn')}
          </button>
          <div id="loading-state" class="hidden flex items-center gap-3 mt-4">
            <svg class="animate-spin w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            <span class="text-sm text-charcoal-light/60">{t(locale, 'ideaGenerator.generating')}</span>
          </div>
          <p id="error-msg" class="hidden mt-4 text-sm text-red-600"></p>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="hidden mt-12">
        <h2 class="font-heading text-2xl text-charcoal mb-6">{t(locale, 'ideaGenerator.resultsTitle')}</h2>
        <div id="ideas-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
        <div class="mt-8">
          <button id="start-over-btn" class="px-7 py-3 rounded-full border border-steel-200/60 text-sm font-medium text-charcoal hover:border-steel-400 hover:bg-steel-50 transition-all cursor-pointer">
            {t(locale, 'ideaGenerator.startOver')}
          </button>
        </div>
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</Base>

<script>
  let selectedSpace = '';
  let selectedSkill = '';
  let selectedBudget = '';
  let selectedInterests: string[] = [];
  let photoBase64: string | null = null;

  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
  const loadingState = document.getElementById('loading-state')!;
  const errorMsg = document.getElementById('error-msg')!;
  const resultsDiv = document.getElementById('results')!;
  const ideasGrid = document.getElementById('ideas-grid')!;
  const questionnaire = document.getElementById('questionnaire')!;

  function checkReady() {
    const ready = selectedSpace && selectedSkill && selectedBudget && selectedInterests.length >= 1;
    generateBtn.disabled = !ready;
  }

  // Step 1: Space
  document.querySelectorAll('.space-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.space-btn').forEach(b => {
        b.classList.remove('border-amber-500', 'bg-amber-100', 'shadow-lg');
        b.querySelector('.space-check')?.classList.add('hidden');
        b.querySelector('.space-label')?.classList.remove('text-steel-900', 'font-bold');
      });
      btn.classList.add('border-amber-500', 'bg-amber-100', 'shadow-lg');
      btn.querySelector('.space-check')?.classList.remove('hidden');
      btn.querySelector('.space-label')?.classList.add('text-steel-900', 'font-bold');
      selectedSpace = (btn as HTMLElement).dataset.space || '';
      checkReady();
    });
  });

  // Step 2: Skill
  document.querySelectorAll('.skill-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.skill-btn').forEach(b => b.classList.remove('bg-steel-700', 'text-white', 'border-steel-700'));
      btn.classList.add('bg-steel-700', 'text-white', 'border-steel-700');
      selectedSkill = (btn as HTMLElement).dataset.skill || '';
      checkReady();
    });
  });

  // Step 3: Budget
  document.querySelectorAll('.budget-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.budget-btn').forEach(b => b.classList.remove('bg-amber-500', 'text-steel-900', 'border-amber-500'));
      btn.classList.add('bg-amber-500', 'text-steel-900', 'border-amber-500');
      selectedBudget = (btn as HTMLElement).dataset.budget || '';
      checkReady();
    });
  });

  // Step 4: Interests (multi-select, 1-4)
  document.querySelectorAll('.interest-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.interest || '';
      const idx = selectedInterests.indexOf(id);
      if (idx >= 0) {
        selectedInterests.splice(idx, 1);
        btn.classList.remove('bg-amber-500', 'text-steel-900', 'border-amber-500');
      } else if (selectedInterests.length < 4) {
        selectedInterests.push(id);
        btn.classList.add('bg-amber-500', 'text-steel-900', 'border-amber-500');
      }
      checkReady();
    });
  });

  // Photo upload
  const photoInput = document.getElementById('photo-input') as HTMLInputElement;
  const dropPlaceholder = document.getElementById('drop-placeholder')!;
  const photoPreview = document.getElementById('photo-preview')!;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const removeBtn = document.getElementById('remove-photo')!;
  const dropZone = document.getElementById('drop-zone')!;

  function processFile(file: File) {
    if (!file.type.match(/^image\/(jpeg|png)$/)) return;
    if (file.size > 4 * 1024 * 1024) {
      errorMsg.textContent = 'Photo exceeds 4MB limit';
      errorMsg.classList.remove('hidden');
      return;
    }

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d')!;
    const img = new Image();
    img.onload = () => {
      let w = img.width, h = img.height;
      const max = 1024;
      if (w > max || h > max) {
        if (w > h) { h = Math.round(h * max / w); w = max; }
        else { w = Math.round(w * max / h); h = max; }
      }
      canvas.width = w;
      canvas.height = h;
      ctx.drawImage(img, 0, 0, w, h);
      const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
      photoBase64 = dataUrl.split(',')[1];
      previewImg.src = dataUrl;
      dropPlaceholder.classList.add('hidden');
      photoPreview.classList.remove('hidden');
      errorMsg.classList.add('hidden');
    };
    img.src = URL.createObjectURL(file);
  }

  photoInput.addEventListener('change', () => {
    if (photoInput.files?.[0]) processFile(photoInput.files[0]);
  });

  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-amber-400', 'bg-amber-50/20'); });
  dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('border-amber-400', 'bg-amber-50/20'); });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-amber-400', 'bg-amber-50/20');
    if (e.dataTransfer?.files?.[0]) processFile(e.dataTransfer.files[0]);
  });

  removeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    photoBase64 = null;
    photoInput.value = '';
    dropPlaceholder.classList.remove('hidden');
    photoPreview.classList.add('hidden');
  });

  // Generate
  generateBtn.addEventListener('click', async () => {
    generateBtn.classList.add('hidden');
    loadingState.classList.remove('hidden');
    errorMsg.classList.add('hidden');
    resultsDiv.classList.add('hidden');

    const payload: any = {
      space: selectedSpace,
      skillLevel: selectedSkill,
      budget: selectedBudget,
      interests: selectedInterests,
    };
    if (photoBase64) payload.photoBase64 = photoBase64;

    try {
      const resp = await fetch('/api/generate-ideas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await resp.json();

      if (!resp.ok || !data.ideas) {
        throw new Error(data.error || 'Failed to generate ideas');
      }

      renderIdeas(data.ideas);
    } catch (e: any) {
      errorMsg.textContent = e.message || 'Something went wrong. Please try again.';
      errorMsg.classList.remove('hidden');
    } finally {
      loadingState.classList.add('hidden');
      generateBtn.classList.remove('hidden');
    }
  });

  const difficultyColors: Record<string, { bg: string; text: string }> = {
    beginner: { bg: 'bg-green-100', text: 'text-green-800' },
    intermediate: { bg: 'bg-amber-100', text: 'text-amber-800' },
    advanced: { bg: 'bg-red-100', text: 'text-red-800' },
  };

  function renderIdeas(ideas: any[]) {
    ideasGrid.textContent = '';

    ideas.forEach(idea => {
      const card = document.createElement('div');
      card.className = 'bg-white border border-steel-200/60 rounded-xl p-5 hover:shadow-md transition-shadow flex flex-col';

      // Title
      const title = document.createElement('h3');
      title.className = 'font-heading text-lg text-charcoal font-semibold leading-snug mb-3';
      title.textContent = idea.title;
      card.appendChild(title);

      // Difficulty badge
      const colors = difficultyColors[idea.difficulty] || difficultyColors.beginner;
      const badge = document.createElement('span');
      badge.className = `inline-block self-start px-2.5 py-0.5 rounded-full text-xs font-medium ${colors.bg} ${colors.text} mb-3 capitalize`;
      badge.textContent = idea.difficulty;
      card.appendChild(badge);

      // Description
      const desc = document.createElement('p');
      desc.className = 'text-sm text-charcoal-light/70 mb-4 leading-relaxed flex-1';
      desc.textContent = idea.description;
      card.appendChild(desc);

      // Cost & time
      const meta = document.createElement('div');
      meta.className = 'flex items-center gap-4 text-xs text-charcoal-light/60 mb-4';
      const costSpan = document.createElement('span');
      costSpan.textContent = idea.estimatedCost;
      const dot = document.createElement('span');
      dot.textContent = '\u00B7';
      const timeSpan = document.createElement('span');
      timeSpan.textContent = idea.estimatedTime;
      meta.appendChild(costSpan);
      meta.appendChild(dot);
      meta.appendChild(timeSpan);
      card.appendChild(meta);

      // Materials
      const matSection = document.createElement('div');
      matSection.className = 'mb-4';
      const matLabel = document.createElement('span');
      matLabel.className = 'block text-xs font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2';
      matLabel.textContent = 'Materials';
      matSection.appendChild(matLabel);
      const matWrap = document.createElement('div');
      matWrap.className = 'flex flex-wrap gap-1.5';
      (idea.materialsNeeded || []).forEach((m: string) => {
        const chip = document.createElement('span');
        chip.className = 'px-2 py-0.5 bg-steel-50 rounded text-xs text-steel-600';
        chip.textContent = m;
        matWrap.appendChild(chip);
      });
      matSection.appendChild(matWrap);
      card.appendChild(matSection);

      // First step
      const stepSection = document.createElement('div');
      stepSection.className = 'pt-3 border-t border-steel-100/60';
      const stepLabel = document.createElement('span');
      stepLabel.className = 'block text-xs font-semibold uppercase tracking-wide text-charcoal-light/50 mb-1';
      stepLabel.textContent = 'First Step';
      stepSection.appendChild(stepLabel);
      const stepText = document.createElement('p');
      stepText.className = 'text-sm text-charcoal leading-relaxed';
      stepText.textContent = idea.firstStep;
      stepSection.appendChild(stepText);
      card.appendChild(stepSection);

      ideasGrid.appendChild(card);
    });

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Start Over
  document.getElementById('start-over-btn')!.addEventListener('click', () => {
    selectedSpace = '';
    selectedSkill = '';
    selectedBudget = '';
    selectedInterests = [];
    photoBase64 = null;
    photoInput.value = '';

    document.querySelectorAll('.space-btn').forEach(b => b.classList.remove('border-amber-500', 'shadow-md', 'bg-amber-100', 'ring-2', 'ring-amber-400'));
    document.querySelectorAll('.skill-btn').forEach(b => b.classList.remove('bg-steel-700', 'text-white', 'border-steel-700'));
    document.querySelectorAll('.budget-btn').forEach(b => b.classList.remove('bg-amber-500', 'text-steel-900', 'border-amber-500'));
    document.querySelectorAll('.interest-btn').forEach(b => b.classList.remove('bg-amber-500', 'text-steel-900', 'border-amber-500'));

    dropPlaceholder.classList.remove('hidden');
    photoPreview.classList.add('hidden');
    resultsDiv.classList.add('hidden');
    errorMsg.classList.add('hidden');
    generateBtn.disabled = true;

    questionnaire.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
