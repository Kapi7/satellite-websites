            <div class="disc">FREE &middot; NO SPAM &middot; PRINT-READY PDFS</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RECENT / FRESH ===== -->
    {recent.length > 0 && (
      <section class="bcd-page">
        <div class="bcd-sec-head">
          <div>
            <div class="bcd-sec-label">&sect; 03 &middot; {t(locale, 'home.latest').toUpperCase()}</div>
            <h2>{t(locale, 'home.freshFromTheShop')}</h2>
          </div>
          <a href={localePath('/category/woodworking/', locale)} class="bcd-meta-link">
            {t(locale, 'common.viewAll').toUpperCase()} &rarr;
