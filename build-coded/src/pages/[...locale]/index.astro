        </div>
        <div class="bcd-recent-grid">
          {recent.map((post, i: number) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={slugOf(post)}
              image={post.data.image}
              type={post.data.type}
              locale={locale}
              indexNo={i + 6}
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <div class="bc-desktop-home">
    <Footer locale={locale} />
  </div>
  <BackToTop />
</Base>

