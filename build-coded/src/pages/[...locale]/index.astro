---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroSlideshow from '../../components/HeroSlideshow.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Load GSC-based featured articles
let featuredData = { trending: [], rising: [] };
try {
  const raw = await import('../../data/featured.json');
  featuredData = raw.default || raw;
} catch { /* no featured data yet — fall back to recent */ }

const trendingSlugs = new Set(featuredData.trending.map((t: any) => t.slug));

const trendingPosts = featuredData.trending
  .map((t: any) => sortedPosts.find(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    return slug === t.slug || slug.replace('.mdx', '').replace('.md', '') === t.slug;
  }))
  .filter(Boolean)
  .slice(0, 6);

const recent = sortedPosts
  .filter(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    const cleanSlug = slug.replace('.mdx', '').replace('.md', '');
    return !trendingSlugs.has(cleanSlug);
  })
  .slice(0, 6);

const slides = [
  {
    image: '/images/hero-slide-1.jpg',
    title: t(locale, 'home.slideProjects'),
    subtitle: t(locale, 'home.slideProjectsDesc'),
    category: t(locale, 'nav.woodworking'),
  },
  {
    image: '/images/hero-slide-2.jpg',
    title: t(locale, 'home.slideWorkshop'),
    subtitle: t(locale, 'home.slideWorkshopDesc'),
    category: t(locale, 'nav.homeImprovement'),
  },
  {
    image: '/images/hero-slide-3.jpg',
    title: t(locale, 'home.slideTools'),
    subtitle: t(locale, 'home.slideToolsDesc'),
    category: t(locale, 'nav.electronics'),
  },
];

const categories = [
  { slug: 'woodworking', label: t(locale, 'categories.woodworking'), icon: '🪚', desc: t(locale, 'categoryDescriptions.woodworking'), count: sortedPosts.filter(p => p.data.category === 'woodworking').length },
  { slug: 'home-improvement', label: t(locale, 'categories.homeImprovement'), icon: '🏠', desc: t(locale, 'categoryDescriptions.homeImprovement'), count: sortedPosts.filter(p => p.data.category === 'home-improvement').length },
  { slug: 'electronics', label: t(locale, 'categories.electronics'), icon: '⚡', desc: t(locale, 'categoryDescriptions.electronics'), count: sortedPosts.filter(p => p.data.category === 'electronics').length },
  { slug: 'crafts', label: t(locale, 'categories.crafts'), icon: '🎨', desc: t(locale, 'categoryDescriptions.crafts'), count: sortedPosts.filter(p => p.data.category === 'crafts').length },
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Build Coded', url: 'https://build-coded.com',
  logo: 'https://build-coded.com/logo.svg',
  description: 'DIY project guides, honest tool reviews, and step-by-step tutorials for makers.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Build Coded', url: 'https://build-coded.com',
});
---

<Base
  title="Build Coded"
  description="DIY project guides, honest tool reviews, and step-by-step tutorials for makers."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <main class="flex-1">
    <!-- Hero -->
    <div class="pt-6 animate-fade-in">
      <HeroSlideshow slides={slides} />
    </div>

    <!-- Trending (GSC top performers) -->
    {trendingPosts.length > 0 && (
      <section class="max-w-[1400px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 mb-16 sm:mb-24">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.trending')}</span>
            <h2 class="font-heading text-4xl text-charcoal tracking-tight">{t(locale, 'home.readerFavorites')}</h2>
          </div>
        </div>

        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
          {trendingPosts.map((post: any, i: number) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id}
              image={post.data.image}
              type={post.data.type}
              locale={locale}
              featured={i === 0}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Fresh from the Workshop -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 mb-16 sm:mb-24">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.latest')}</span>
          <h2 class="font-heading text-4xl text-charcoal tracking-tight">{t(locale, 'home.freshFromTheShop')}</h2>
        </div>
        <a href={localePath('/category/woodworking/', locale)} class="hidden sm:inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/60 hover:text-steel-700 transition-colors">
          {t(locale, 'common.viewAll')}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id}
            image={post.data.image}
            type={post.data.type}
            locale={locale}
          />
        ))}
      </div>
    </section>

    <!-- Topics We Cover -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="border-t border-steel-200/40 pt-16">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.explore')}</span>
            <h2 class="font-heading text-4xl text-charcoal tracking-tight">{t(locale, 'home.topicsWeCover')}</h2>
          </div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {categories.map((cat) => (
            <a
              href={localePath(`/category/${cat.slug}`, locale)}
              class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-steel-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-steel-600/0 to-steel-700/0 group-hover:from-steel-600/5 group-hover:to-steel-700/10 transition-all duration-500 rounded-2xl"></div>

              <div class="relative z-10 flex flex-col items-center">
                <span class="text-4xl mb-4" aria-hidden="true">{cat.icon}</span>
                <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-steel-700 transition-colors">{cat.label}</h3>
                <p class="text-xs text-charcoal-light/60 leading-relaxed mb-4 max-w-[180px]">{cat.desc}</p>
                <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 group-hover:text-amber-500 transition-colors">
                  {cat.count} {cat.count === 1 ? t(locale, 'common.article') : t(locale, 'common.articles')}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tools -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.interactive')}</span>
          <h2 class="font-heading text-4xl text-charcoal tracking-tight">{t(locale, 'home.toolsAndGuides')}</h2>
        </div>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        <a href={localePath('/cost-calculator/', locale)} class="group relative aspect-[2/1] sm:aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-steel-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-steel-600/0 to-steel-700/0 group-hover:from-steel-600/5 group-hover:to-steel-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-steel-50 flex items-center justify-center group-hover:bg-steel-100 transition-colors">
              <svg class="w-7 h-7 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm2.25-4.5h.008v.008H10.5v-.008Zm0 2.25h.008v.008H10.5v-.008Zm0 2.25h.008v.008H10.5v-.008Zm2.25-4.5h.008v.008H12.75v-.008Zm0 2.25h.008v.008H12.75v-.008Zm2.25-2.25h.008v.008H15v-.008Zm0 2.25h.008v.008H15v-.008ZM5.248 6.79 15 2.604l3.002 1.125-9.752 4.188M5.25 6.788v13.462H18.75V6.788" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-steel-700 transition-colors">{t(locale, 'home.costCalcTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.costCalcDesc')}</p>
          </div>
        </a>
        <a href={localePath('/tool-finder/', locale)} class="group relative aspect-[2/1] sm:aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-steel-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-steel-600/0 to-steel-700/0 group-hover:from-steel-600/5 group-hover:to-steel-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-steel-50 flex items-center justify-center group-hover:bg-steel-100 transition-colors">
              <svg class="w-7 h-7 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.6-5.6a8 8 0 1 1 11.31 0l-5.6 5.6a.75.75 0 0 1-1.06 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-steel-700 transition-colors">{t(locale, 'home.toolFinderTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.toolFinderDesc')}</p>
          </div>
        </a>
        <a href={localePath('/idea-generator/', locale)} class="group relative aspect-[2/1] sm:aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-steel-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-steel-600/0 to-steel-700/0 group-hover:from-steel-600/5 group-hover:to-steel-700/10 transition-all duration-500 rounded-2xl"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-14 h-14 mb-4 rounded-full bg-steel-50 flex items-center justify-center group-hover:bg-steel-100 transition-colors">
              <svg class="w-7 h-7 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>
            </div>
            <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-steel-700 transition-colors">{t(locale, 'home.ideaGeneratorTitle')}</h3>
            <p class="text-xs text-charcoal-light/60 leading-relaxed max-w-[180px]">{t(locale, 'home.ideaGeneratorDesc')}</p>
          </div>
        </a>
      </div>
    </section>

    <!-- Project CTA -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="relative rounded-2xl sm:rounded-[2.5rem] bg-gradient-to-br from-steel-700 via-steel-800 to-steel-900 p-10 sm:p-16 text-center overflow-hidden">
        <div class="absolute top-[-60px] left-[-40px] w-48 h-48 bg-amber-500/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-[-80px] right-[-40px] w-64 h-64 bg-amber-400/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-steel-400/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.25em] text-amber-300/80 mb-4">{t(locale, 'home.new')}</span>
          <h2 class="font-heading text-4xl sm:text-5xl text-cream mb-4 leading-tight" set:html={t(locale, 'home.findYourProject').replace('\n', '<br />')} />
          <p class="text-sm sm:text-base text-steel-200 mb-8 max-w-lg mx-auto leading-relaxed">{t(locale, 'home.projectCtaDesc')}</p>
          <a href={localePath('/category/woodworking/', locale)} class="inline-flex items-center gap-2.5 px-9 py-3.5 bg-amber-500 text-steel-900 text-sm font-semibold rounded-full hover:bg-amber-400 hover:shadow-lg transition-all duration-300">
            {t(locale, 'home.browseProjects')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-2xl bg-steel-50 p-10 sm:p-16">
        <div class="grid sm:grid-cols-2 gap-10 sm:gap-16 items-center">
          <div>
            <img src="/logo.svg" alt="Build Coded" class="w-32 h-32 mb-6" />
            <h2 class="font-heading text-4xl text-charcoal tracking-tight mb-4">{t(locale, 'home.aboutTitle')}</h2>
          </div>
          <div>
            <p class="text-sm sm:text-base text-steel-500 leading-relaxed mb-6">
              {t(locale, 'home.aboutDesc')}
            </p>
            <a href={localePath('/about/', locale)} class="inline-flex items-center gap-2 text-sm font-medium text-steel-700 hover:text-steel-900 transition-colors group">
              {t(locale, 'home.learnMore')}
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="max-w-4xl mx-auto px-5 sm:px-8 mb-20">
      <NewsletterSignup locale={locale} />
    </div>
  </main>

  <Footer locale={locale} />
  <BackToTop />
</Base>
