---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Load GSC-based featured articles
let featuredData = { trending: [], rising: [] };
try {
  const raw = await import('../../data/featured.json');
  featuredData = raw.default || raw;
} catch { /* no featured data yet — fall back to recent */ }

const trendingSlugs = new Set(featuredData.trending.map((t: any) => t.slug));

const trendingPosts = featuredData.trending
  .map((t: any) => sortedPosts.find(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    return slug === t.slug || slug.replace('.mdx', '').replace('.md', '') === t.slug;
  }))
  .filter(Boolean)
  .slice(0, 6);

const recent = sortedPosts
  .filter(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    const cleanSlug = slug.replace('.mdx', '').replace('.md', '');
    return !trendingSlugs.has(cleanSlug);
  })
  .slice(0, 6);

const categories = [
  { slug: 'woodworking', label: t(locale, 'categories.woodworking'), icon: 'saw', desc: 'saw · joinery · finish', tint: 'wood', count: sortedPosts.filter(p => p.data.category === 'woodworking').length },
  { slug: 'home-improvement', label: t(locale, 'categories.homeImprovement'), icon: 'wrench', desc: 'repair · paint · tile', tint: 'steel', count: sortedPosts.filter(p => p.data.category === 'home-improvement').length },
  { slug: 'electronics', label: t(locale, 'categories.electronics'), icon: 'chip', desc: 'arduino · solder · pcb', tint: 'electronics', count: sortedPosts.filter(p => p.data.category === 'electronics').length },
  { slug: 'crafts', label: t(locale, 'categories.crafts'), icon: 'brush', desc: 'cast · sew · print', tint: 'craft', count: sortedPosts.filter(p => p.data.category === 'crafts').length },
];

const heroPost = trendingPosts[0] || sortedPosts[0];
const editorialRest = (trendingPosts.length > 1 ? trendingPosts.slice(1, 5) : sortedPosts.slice(1, 5));

const totalArticles = sortedPosts.length;
const totalCategories = categories.length;

const mobileGrid = editorialRest.slice(0, 4);
const mobileList = recent.slice(0, 3);

const chipTabs = [
  { label: t(locale, 'home.chipLatest'), href: localePath('/', locale), active: true },
  { label: t(locale, 'home.chipWoodworking'), href: localePath('/category/woodworking/', locale) },
  { label: t(locale, 'home.chipHomeFix'), href: localePath('/category/home-improvement/', locale) },
  { label: t(locale, 'home.chipElectronics'), href: localePath('/category/electronics/', locale) },
  { label: t(locale, 'home.chipCrafts'), href: localePath('/category/crafts/', locale) },
];

const mobileMetrics = [
  { n: String(totalArticles), l: t(locale, 'home.trustProjects') },
  { n: '42', l: t(locale, 'home.trustTools') },
  { n: '0', l: t(locale, 'home.trustSponsored') },
];

const marqueeItems = [
  'NEW PLANS \u00b7 WEEKLY',
  'FREE TOOL FINDER',
  'NO GATEKEEPING',
  'HONEST REVIEWS',
  t(locale, 'home.issueStamp') || 'APR ISSUE \u00b7 OUT NOW',
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Build Coded', url: 'https://build-coded.com',
  logo: 'https://build-coded.com/logo.svg',
  description: 'DIY project guides, honest tool reviews, and step-by-step tutorials for makers.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Build Coded', url: 'https://build-coded.com',
});

const slugOf = (p: any) => (p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id).replace('.mdx', '').replace('.md', '');

const tintByCategory: Record<string, string> = {
  'woodworking': 'wood',
  'home-improvement': 'steel',
  'electronics': 'electronics',
  'crafts': 'craft',
};
---

<Base
  title="Build Coded"
  description="DIY project guides, honest tool reviews, and step-by-step tutorials for makers."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <!-- ============================================================ -->
  <!-- MOBILE HOMEPAGE (visible <= 960px)                            -->
  <!-- ============================================================ -->
  <main class="bc-mobile-home flex-1">
    <!-- Masthead -->
    <section class="bc-mh-mast">
      <div class="bc-mh-mast-row">
        <span class="mono bc-mh-dim">{t(locale, 'home.volIssue')}</span>
        <span class="mono bc-mh-dim">{t(locale, 'home.season')}</span>
      </div>
      <h1 class="bc-mh-headline">
        {t(locale, 'home.mobileHeroHead1')}<br/>
        <em>{t(locale, 'home.mobileHeroHead2')}</em> {t(locale, 'home.mobileHeroHead3')}<br/>
        {t(locale, 'home.mobileHeroHead4')}
      </h1>
      <p class="bc-mh-sub">{t(locale, 'home.mobileSubhead')}</p>
    </section>

    <!-- Chip row -->
    <div class="bc-mh-chips bc-scroll">
      {chipTabs.map((chip, i) => (
        <a href={chip.href} class={`bc-chip ${i === 0 ? 'active' : ''}`}>{chip.label}</a>
      ))}
    </div>

    <!-- Featured project -->
    {heroPost && (
      <section class="bc-mh-featured">
        <div class="bc-mh-kicker">
          <span class="bc-mh-kicker-rule"></span>
          <span class="mono">{t(locale, 'home.featuredProject')}</span>
        </div>
        <a href={localePath('/' + slugOf(heroPost) + '/', locale)} class="bc-card bc-mh-hero-card">
          <div class="bc-mh-hero-ph">
            {heroPost.data.image ? (
              <img src={heroPost.data.image} alt={heroPost.data.title} />
            ) : (
              <div class={`bc-ph bc-ph-${tintByCategory[heroPost.data.category] || 'wood'}`} style="position:absolute; inset:0;">
                <svg viewBox="0 0 200 160" width="170" fill="none" stroke="#1b2027" stroke-width="1.3" stroke-linecap="round" style="position:relative; z-index:2;">
                  <rect x="20" y="60" width="160" height="14" stroke-width="1.6"/>
                  <path d="M20 74 L30 80 L170 80 L180 74"/>
                  <path d="M12 44 L20 60 M20 44 V88 M28 44 L20 60"/>
                  <circle cx="50" cy="50" r="2.5" fill="#1b2027"/>
                  <circle cx="150" cy="50" r="2.5" fill="#1b2027"/>
                  <path d="M50 50 L50 67 M150 50 L150 67" stroke-dasharray="2 2"/>
                  <text x="150" y="30" font-family="Bitter,serif" font-size="8" font-style="italic" fill="#1b2027">fig. 01</text>
                </svg>
              </div>
            )}
            <span class="bc-mh-cat-badge mono">{t(locale, `categories.${heroPost.data.category === 'home-improvement' ? 'homeImprovement' : heroPost.data.category}`).toUpperCase()}</span>
            {heroPost.data.difficulty && (
              <span class="bc-mh-lvl-badge mono">LVL &middot; {heroPost.data.difficulty.charAt(0).toUpperCase() + heroPost.data.difficulty.slice(1)}</span>
            )}
          </div>
          <div class="bc-mh-hero-body">
            <h3>{heroPost.data.title}</h3>
            <p>{heroPost.data.description}</p>
            <div class="bc-mh-hero-meta">
              {heroPost.data.estimatedCost && (
                <span class="mono bc-mh-dim">COST &middot; <b>{heroPost.data.estimatedCost}</b></span>
              )}
              {heroPost.data.estimatedTime && (
                <span class="mono bc-mh-dim">TIME &middot; <b>{heroPost.data.estimatedTime}</b></span>
              )}
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Metric strip -->
    <div class="bc-mh-metrics">
      {mobileMetrics.map((m) => (
        <div class="bc-mh-metric">
          <div class="bc-mh-metric-n">{m.n}</div>
          <div class="mono bc-mh-metric-l">{m.l}</div>
        </div>
      ))}
    </div>

    <!-- Browse by trade -->
    <section class="bc-mh-depts">
      <div class="bc-mh-sec-head">
        <h2>{t(locale, 'home.browseByTrade')}</h2>
        <span class="mono bc-mh-dim">{t(locale, 'home.fourDepts')}</span>
      </div>
      <div class="bc-mh-dept-grid">
        {categories.map((c) => (
          <a href={localePath(`/category/${c.slug}/`, locale)} class="bc-card bc-mh-dept">
            <div class="bc-mh-dept-top">
              <div class={`bc-mh-dept-icon bc-mh-dept-icon-${c.tint}`}>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  {c.icon === 'saw' && (
                    <>
                      <path d="M3 8 L20 8 L21 11 L14 11"/>
                      <path d="M3 8 L4 14 L6 12 L7 14 L9 12 L10 14 L12 12 L13 14"/>
                      <rect x="14" y="7" width="2.5" height="5"/>
                    </>
                  )}
                  {c.icon === 'wrench' && (<path d="M14 5 A4 4 0 1 0 19 10 L21 12 L12 21 L3 12 L12 3 Z"/>)}
                  {c.icon === 'chip' && (
                    <>
                      <rect x="6" y="6" width="12" height="12"/>
                      <rect x="9" y="9" width="6" height="6"/>
                      <path d="M3 9 H6 M3 12 H6 M3 15 H6 M18 9 H21 M18 12 H21 M18 15 H21 M9 3 V6 M12 3 V6 M15 3 V6 M9 18 V21 M12 18 V21 M15 18 V21"/>
                    </>
                  )}
                  {c.icon === 'brush' && (<path d="M9 15 L4 20 L6 22 L11 17 M9 15 L12 12 L18 6 A2 2 0 0 1 21 9 L15 15 L12 18 Z"/>)}
                </svg>
              </div>
              <span class="mono bc-mh-dim">{String(c.count).padStart(2, '0')}</span>
            </div>
            <div class="bc-mh-dept-name">{c.label}</div>
            <div class="mono bc-mh-dept-view">{t(locale, 'home.view')} &rarr;</div>
          </a>
        ))}
      </div>
    </section>

    <!-- This week's builds -->
    <section class="bc-mh-thisweek">
      <div class="bc-mh-sec-head">
        <h2>{t(locale, 'home.thisWeeksBuilds')}</h2>
        <a href={localePath('/departments/', locale)} class="mono bc-mh-dim">{t(locale, 'home.seeAll')}</a>
      </div>
      <div class="bc-mh-thisweek-grid">
        {mobileGrid.map((post: any) => (
          <a href={localePath('/' + slugOf(post) + '/', locale)} class="bc-card bc-mh-grid-card">
            <div class={`bc-mh-grid-ph bc-ph bc-ph-${tintByCategory[post.data.category] || 'wood'}`}>
              {post.data.image && (<img src={post.data.image} alt={post.data.title} />)}
            </div>
            <div class="bc-mh-grid-body">
              <div class="mono bc-mh-grid-cat">{t(locale, `categories.${post.data.category === 'home-improvement' ? 'homeImprovement' : post.data.category}`).toUpperCase()}</div>
              <h4>{post.data.title}</h4>
              <div class="mono bc-mh-dim bc-mh-grid-meta">
                {Math.max(4, Math.ceil((post.body?.length || 3000) / 1200))} min &middot; {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Tool finder promo -->
    <a href={localePath('/tool-finder/', locale)} class="bc-mh-promo">
      <div class="bc-mh-promo-grid"></div>
      <div class="bc-mh-promo-inner">
        <div class="mono bc-mh-promo-kicker">{t(locale, 'home.toolFinderKicker')}</div>
        <div class="bc-mh-promo-head">
          {t(locale, 'home.toolFinderMobileHead1')}<br/>
          <em>{t(locale, 'home.toolFinderMobileHead2')}</em>
        </div>
        <p class="bc-mh-promo-body">{t(locale, 'home.toolFinderMobileBody')}</p>
        <span class="bc-btn bc-btn-safety bc-mh-promo-cta">{t(locale, 'home.toolFinderCta')}</span>
      </div>
    </a>

    <!-- Reviews & guides (side list) -->
    <section class="bc-mh-reviews">
      <div class="bc-mh-sec-head">
        <h2>{t(locale, 'home.reviewsAndGuides')}</h2>
        <span class="mono bc-mh-dim">{t(locale, 'home.handsOn')}</span>
      </div>
      <div class="mono bc-mh-dim bc-mh-reviews-note">{t(locale, 'home.honestTestBadge')}</div>
      <div>
        {mobileList.map((post: any) => (
          <a href={localePath('/' + slugOf(post) + '/', locale)} class="bc-mh-side">
            <div class="bc-mh-side-ph">
              <div class={`bc-ph bc-ph-${tintByCategory[post.data.category] || 'wood'}`} style="position:absolute; inset:0;">
                {post.data.image && (<img src={post.data.image} alt={post.data.title} />)}
              </div>
              {post.data.difficulty && (
                <span class="mono bc-mh-side-lvl">{post.data.difficulty.slice(0, 3).toUpperCase()}</span>
              )}
            </div>
            <div class="bc-mh-side-body">
              <div class="mono bc-mh-side-cat">{t(locale, `categories.${post.data.category === 'home-improvement' ? 'homeImprovement' : post.data.category}`).toUpperCase()}</div>
              <h4>{post.data.title}</h4>
              <div class="mono bc-mh-dim bc-mh-side-meta">
                <span>{Math.max(4, Math.ceil((post.body?.length || 3000) / 1200))} min read</span>
                {post.data.estimatedCost && (<><span>&middot;</span><span>{post.data.estimatedCost}</span></>)}
                {post.data.estimatedTime && (<><span>&middot;</span><span>{post.data.estimatedTime}</span></>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Saturday Brief newsletter -->
    <section class="bc-mh-newsletter" id="newsletter">
      <div class="bc-mh-newsletter-stamp">
        <span class="bc-stamp">{t(locale, 'home.saturdayStamp')}</span>
      </div>
      <div class="mono bc-mh-newsletter-kicker">{t(locale, 'home.saturdayKicker')}</div>
      <h3 class="bc-mh-newsletter-head">{t(locale, 'home.saturdayHeadline')}</h3>
      <p class="bc-mh-newsletter-body">{t(locale, 'home.saturdayBody')}</p>
      <form class="newsletter-form bc-mh-newsletter-form" data-locale={locale}>
        <input type="email" placeholder={t(locale, 'footer.emailPlaceholder')} required />
        <button type="submit">{t(locale, 'home.saturdaySub')}</button>
      </form>
      <p class="newsletter-msg hidden" style="margin-top: 8px; font-size: 12px;"></p>
      <div class="mono bc-mh-newsletter-stats">{t(locale, 'home.saturdayStats')}</div>
    </section>

    <!-- Mini mobile footer -->
    <div class="bc-mh-footer">
      <div class="bc-mh-footer-brand">
        <span class="bc-mh-footer-sq"></span>
        <span class="bc-mh-footer-mark">BUILD CODED</span>
      </div>
      <p class="bc-mh-footer-tagline">{t(locale, 'home.mobileFooterTagline')}</p>
      <div class="mono bc-mh-footer-affiliate">{t(locale, 'home.mobileAffiliate')}</div>
    </div>
  </main>

  <!-- ============================================================ -->
  <!-- DESKTOP HOMEPAGE (visible > 960px)                            -->
  <!-- ============================================================ -->
  <main class="bc-desktop-home flex-1">
    <!-- Docket bar -->
    <div class="bcd-docket">
      <div class="bcd-page" style="display: flex; justify-content: space-between; align-items: center; max-width: 1360px; margin: 0 auto;">
        <div class="docket-set">
          <span>DOC &middot; <b>BC-HOME</b></span>
          <span>SHEET <b>01/03</b></span>
          <span>SCALE <b>1:1</b></span>
        </div>
        <div class="docket-set">
          <span>EDITOR <b>R. CONNORS</b></span>
          <span>APPROVED <b>&#10003;</b></span>
        </div>
      </div>
    </div>

    <!-- ===== MASTHEAD ===== -->
    <section class="bcd-page">
      <div class="bcd-mast">
        <div>
          <div class="bcd-mast-kicker">
            {categories.map((c) => (<span class="tag">{c.label}</span>))}
          </div>
          <h1 class="bcd-mast-title">
            Make<br/>something<br/><em>good.</em>
          </h1>
          <p class="bcd-mast-sub">{t(locale, 'home.mastSub') || "DIY projects with real material lists, honest costs, and the tools we'd actually use again. We write plans we'd follow ourselves — not content."}</p>
        </div>
        {heroPost && (
          <a href={localePath('/' + slugOf(heroPost) + '/', locale)} class="bcd-hero-card">
            <div class="bcd-hero-ph">
              {heroPost.data.image ? (
                <img src={heroPost.data.image} alt={heroPost.data.title} style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" />
              ) : (
                <div class={`bc-ph bc-ph-${tintByCategory[heroPost.data.category] || 'wood'}`} style="position: absolute; inset: 0;">
                  <span class="bcd-hero-big">{heroPost.data.title[0]}</span>
                </div>
              )}
              <div class="stamp">Featured</div>
              <div class="corner">FIG. 01 &middot; THIS WEEK</div>
            </div>
            <div class="body">
              <div class="tag">{heroPost.data.category.toUpperCase()}</div>
              <h3>{heroPost.data.title}</h3>
              <div class="specs">
                <div class="spec"><small>READ</small><b>{Math.max(4, Math.ceil((heroPost.body?.length || 3000) / 1200))} min</b></div>
                <div class="spec"><small>DATE</small><b>{heroPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</b></div>
                <div class="spec"><small>TYPE</small><b>{(heroPost.data.type || 'Guide').slice(0, 8)}</b></div>
              </div>
            </div>
          </a>
        )}
      </div>
    </section>

    <!-- ===== MARQUEE TAPE ===== -->
    <div class="bcd-tape">
      <div class="track">
        {[0, 1, 2].map(() => (
          <span class="track-inner">
            {marqueeItems.map((item) => (
              <>
                <span>{item}</span>
                <span class="star">&#9670;</span>
              </>
            ))}
          </span>
        ))}
      </div>
    </div>

    <!-- ===== EDITORIAL GRID ===== -->
    <section class="bcd-page">
      <div class="bcd-sec-head">
        <div>
          <div class="bcd-sec-label">&sect; 01 &middot; {t(locale, 'home.latest').toUpperCase()}</div>
          <h2>{t(locale, 'home.thisWeek') || 'This week'} <em>{t(locale, 'home.onTheBench') || 'on the bench'}</em></h2>
        </div>
        <a href={localePath('/category/woodworking/', locale)} class="bcd-meta-link">
          {totalArticles} {t(locale, 'common.articles')} &middot; {t(locale, 'common.viewAll').toUpperCase()} &rarr;
        </a>
      </div>

      <div class="bcd-edit-grid">
        {editorialRest.length > 0 && heroPost && (
          <ArticleCard
            title={heroPost.data.title}
            description={heroPost.data.description}
            date={heroPost.data.date}
            category={heroPost.data.category}
            slug={slugOf(heroPost)}
            image={heroPost.data.image}
            type={heroPost.data.type}
            locale={locale}
            featured
            indexNo={1}
          />
        )}
        {editorialRest.map((post: any, i: number) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={slugOf(post)}
            image={post.data.image}
            type={post.data.type}
            locale={locale}
            indexNo={i + 2}
          />
        ))}
      </div>
    </section>

    <!-- ===== DEPARTMENTS ===== -->
    <section class="bcd-page">
      <div class="bcd-sec-head">
        <div>
          <div class="bcd-sec-label">&sect; 02 &middot; {t(locale, 'home.departmentsLabel') || 'DEPARTMENTS'}</div>
          <h2>{t(locale, 'home.fourBenches') || 'Four benches,'} <em>{t(locale, 'home.oneHouse') || 'one house'}</em></h2>
        </div>
        <div class="bcd-meta">{totalArticles} {t(locale, 'home.plansSorted') || 'plans \u00b7 sorted by craft'}</div>
      </div>
      <div class="bcd-depts">
        {categories.map((cat) => (
          <a href={localePath(`/category/${cat.slug}/`, locale)} class="bcd-dept">
            <div class="swatch">
              <div class={`bc-ph bc-ph-${cat.tint}`} style="position: absolute; inset: 0;"></div>
              <svg viewBox="0 0 40 40" width="56" height="56" style={`position: absolute; inset: 0; margin: auto; z-index: 2;`} fill="none" stroke={cat.tint === 'wood' || cat.tint === 'craft' ? '#1b2027' : '#f3ede1'} stroke-width="1.3" stroke-linecap="round">
                {cat.icon === 'saw' && (
                  <>
                    <path d="M5 18 L30 18 L30 22 L5 22 Z"/>
                    <path d="M30 20 L36 20"/>
                    <path d="M5 20 L8 16 M8 20 L11 16 M11 20 L14 16 M14 20 L17 16 M17 20 L20 16 M20 20 L23 16 M23 20 L26 16"/>
                  </>
                )}
                {cat.icon === 'wrench' && (
                  <path d="M26 8 A6 6 0 1 0 28 20 L36 28 L32 32 L24 24 A6 6 0 0 0 26 8 Z"/>
                )}
                {cat.icon === 'chip' && (
                  <>
                    <rect x="10" y="10" width="20" height="20" rx="1"/>
                    <path d="M6 14 H10 M6 18 H10 M6 22 H10 M6 26 H10 M30 14 H34 M30 18 H34 M30 22 H34 M30 26 H34 M14 6 V10 M18 6 V10 M22 6 V10 M26 6 V10 M14 30 V34 M18 30 V34 M22 30 V34 M26 30 V34"/>
                  </>
                )}
                {cat.icon === 'brush' && (
                  <>
                    <path d="M24 6 L34 16 L22 28 L12 18 Z"/>
                    <path d="M12 18 L6 24 Q 2 28 6 32 Q 10 36 14 32 L20 26"/>
                  </>
                )}
              </svg>
              <span class="lbl">{cat.count} {t(locale, 'home.plansShort') || 'plans'}</span>
            </div>
            <div class="body">
              <h4>{cat.label}</h4>
              <small>{cat.desc}</small>
              <span class="arrow">{t(locale, 'home.seeThePlans') || 'see the plans'} &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ===== TOOL FINDER + NEWSLETTER ===== -->
    <section class="bcd-page" id="newsletter">
      <div class="bcd-duo">
        <div class="bcd-finder">
          <div class="label">{t(locale, 'home.interactiveLabel') || 'INTERACTIVE \u00b7 4 QUESTIONS'}</div>
          <h3>{t(locale, 'home.whatTool') || 'What tool'}<br/>{t(locale, 'home.doYou') || 'do you'} <em>{t(locale, 'home.actually') || 'actually'}</em><br/>{t(locale, 'home.need') || 'need?'}</h3>
          <p>{t(locale, 'home.finderDesc') || "Project, skill level, budget, timeframe. We'll point you at the one tool that unlocks the most next projects — not the full catalog."}</p>
          <div class="steps">
            <div class="step"><b>01</b>{t(locale, 'home.stepProject') || 'Project'}</div>
            <div class="step"><b>02</b>{t(locale, 'home.stepSkill') || 'Skill'}</div>
            <div class="step"><b>03</b>{t(locale, 'home.stepBudget') || 'Budget'}</div>
            <div class="step"><b>04</b>{t(locale, 'home.stepMatch') || 'Match'}</div>
          </div>
          <a href={localePath('/tool-finder/', locale)} class="cta">{t(locale, 'home.startTheFinder') || 'Start the finder'} &rarr;</a>
          <div class="rule">FIG. 02 &middot; DECISION TREE</div>
        </div>
        <div class="bcd-nl">
          <div>
            <div class="label">{t(locale, 'home.newsletterLabel') || 'WEEKLY \u00b7 12,400 BUILDERS'}</div>
            <h3>{t(locale, 'home.theBlueprint') || 'The'} <em>{t(locale, 'home.blueprintEm') || 'Blueprint.'}</em></h3>
