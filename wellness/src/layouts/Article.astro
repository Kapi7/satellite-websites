---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';
import { t, localePath, formatDate, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  category: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
  type?: string;
  locale?: Locale;
  author?: string;
}

const {
  title, description, date, updated, category, tags = [],
  image, imageAlt, headings, slug, rawContent, type,
  locale = 'en', author,
} = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];
const readingTime = rawContent ? Math.max(1, Math.ceil(rawContent.split(/\s+/).length / 200)) : null;

const categoryLabels: Record<string, string> = {
  'nutrition': t(locale, 'categories.nutrition'),
  'movement': t(locale, 'categories.movement'),
  'k-beauty': t(locale, 'categories.kBeauty'),
  'natural-health': t(locale, 'categories.naturalHealth'),
};
const categoryLabel = categoryLabels[category] || category;

const formattedDate = formatDate(date, locale);
const formattedUpdated = updated ? formatDate(updated, locale) : undefined;
const articleUrl = new URL(localePath(`/${slug}`, locale), Astro.site).href;

const authorObj = author
  ? { '@type': 'Person', name: author }
  : { '@type': 'Organization', name: t(locale, 'article.editorial') };

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image, url: articleUrl,
  datePublished: date.toISOString(),
  dateModified: updated?.toISOString() || date.toISOString(),
  author: authorObj,
  publisher: { '@type': 'Organization', name: 'Rooted Glow', url: 'https://rooted-glow.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  inLanguage: locale,
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(localePath(`/category/${category}`, locale), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
  ],
});

const schemas = [articleSchema, breadcrumbSchema];

if (type === 'guide' && headings) {
  const stepHeadings = headings.filter(
    (h) => h.depth === 3 && /^(\d+[\.\)]\s|step\s|day\s)/i.test(h.text)
  );
  if (stepHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const steps = stepHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let text = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (text) break; continue; }
          text = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return { '@type': 'HowToStep', name: h.text, text: text || h.text };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'HowTo',
      name: title, description, step: steps,
    }));
  }
}

if (headings) {
  const questionHeadings = headings.filter(
    (h) => (h.depth === 2 || h.depth === 3) && h.text.trim().endsWith('?')
  );
  if (questionHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const faqEntries = questionHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let answer = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (answer) break; continue; }
          answer = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return {
        '@type': 'Question', name: h.text,
        acceptedAnswer: { '@type': 'Answer', text: answer || h.text },
      };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: faqEntries, inLanguage: locale,
    }));
  }
}

// ItemList schema — auto-detect for listicle type
if (type === 'listicle' && headings) {
  const listHeadings = headings.filter(
    (h) => h.depth === 2 && /^(\d+[\.\)]\s|best|top|\w+\s#?\d)/i.test(h.text)
  );
  if (listHeadings.length >= 3) {
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'ItemList',
      name: title, numberOfItems: listHeadings.length,
      itemListElement: listHeadings.map((h, i) => ({
        '@type': 'ListItem', position: i + 1, name: h.text,
        url: `${articleUrl}#${h.slug}`,
      })),
    }));
  }
}
---

<Base
  title={title} description={description} image={image} type="article"
  jsonLd={schemas}
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={(updated || date).toISOString()}
  articleSection={categoryLabel}
  articleTags={tags}
  locale={locale}
>
  <ReadingProgress />
  <Header locale={locale} />

  <main class="flex-1 rgd-page linen">
    <!-- Breadcrumb -->
    <nav class="animate-fade-in-up" aria-label="Breadcrumb" style="padding:28px 0 0;display:flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-soft);">
      <a href={localePath('/', locale)} style="color:var(--forest);text-decoration:none;">{t(locale, 'common.home')}</a>
      <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <a href={localePath(`/category/${category}/`, locale)} style="color:var(--forest);text-decoration:none;">{categoryLabel}</a>
    </nav>

    <div class={`rgd-article-layout ${products.length > 0 ? 'has-aside' : ''}`}>
      <article data-pagefind-body class="rgd-article-main">
        <!-- Article header -->
        <header class="animate-fade-in-up stagger-1" style="padding:28px 0 0;">
          <div class="meta">
            <span>{categoryLabel}</span>
            <span>·</span>
            {readingTime && <span>{readingTime} {t(locale, 'common.minRead')}</span>}
            {readingTime && <span>·</span>}
            <span>{formattedDate}</span>
          </div>
          <h1>{title}</h1>
          <p class="lede">{description}</p>
          <div class="byline">
            <div class="av">
              {author ? (
                <img src={`/images/team/${author.toLowerCase().replace(/\s+/g, '-')}.jpg`} alt={author} width="42" height="42"  loading="lazy" decoding="async" />
              ) : (
                <span>{(author || 'R')[0]}</span>
              )}
            </div>
            <div>
              By {(author || t(locale, 'article.editorial')).toUpperCase()}
              {formattedUpdated && <span> · {t(locale, 'common.updated')} {formattedUpdated}</span>}
            </div>
          </div>
        </header>

        <!-- Hero image -->
        {image && (
          <div class="animate-fade-in-up stagger-2" style="margin:38px 0 34px;">
            <div class="rg-tint-sage" style="aspect-ratio:5/2;border-radius:12px;overflow:hidden;">
              <img src={image} alt={imageAlt || title} style="width:100%;height:100%;object-fit:cover;" loading="eager" width="1200" height="480" />
            </div>
          </div>
        )}

        <!-- Table of contents -->
        <div class="animate-fade-in-up stagger-2">
          <TableOfContents headings={headings} locale={locale} />
        </div>

        <!-- Article body -->
        <div class="prose prose-wide animate-fade-in-up stagger-3">
          <slot />
        </div>

        <!-- Tags + share -->
        {tags.length > 0 && (
          <div style="margin-top:56px;padding-top:28px;border-top:1px solid rgba(47,61,42,0.15);display:flex;flex-direction:column;gap:20px;">
            <div>
              <span class="mono" style="color:var(--ink-soft);margin-right:10px;">{t(locale, 'common.tagged')}</span>
              <div style="display:inline-flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
                {tags.map((tag) => (
                  <span class="rg-chip" style="cursor:default;">{tag}</span>
                ))}
              </div>
            </div>
            <ShareButtons title={title} url={articleUrl} locale={locale} />
          </div>
        )}

        {tags.length === 0 && (
          <div style="margin-top:40px;">
            <ShareButtons title={title} url={articleUrl} locale={locale} />
          </div>
        )}
      </article>

      <!-- Sidebar: featured products + TL;DR -->
      {products.length > 0 && (
        <aside class="rgd-article-aside">
          <div class="rg-card" style="padding:22px 22px;">
            <h5 class="mono" style="color:var(--ink-soft);margin:0 0 12px;">{t(locale, 'common.featuredProducts')}</h5>
            <div style="display:flex;flex-direction:column;gap:20px;">
              {products.slice(0, 3).map((product) => (
                <a href={product.url} target="_blank" rel="noopener noreferrer" class="group" style="display:block;text-decoration:none;color:inherit;">
                  <div style="aspect-ratio:4/5;overflow:hidden;border-radius:10px;background:var(--linen);margin-bottom:10px;">
                    <img src={product.image} alt={product.name} style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s;" loading="lazy" />
                  </div>
                  <p class="serif" style="font-size:15px;color:var(--forest);line-height:1.2;margin:0 0 4px;">{product.name}</p>
                  <span class="mono" style="color:var(--terracotta-dark);">{t(locale, 'common.shopNow')} &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>

    <!-- Related + Newsletter -->
    <div style="padding-top:40px;">
      <RelatedArticles currentSlug={slug} category={category} locale={locale} />
      <NewsletterSignup locale={locale} />
    </div>
  </main>

  <style>
    .rgd-article-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 40px;
      padding: 20px 0 40px;
    }
    .rgd-article-main { min-width: 0; max-width: 760px; margin: 0 auto; width: 100%; }
    .rgd-article-aside { display: none; }
    @media (min-width: 1100px) {
      .rgd-article-layout.has-aside {
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 60px;
        max-width: 1200px;
        margin: 0 auto;
      }
      .rgd-article-layout.has-aside .rgd-article-main { margin: 0; }
      .rgd-article-layout.has-aside .rgd-article-aside {
        display: block;
        position: sticky;
        top: 100px;
        align-self: start;
      }
    }
  </style>

  <Footer locale={locale} />
  <BackToTop locale={locale} />

  <script>
    // Expand table to full screen — no sideways scrolling
    document.querySelectorAll(".prose table").forEach((table) => {
      const wrapper = document.createElement("div");
      wrapper.className = "table-expand-wrapper";

      const header = document.createElement("div");
      header.className = "table-expand-header";

      const btn = document.createElement("button");
      btn.className = "table-expand-btn";
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';

      btn.addEventListener("click", () => {
        const isExpanded = wrapper.classList.toggle("expanded");
        btn.innerHTML = isExpanded
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14h6v6M14 10h6V4M3 21l7-7M21 3l-7 7"/></svg> Collapse'
          : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';

        if (isExpanded) {
          document.body.style.overflow = "hidden";
        } else {
          document.body.style.overflow = "";
        }
      });

      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && wrapper.classList.contains("expanded")) {
          btn.click();
        }
      });

      header.appendChild(btn);
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(header);
      wrapper.appendChild(table);
    });
  </script>
</Base>
