---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { extractProducts } from '../utils/extract-products';
import { t, localePath, formatDate, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  category: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  rawContent?: string;
  type?: string;
  locale?: Locale;
  author?: string;
}

const {
  title, description, date, updated, category, tags = [],
  image, imageAlt, headings, slug, rawContent, type,
  locale = 'en', author,
} = Astro.props;

const products = rawContent ? extractProducts(rawContent) : [];
const readingTime = rawContent ? Math.max(1, Math.ceil(rawContent.split(/\s+/).length / 200)) : null;

const categoryLabels: Record<string, string> = {
  'nutrition': t(locale, 'categories.nutrition'),
  'movement': t(locale, 'categories.movement'),
  'k-beauty': t(locale, 'categories.kBeauty'),
  'natural-health': t(locale, 'categories.naturalHealth'),
};
const categoryLabel = categoryLabels[category] || category;

const formattedDate = formatDate(date, locale);
const formattedUpdated = updated ? formatDate(updated, locale) : undefined;
const articleUrl = new URL(localePath(`/${slug}`, locale), Astro.site).href;

const authorName = author || t(locale, 'article.editorial');

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description, image,
  datePublished: date.toISOString(),
  dateModified: updated?.toISOString() || date.toISOString(),
  author: { '@type': 'Organization', name: authorName },
  publisher: { '@type': 'Organization', name: 'Rooted Glow' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: new URL(localePath('/', locale), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(localePath(`/category/${category}`, locale), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
});

const schemas = [articleSchema, breadcrumbSchema];

if (type === 'guide' && headings) {
  const stepHeadings = headings.filter(
    (h) => h.depth === 3 && /^(\d+[\.\)]\s|step\s|day\s)/i.test(h.text)
  );
  if (stepHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const steps = stepHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let text = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (text) break; continue; }
          text = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return { '@type': 'HowToStep', name: h.text, text: text || h.text };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'HowTo',
      name: title, description, step: steps,
    }));
  }
}

if (headings) {
  const questionHeadings = headings.filter(
    (h) => (h.depth === 2 || h.depth === 3) && h.text.trim().endsWith('?')
  );
  if (questionHeadings.length >= 2 && rawContent) {
    const lines = rawContent.split('\n');
    const faqEntries = questionHeadings.map((h) => {
      const headingIdx = lines.findIndex((l) => l.includes(h.text));
      let answer = '';
      if (headingIdx !== -1) {
        for (let i = headingIdx + 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (line.startsWith('#') || line === '') { if (answer) break; continue; }
          answer = line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_~`]/g, '');
          break;
        }
      }
      return {
        '@type': 'Question', name: h.text,
        acceptedAnswer: { '@type': 'Answer', text: answer || h.text },
      };
    });
    schemas.push(JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: faqEntries,
    }));
  }
}
---

<Base
  title={title} description={description} image={image} type="article"
  jsonLd={schemas}
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={(updated || date).toISOString()}
  articleSection={categoryLabel}
  articleTags={tags}
  locale={locale}
>
  <ReadingProgress />
  <Header locale={locale} />

  <main class="flex-1">
    <!-- Hero Image — wider, more impactful -->
    <div class="animate-fade-in">
      {image && (
        <div class="max-w-[1400px] mx-auto px-4 sm:px-8 pt-4 sm:pt-8">
          <div class="aspect-[5/2] max-h-[40vh] overflow-hidden rounded-xl sm:rounded-2xl bg-sage-100">
            <img src={image} alt={imageAlt || title} class="w-full h-full object-cover" loading="eager" width="1200" height="675" />
          </div>
        </div>
      )}
    </div>

    <!-- Main content area — wider container -->
    <div class={`max-w-[1400px] mx-auto px-4 sm:px-8 py-6 sm:py-10 ${products.length > 0 ? "xl:flex xl:gap-16" : ""}`}>
      <article data-pagefind-body class={`flex-1 min-w-0 ${products.length === 0 ? "max-w-5xl mx-auto" : ""}`}>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-[11px] uppercase tracking-wide text-charcoal-light/50 mb-8 animate-fade-in-up" aria-label="Breadcrumb">
          <a href={localePath('/', locale)} class="hover:text-sage-700 transition-colors">{t(locale, 'common.home')}</a>
          <svg class="w-3 h-3 text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <a href={localePath(`/category/${category}`, locale)} class="hover:text-sage-700 transition-colors">{categoryLabel}</a>
        </nav>

        <!-- Article header — bigger, bolder -->
        <header class="mb-10 animate-fade-in-up stagger-1 max-w-5xl">
          <h1 class="font-heading text-4xl sm:text-5xl md:text-[3.5rem] text-charcoal leading-[1.08] tracking-tight mb-6">{title}</h1>
          <p class="text-lg sm:text-xl text-charcoal-light/60 leading-relaxed mb-6 max-w-3xl">{description}</p>
          <div class="flex items-center gap-4 border-t border-sage-200/40 pt-6">
            {author ? (
              <img src={`/images/team/${author.toLowerCase().replace(/\s+/g, '-')}.jpg`} alt={author} class="w-9 h-9 rounded-full object-cover" />
            ) : (
              <img src="/logo.svg" alt="" class="w-8 h-8 rounded-full" />
            )}
            <div>
              <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal block">{authorName}</span>
              <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.1em] text-charcoal-light/50 mt-0.5">
                <time datetime={date.toISOString()}>{formattedDate}</time>
                {formattedUpdated && (
                  <>
                    <span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span>
                    <span>{t(locale, 'common.updated')} {formattedUpdated}</span>
                  </>
                )}
                {readingTime && (
                  <>
                    <span class="w-1 h-1 rounded-full bg-charcoal-light/20"></span>
                    <span>{readingTime} {t(locale, 'common.minRead')}</span>
                  </>
                )}
              </div>
            </div>
          </div>
        </header>

        <!-- Table of contents -->
        <div class="animate-fade-in-up stagger-2">
          <TableOfContents headings={headings} locale={locale} />
        </div>

        <!-- Article body — wider prose -->
        <div class="prose prose-wide animate-fade-in-up stagger-3">
          <slot />
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-16 pt-8 border-t border-sage-200/30 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            <div>
              <span class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mr-3">{t(locale, 'common.tagged')}</span>
              <div class="inline-flex flex-wrap gap-2 mt-2">
                {tags.map((tag) => (
                  <a class="px-4 py-1.5 bg-sage-100/60 text-sage-600 text-xs font-medium rounded-full hover:bg-sage-200 transition-colors">{tag}</a>
                ))}
              </div>
            </div>
            <ShareButtons title={title} url={articleUrl} locale={locale} />
          </div>
        )}

        {tags.length === 0 && (
          <ShareButtons title={title} url={articleUrl} locale={locale} />
        )}
      </article>

      <!-- Sidebar — Stitch-inspired card design -->
      {products.length > 0 && (
        <aside class="hidden xl:block w-[220px] shrink-0">
          <div class="bg-sage-50/50 rounded-xl p-5 space-y-6">
            <h3 class="font-heading text-xs uppercase tracking-wide text-sage-600 pb-2 border-b border-sage-200/40">{t(locale, 'common.featuredProducts')}</h3>
            <div class="space-y-6">
              {products.slice(0, 3).map((product) => (
                <a href={product.url} target="_blank" rel="noopener noreferrer" class="block group">
                  <div class="aspect-[4/5] overflow-hidden rounded-lg bg-white mb-3">
                    <img src={product.image} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  </div>
                  <p class="font-heading text-sm text-charcoal leading-snug mb-1">{product.name}</p>
                  <span class="text-[11px] font-semibold uppercase tracking-wide text-sage-600 group-hover:text-sage-800 transition-colors">{t(locale, 'common.shopNow')} &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>

    <!-- Newsletter + Related — wider container -->
    <div class="max-w-[1400px] mx-auto px-4 sm:px-8">
      <RelatedArticles currentSlug={slug} category={category} locale={locale} />
      <NewsletterSignup locale={locale} />
    </div>
  </main>

  <Footer locale={locale} />
  <BackToTop locale={locale} />

  <script>
    // Expand table to full screen — no sideways scrolling
    document.querySelectorAll(".prose table").forEach((table) => {
      const wrapper = document.createElement("div");
      wrapper.className = "table-expand-wrapper";

      const header = document.createElement("div");
      header.className = "table-expand-header";

      const btn = document.createElement("button");
      btn.className = "table-expand-btn";
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';

      btn.addEventListener("click", () => {
        const isExpanded = wrapper.classList.toggle("expanded");
        btn.innerHTML = isExpanded
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14h6v6M14 10h6V4M3 21l7-7M21 3l-7 7"/></svg> Collapse'
          : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand Full Screen';

        if (isExpanded) {
          document.body.style.overflow = "hidden";
        } else {
          document.body.style.overflow = "";
        }
      });

      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && wrapper.classList.contains("expanded")) {
          btn.click();
        }
      });

      header.appendChild(btn);
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(header);
      wrapper.appendChild(table);
    });
  </script>
</Base>
