---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  category: string;
}

const { title, description, category } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => {
  return data.category === category && !data.draft;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: title },
  ],
});
---

<Base title={title} description={description} jsonLd={[breadcrumbSchema]}>
  <Header />

  <main class="flex-1">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 py-16">
      <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-sage-400 mb-10" aria-label="Breadcrumb">
        <a href="/" class="hover:text-sage-700 transition-colors">Home</a>
        <svg class="w-3 h-3 text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span class="font-medium">{title}</span>
      </nav>

      <header class="mb-14 max-w-3xl">
        <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.2em] text-sage-400 mb-4">Category</span>
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl italic text-charcoal tracking-tight leading-[1.08] mb-5">
          {title}
        </h1>
        <p class="text-lg sm:text-xl text-sage-500 leading-relaxed max-w-2xl">{description}</p>
      </header>

      <div class="border-t border-sage-200/40 pt-12" data-pagefind-body>
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.id}
              image={post.data.image}
              type={post.data.type}
            />
          ))}
        </div>
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-24">
          <p class="text-sage-400 font-heading text-2xl italic">Articles coming soon.</p>
          <p class="text-sm text-sage-300 mt-2">We're working on this section. Check back shortly.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>
