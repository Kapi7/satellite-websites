---
import ArticleCard from './ArticleCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  category: string;
  limit?: number;
}

const { currentSlug, category, limit = 3 } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => {
  return data.category === category && !data.draft;
});

const related = allPosts
  .filter((p) => p.id !== currentSlug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, limit);
---

{related.length > 0 && (
  <section class="mt-16 pt-12 border-t border-sage-200/60">
    <h2 class="text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-8">Keep Reading</h2>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.id}
          image={post.data.image}
          type={post.data.type}
        />
      ))}
    </div>
  </section>
)}
