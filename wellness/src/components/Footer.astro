---
import { t, localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const year = new Date().getFullYear();

const readLinks = [
  { label: t(locale, 'nav.library'), href: localePath('/library/', locale) },
  { label: t(locale, 'categories.nutrition'), href: localePath('/category/nutrition/', locale) },
  { label: t(locale, 'categories.movement'), href: localePath('/category/movement/', locale) },
  { label: t(locale, 'categories.kBeauty'), href: localePath('/category/k-beauty/', locale) },
  { label: t(locale, 'categories.naturalHealth'), href: localePath('/category/natural-health/', locale) },
];

const toolLinks = [
  { label: t(locale, 'nav.toolsHub'), href: localePath('/tools/', locale) },
  { label: t(locale, 'nav.wellnessQuiz'), href: localePath('/tools/quiz/', locale) },
  { label: t(locale, 'nav.seasonalGuide'), href: localePath('/tools/seasonal-guide/', locale) },
  { label: t(locale, 'nav.herbIndex'), href: localePath('/tools/herb-index/', locale) },
  { label: t(locale, 'nav.recipeGenerator'), href: localePath('/tools/recipe-generator/', locale) },
];

const houseLinks = [
  { label: t(locale, 'nav.letter'), href: localePath('/letter/', locale) },
  { label: t(locale, 'nav.about'), href: localePath('/about/', locale) },
  { label: t(locale, 'footer.privacy'), href: localePath('/privacy/', locale) },
];
---

<footer class="rgd-page" style="margin-top:80px;padding-bottom:20px;font-family:'General Sans',sans-serif;">
  <!-- Newsletter strip -->
  <div class="rgd-footer-cta" style="margin-top:0;margin-bottom:60px;">
    <div class="rgd-news">
      <div class="label">{t(locale, 'footer.newsletterLabel')}</div>
      <h3 set:html={t(locale, 'footer.newsletterTitle')} />
      <p>{t(locale, 'footer.newsletterDesc')}</p>
      <form class="newsletter-form form" data-locale={locale}>
        <input type="email" name="email" required placeholder={t(locale, 'footer.emailPlaceholder')} />
        <button type="submit">{t(locale, 'common.subscribe')}</button>
      </form>
      <p class="newsletter-msg" style="display:none;margin-top:12px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;"></p>
    </div>
    <div class="rgd-about-block">
      <div class="label">{t(locale, 'footer.fromEditors')}</div>
      <blockquote>{t(locale, 'footer.editorsQuote')}</blockquote>
      <div class="authors">
        <div class="stack">
          <div class="avatar">N</div>
          <div class="avatar" style="background:var(--ochre);">M</div>
          <div class="avatar" style="background:var(--forest-soft);">E</div>
        </div>
        <small>Noa Sato · Mara Lindqvist · Elias Hart</small>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div style="padding:60px 0 20px;border-top:1px solid rgba(47,61,42,0.18);display:grid;grid-template-columns:1.4fr repeat(3,1fr);gap:40px;" class="rg-footer-grid">
    <div>
      <div style="font-family:'Instrument Serif',serif;font-size:clamp(36px,4vw,44px);line-height:1;letter-spacing:-0.01em;color:var(--forest);margin-bottom:12px;">
        rooted <em style="font-style:italic;color:var(--terracotta);">glow.</em>
      </div>
      <p style="font-size:14px;color:var(--forest-soft);line-height:1.6;margin:0 0 16px;max-width:340px;">{t(locale, 'footer.brandDesc')}</p>
      <small class="mono" style="color:var(--ink-soft);">&copy; {year} · {t(locale, 'footer.copyright')}</small>
    </div>
    <div>
      <h5 class="mono" style="color:var(--ink-soft);margin:0 0 18px;">{t(locale, 'footer.read')}</h5>
      <ul style="list-style:none;padding:0;margin:0;font-size:14px;line-height:2.1;">
        {readLinks.map((l) => <li><a href={l.href} style="color:var(--forest);text-decoration:none;">{l.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h5 class="mono" style="color:var(--ink-soft);margin:0 0 18px;">{t(locale, 'nav.tools')}</h5>
      <ul style="list-style:none;padding:0;margin:0;font-size:14px;line-height:2.1;">
        {toolLinks.map((l) => <li><a href={l.href} style="color:var(--forest);text-decoration:none;">{l.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h5 class="mono" style="color:var(--ink-soft);margin:0 0 18px;">{t(locale, 'footer.house')}</h5>
      <ul style="list-style:none;padding:0;margin:0;font-size:14px;line-height:2.1;">
        {houseLinks.map((l) => <li><a href={l.href} style="color:var(--forest);text-decoration:none;">{l.label}</a></li>)}
        <li>
          <a href="https://www.pinterest.com/rootedglow" target="_blank" rel="noopener noreferrer" style="color:var(--forest);text-decoration:none;">Pinterest</a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  footer a:hover { color: var(--terracotta) !important; }
  @media (max-width: 900px) {
    .rg-footer-grid { grid-template-columns: 1fr 1fr !important; gap: 28px !important; padding: 36px 0 20px !important; }
    .rg-footer-grid > div:first-child { grid-column: 1 / -1; }
  }
  /* Sub-640px: collapse to single column for comfortable mobile reading */
  @media (max-width: 640px) {
    .rg-footer-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.newsletter-form').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.currentTarget as HTMLFormElement;
        const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
        const msg = f.parentElement?.querySelector('.newsletter-msg') as HTMLElement;
        const input = f.querySelector('input[type="email"]') as HTMLInputElement;
        const email = input.value.trim();
        if (!email) return;

        btn.disabled = true;
        btn.style.opacity = '0.6';
        if (msg) msg.style.display = 'none';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, locale: (f.dataset.locale as string) || 'en' }),
          });
          const data = await res.json();

          if (msg) {
            msg.style.display = 'block';
            if (data.status === 'subscribed') {
              msg.textContent = 'Welcome — your first letter arrives Sunday.';
              msg.style.color = 'var(--forest)';
              input.value = '';
            } else if (data.status === 'already_subscribed') {
              msg.textContent = 'You are already subscribed.';
              msg.style.color = 'var(--ochre)';
            } else {
              msg.textContent = data.error === 'invalid_email' ? 'Please enter a valid email.' : 'Something went wrong.';
              msg.style.color = 'var(--terracotta-dark)';
            }
          }
        } catch {
          if (msg) {
            msg.style.display = 'block';
            msg.textContent = 'Network error — please try again.';
            msg.style.color = 'var(--terracotta-dark)';
          }
        } finally {
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      });
    });
  });
</script>
