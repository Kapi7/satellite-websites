---
const year = new Date().getFullYear();
const categories = [
  { label: 'Nutrition', href: '/category/nutrition' },
  { label: 'Movement', href: '/category/movement' },
  { label: 'K-Beauty', href: '/category/k-beauty' },
  { label: 'Natural Health', href: '/category/natural-health' },
];
---

<footer class="border-t border-sage-200/60 bg-sage-50/50">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 md:gap-8">
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <img src="/logo.svg" alt="" class="w-7 h-7" />
          <span class="text-lg font-heading text-charcoal tracking-tight">Rooted Glow</span>
        </div>
        <p class="text-sm text-sage-500 leading-relaxed">
          Wellness, movement, and K-Beauty grounded in real experience.
        </p>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-4">Explore</h4>
        <ul class="space-y-2.5">
          {categories.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-sage-600 hover:text-charcoal transition-colors duration-200">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-4">Info</h4>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm text-sage-600 hover:text-charcoal transition-colors duration-200">About Us</a></li>
          <li><a href="/privacy" class="text-sm text-sage-600 hover:text-charcoal transition-colors duration-200">Privacy</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-4">Stay Rooted</h4>
        <p class="text-xs text-sage-500 leading-relaxed">Weekly reads on nutrition, movement & K-Beauty.</p>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-sage-200/60 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-sage-400">&copy; {year} Rooted Glow. All rights reserved.</span>
      <span class="text-xs text-sage-300">Made with intention.</span>
    </div>
  </div>
</footer>
