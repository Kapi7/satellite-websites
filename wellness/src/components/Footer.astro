---
const year = new Date().getFullYear();
const categories = [
  { label: 'Nutrition', href: '/category/nutrition' },
  { label: 'Movement', href: '/category/movement' },
  { label: 'K-Beauty', href: '/category/k-beauty' },
  { label: 'Natural Health', href: '/category/natural-health' },
  { label: 'Wellness Quiz', href: '/quiz/' },
];
---

<footer class="bg-sage-100/50 rounded-t-[2rem] mt-16">
  <!-- Main Grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-10 sm:gap-12 px-6 sm:px-12 py-12 sm:py-16 max-w-[1400px] mx-auto">

    <!-- Column 1: Brand -->
    <div class="space-y-5">
      <a href="/"><img src="/logo.svg" alt="Rooted Glow" class="h-10 w-auto mb-3" /></a>
      <h2 class="font-heading text-2xl italic text-charcoal">Rooted Glow</h2>
      <p class="text-sm text-sage-500 leading-relaxed max-w-xs">
        Wellness, movement, and K-Beauty grounded in real experience — not trends.
        We write about what we actually do, eat, and put on our skin.
      </p>
      <div class="flex items-center gap-3 text-sage-400 text-lg">
        <span title="Leaf">&#127807;</span>
        <span title="Sparkle">&#10024;</span>
        <span title="Seedling">&#127793;</span>
      </div>
    </div>

    <!-- Column 2: Explore -->
    <div>
      <h3 class="font-heading text-xl font-semibold text-charcoal mb-5">Explore</h3>
      <ul class="space-y-3">
        {categories.map((cat) => (
          <li>
            <a
              href={cat.href}
              class="text-sm text-sage-500 hover:text-sage-800 transition-colors duration-200"
            >
              {cat.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Info -->
    <div>
      <h3 class="font-heading text-xl font-semibold text-charcoal mb-5">Info</h3>
      <ul class="space-y-3">
        <li>
          <a
            href="/about"
            class="text-sm text-sage-500 hover:text-sage-800 transition-colors duration-200"
          >
            About Us
          </a>
        </li>
        <li>
          <a
            href="/privacy"
            class="text-sm text-sage-500 hover:text-sage-800 transition-colors duration-200"
          >
            Privacy
          </a>
        </li>
      </ul>
    </div>

    <!-- Column 4: Newsletter CTA -->
    <div class="space-y-4">
      <h3 class="font-heading text-xl font-semibold text-charcoal">Inner Glow Journal</h3>
      <p class="text-sm text-sage-500 leading-relaxed">
        A weekly letter on nutrition, movement, and K-Beauty — written with care, never noise.
      </p>
      <form class="flex flex-col gap-3" action="#" method="POST">
        <input
          type="email"
          name="email"
          placeholder="Your email"
          required
          class="w-full px-4 py-2.5 rounded-lg border border-sage-200 bg-white/70 text-sm text-charcoal placeholder:text-sage-400 focus:outline-none focus:ring-2 focus:ring-sage-300 transition-all"
        />
        <button
          type="submit"
          class="w-full px-4 py-2.5 rounded-lg bg-sage-700 text-cream text-sm font-semibold hover:bg-sage-800 transition-colors duration-200"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="border-t border-sage-200/60 max-w-[1400px] mx-auto px-6 sm:px-12 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="text-xs text-sage-400">&copy; {year} Rooted Glow. All rights reserved.</span>

    <div class="flex items-center gap-5">
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/rootedglow"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-sage-400 hover:text-sage-700 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
        </svg>
      </a>

      <!-- Pinterest -->
      <a
        href="https://www.pinterest.com/rootedglow"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Pinterest"
        class="text-sage-400 hover:text-sage-700 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345c-.091.379-.293 1.194-.333 1.361-.052.22-.174.266-.401.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
