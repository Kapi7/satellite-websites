---
import { t, localePath, formatDateShort, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  type?: string;
  featured?: boolean;
  locale?: Locale;
}

const { title, description, date, category, slug, image, type, featured = false, locale = 'en' } = Astro.props;

const categoryKeyMap: Record<string, string> = {
  'nutrition': 'categories.nutrition',
  'movement': 'categories.movement',
  'k-beauty': 'categories.kBeauty',
  'natural-health': 'categories.naturalHealth',
};
const typeKeyMap: Record<string, string> = {
  hub: 'types.hub',
  guide: 'types.guide',
  listicle: 'types.listicle',
  review: 'types.review',
  routine: 'types.routine',
};

const categoryLabel = categoryKeyMap[category] ? t(locale, categoryKeyMap[category]) : category;
const typeLabel = type && typeKeyMap[type] ? t(locale, typeKeyMap[type]) : type;
const formattedDate = formatDateShort(date, locale);
const href = localePath(`/${slug}/`, locale);
---

<a href={href} class="rgd-article-card" data-featured={featured}>
  <div class="img rg-tint-sage">
    {image && (
      <img src={image} alt={title} loading="lazy" width="600" height="400" />
    )}
    <span class="tag">{categoryLabel}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="byline">
    <span>{typeLabel || t(locale, 'article.editorial')}</span>
    <span>{formattedDate}</span>
  </div>
</a>

<style>
  a.rgd-article-card[data-featured="true"] {
    grid-column: span 1;
  }
  @media (min-width: 901px) {
    a.rgd-article-card[data-featured="true"] {
      grid-column: span 2;
    }
    a.rgd-article-card[data-featured="true"] .img { height: 400px; }
    a.rgd-article-card[data-featured="true"] h3 { font-size: 38px; }
  }
</style>
