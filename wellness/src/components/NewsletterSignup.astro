---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section class="relative my-20 overflow-hidden">
  <!-- Decorative circles, soft blur -->
  <div class="absolute -top-24 -right-24 w-72 h-72 rounded-full bg-charcoal-light/20 blur-3xl"></div>
  <div class="absolute -bottom-20 -left-20 w-56 h-56 rounded-full bg-sage-400/15 blur-3xl"></div>

  <div class="bg-sage-100/60 rounded-2xl sm:rounded-[3rem] p-6 sm:p-8 md:p-14 border border-sage-200/30 relative overflow-hidden">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <!-- Left column: editorial copy -->
      <div class="flex-1 text-center md:text-left">
        <span class="text-xs tracking-widest text-sage-600 font-semibold uppercase">
          {t(locale, 'newsletter.preTitle')}
        </span>
        <h3 class="font-heading text-3xl md:text-4xl italic text-sage-900 mt-4 mb-5 leading-snug">
          {t(locale, 'newsletter.title')}
        </h3>
        <p class="text-sm text-sage-600 leading-relaxed max-w-md">
          {t(locale, 'newsletter.description')}
        </p>
      </div>

      <!-- Right column: form -->
      <div class="w-full md:w-auto md:min-w-[320px] flex-shrink-0">
        <form class="newsletter-form flex flex-col gap-6" data-locale={locale}>
          <input
            type="email"
            placeholder={t(locale, 'footer.emailPlaceholder')}
            required
            class="w-full bg-transparent border-b-2 border-sage-300 focus:border-sage-600 text-sage-900 text-sm py-3 placeholder:text-charcoal-light/50 focus:outline-none transition-colors duration-300"
          />
          <button
            type="submit"
            class="bg-sage-700 text-cream px-10 py-4 rounded-full text-xs tracking-widest font-semibold uppercase hover:bg-sage-800 transition-colors duration-300"
          >
            {t(locale, 'common.subscribe')}
          </button>
          <p class="newsletter-msg text-sm hidden"></p>
        </form>

      </div>
    </div>
  </div>
</section>
