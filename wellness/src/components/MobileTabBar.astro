---
import { t, localePath, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

// 5 tabs matching the rooted-glow prototype's mobile bottom nav
const tabs = [
  {
    key: 'home',
    label: t(locale, 'mobileNav.home'),
    href: localePath('/', locale),
    match: ['^/$', '^/[a-z]{2}/?$'],
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12 L12 4 L21 12"/><path d="M5 10 V20 H19 V10"/></svg>`,
  },
  {
    key: 'library',
    label: t(locale, 'mobileNav.library'),
    href: localePath('/library/', locale),
    match: ['/library/', '/category/'],
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16"/><path d="M4 10 H20 M10 4 V20"/></svg>`,
  },
  {
    key: 'tools',
    label: t(locale, 'mobileNav.tools'),
    href: localePath('/tools/', locale),
    match: ['/tools/'],
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="9"/><path d="M12 3 V6 M12 18 V21 M3 12 H6 M18 12 H21"/></svg>`,
  },
  {
    key: 'letter',
    label: t(locale, 'mobileNav.letter'),
    href: localePath('/letter/', locale),
    match: ['/letter/'],
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7 H20 V17 H4 Z"/><path d="M4 7 L12 13 L20 7"/></svg>`,
  },
  {
    key: 'more',
    label: t(locale, 'mobileNav.more'),
    href: localePath('/about/', locale),
    match: ['/about/', '/privacy/'],
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="6" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="18" cy="12" r="1.5"/></svg>`,
  },
];
---

<nav class="rg-tab-bar" aria-label="Mobile tab bar">
  {tabs.map((tab) => (
    <a href={tab.href} class="rg-tab" data-tab-key={tab.key} data-tab-match={tab.match.join('|')}>
      <span class="rg-tab-icon" set:html={tab.icon}></span>
      <span class="rg-tab-label">{tab.label}</span>
      <span class="rg-tab-dot" aria-hidden="true"></span>
    </a>
  ))}
</nav>

<style>
  .rg-tab-bar {
    display: none;
  }
  @media (max-width: 900px) {
    .rg-tab-bar {
      display: flex;
      justify-content: space-around;
      align-items: center;
      background: var(--cream);
      border-top: 1px solid rgba(47, 61, 42, 0.12);
      padding: 8px 10px calc(10px + env(safe-area-inset-bottom, 0px));
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 45;
      box-shadow: 0 -4px 20px rgba(47, 61, 42, 0.05);
    }
    body {
      padding-bottom: calc(68px + env(safe-area-inset-bottom, 0px));
    }
  }
  .rg-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    font-family: 'General Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-soft);
    padding: 4px 8px;
    text-decoration: none;
    position: relative;
    min-width: 52px;
  }
  .rg-tab.active { color: var(--forest); }
  .rg-tab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
  }
  .rg-tab-label {
    line-height: 1;
  }
  .rg-tab-dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--terracotta);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .rg-tab.active .rg-tab-dot { opacity: 1; }
  html.dark .rg-tab-bar {
    background: var(--cream);
    border-top-color: rgba(216, 221, 208, 0.15);
  }
</style>

<script>
  (function () {
    const path = window.location.pathname;
    const tabs = document.querySelectorAll('[data-tab-key]');
    let activeTab: Element | null = null;
    tabs.forEach((tab) => {
      const match = tab.getAttribute('data-tab-match') || '';
      const patterns = match.split('|').filter(Boolean);
      for (const p of patterns) {
        const re = new RegExp(p);
        if (re.test(path)) {
          // Prefer non-home tabs for non-root paths
          if (!activeTab || tab.getAttribute('data-tab-key') !== 'home') activeTab = tab;
          break;
        }
      }
    });
    activeTab?.classList.add('active');
  })();
</script>
