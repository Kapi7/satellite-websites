---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, localePath, getPathWithoutLocale, type Locale } from '../i18n/utils';
import { locales, localeNativeNames } from '../i18n/locales';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const currentPath = getPathWithoutLocale(Astro.url);

// Desktop nav — mirrors prototype: Library · Tools | brand | The Letter · About
const leftNav = [
  { label: t(locale, 'nav.library'), href: localePath('/library/', locale) },
  { label: t(locale, 'nav.tools'), href: localePath('/tools/', locale) },
];
const rightNav = [
  { label: t(locale, 'nav.letter'), href: localePath('/letter/', locale) },
  { label: t(locale, 'nav.about'), href: localePath('/about/', locale) },
];

// Mobile drawer — the same prototype items + sub-tools + utility links
const drawerPrimary = [
  { label: t(locale, 'nav.library'), href: localePath('/library/', locale) },
  { label: t(locale, 'nav.tools'), href: localePath('/tools/', locale) },
  { label: t(locale, 'nav.letter'), href: localePath('/letter/', locale) },
  { label: t(locale, 'nav.about'), href: localePath('/about/', locale) },
];
const drawerCategories = [
  { label: t(locale, 'categories.nutrition'), href: localePath('/category/nutrition/', locale) },
  { label: t(locale, 'categories.movement'), href: localePath('/category/movement/', locale) },
  { label: t(locale, 'categories.kBeauty'), href: localePath('/category/k-beauty/', locale) },
  { label: t(locale, 'categories.naturalHealth'), href: localePath('/category/natural-health/', locale) },
];
const drawerTools = [
  { label: t(locale, 'nav.wellnessQuiz'), href: localePath('/tools/quiz/', locale) },
  { label: t(locale, 'nav.seasonalGuide'), href: localePath('/tools/seasonal-guide/', locale) },
  { label: t(locale, 'nav.herbIndex'), href: localePath('/tools/herb-index/', locale) },
  { label: t(locale, 'nav.recipeGenerator'), href: localePath('/tools/recipe-generator/', locale) },
  { label: t(locale, 'nav.runningPlan'), href: localePath('/tools/running-plan/', locale) },
];

const now = new Date();
const issueStamp = now.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase();
---

<header class="rgd-page sticky top-0 z-50 backdrop-blur-md" id="site-header" style="background: rgba(245,241,234,0.92); border-bottom: 1px solid rgba(47,61,42,0.15);">
  <div class="rgd-nav-inner">

    <!-- Desktop: left nav -->
    <nav class="rgd-left-nav">
      {leftNav.map((item) => (
        <a href={item.href} class="rgd-nav-link">{item.label}</a>
      ))}
    </nav>

    <!-- Mobile: hamburger button -->
    <button id="mobile-menu-btn" class="rgd-hamburger" aria-label={t(locale, 'common.openMenu')} aria-expanded="false">
      <svg id="menu-icon-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M3.75 9h16.5m-16.5 6.75h16.5" /></svg>
      <svg id="menu-icon-close" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M6 18 18 6M6 6l12 12" /></svg>
    </button>

    <!-- Brand (centre, always shown) -->
    <a href={localePath('/', locale)} class="rgd-brand">
      rooted <em>glow.</em>
    </a>

    <!-- Desktop: right nav + issue stamp + controls -->
    <div class="rgd-right-nav">
      {rightNav.map((item) => (
        <a href={item.href} class="rgd-nav-link">{item.label}</a>
      ))}
      <span class="rgd-stamp">{issueStamp}</span>
      <LanguageSwitcher locale={locale} />
      <button id="dark-mode-toggle" class="rgd-icon-btn" aria-label={t(locale, 'common.toggleDarkMode')}>
        <svg class="w-4 h-4 block dark:hidden" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
        <svg class="w-4 h-4 hidden dark:block" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
      </button>
    </div>

    <!-- Mobile: empty spacer so brand stays centred -->
    <div class="rgd-mobile-spacer" aria-hidden="true"></div>
  </div>
</header>

<!-- Mobile menu rendered OUTSIDE the <header> because header has backdrop-filter,
     which creates a new containing block that would trap position:fixed children. -->
<div id="mobile-menu-backdrop" class="rgd-backdrop" hidden aria-hidden="true"></div>
<aside id="mobile-menu" class="rgd-drawer" hidden aria-label={t(locale, 'common.openMenu')} role="dialog" aria-modal="true">
  <div class="rgd-drawer-head">
    <a href={localePath('/', locale)} class="rgd-brand rgd-drawer-brand">
      rooted <em>glow.</em>
    </a>
    <button id="mobile-menu-close" class="rgd-drawer-close" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M6 18 18 6M6 6l12 12" /></svg>
    </button>
  </div>

  <nav class="rgd-drawer-inner">
    {drawerPrimary.map((item) => (
      <a href={item.href} class="rgd-drawer-link rgd-drawer-link--primary">{item.label}</a>
    ))}

    <span class="rgd-drawer-label">{t(locale, 'home.explore')}</span>
    {drawerCategories.map((item) => (
      <a href={item.href} class="rgd-drawer-link rgd-drawer-link--sub">{item.label}</a>
    ))}

    <span class="rgd-drawer-label">{t(locale, 'nav.tools')}</span>
    {drawerTools.map((tool) => (
      <a href={tool.href} class="rgd-drawer-link rgd-drawer-link--sub">{tool.label}</a>
    ))}

    <!-- Inline language picker (no dropdown — better UX inside drawer) -->
    <span class="rgd-drawer-label">{t(locale, 'common.language') || 'Language'}</span>
    <div class="rgd-drawer-langs" role="group" aria-label="Language">
      {locales.map((l) => (
        <a
          href={l === 'en' ? (currentPath || '/') : `/${l}${currentPath || '/'}`}
          class={`rgd-drawer-lang ${l === locale ? 'is-active' : ''}`}
          lang={l}
          hreflang={l}
        >
          {localeNativeNames[l]}
        </a>
      ))}
    </div>

    <!-- Bottom controls: dark mode -->
    <div class="rgd-drawer-controls">
      <button id="dark-mode-toggle-mobile" class="rgd-drawer-dark" aria-label={t(locale, 'common.toggleDarkMode')}>
        <svg class="block dark:hidden" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
        <svg class="hidden dark:block" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
        <span>{t(locale, 'common.toggleDarkMode')}</span>
      </button>
    </div>
  </nav>
</aside>

<style>
  .rgd-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 20px 0 18px;
    gap: 24px;
    font-family: 'General Sans', sans-serif;
  }
  .rgd-left-nav, .rgd-right-nav {
    display: flex;
    align-items: center;
    gap: 22px;
    font-size: 13.5px;
  }
  .rgd-right-nav { justify-content: flex-end; }
  .rgd-nav-link {
    color: var(--forest);
    text-decoration: none;
    padding: 6px 4px;
    transition: color 0.15s;
  }
  .rgd-nav-link:hover { color: var(--terracotta); }
  .rgd-brand {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(22px, 3vw, 30px);
    letter-spacing: -0.01em;
    text-align: center;
    text-decoration: none;
    color: var(--forest);
    line-height: 1;
  }
  .rgd-brand em { font-style: italic; color: var(--terracotta); }
  .rgd-stamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .rgd-icon-btn {
    background: transparent;
    border: none;
    padding: 6px;
    color: var(--ink-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }
  .rgd-icon-btn:hover { color: var(--terracotta); }
  .rgd-hamburger {
    display: none;
    background: transparent;
    border: 1px solid rgba(47, 61, 42, 0.3);
    border-radius: 999px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    color: var(--forest);
    cursor: pointer;
    padding: 0;
  }
  .rgd-mobile-spacer { display: none; }

  /* ===== Mobile drawer — full-viewport slide-in from right ===== */
  .rgd-backdrop {
    position: fixed; inset: 0;
    background: rgba(26, 32, 22, 0.45);
    z-index: 90;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease-out;
  }
  .rgd-backdrop[hidden] { display: none; }
  .rgd-backdrop.is-open { opacity: 1; pointer-events: auto; }

  .rgd-drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(86vw, 380px);
    background: var(--linen);
    z-index: 100;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.22s ease-out;
    box-shadow: -8px 0 24px rgba(47, 61, 42, 0.08);
    overscroll-behavior: contain;
  }
  .rgd-drawer[hidden] { display: none; }
  .rgd-drawer.is-open { transform: translateX(0); }

  .rgd-drawer-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(47, 61, 42, 0.1);
    flex: 0 0 auto;
  }
  .rgd-drawer-brand {
    font-size: 24px;
  }
  .rgd-drawer-close {
    width: 44px; height: 44px;
    min-width: 44px; min-height: 44px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent;
    border: 1px solid rgba(47, 61, 42, 0.2);
    border-radius: 999px;
    color: var(--forest);
    cursor: pointer;
    padding: 0;
  }

  .rgd-drawer-inner {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 12px 20px calc(28px + env(safe-area-inset-bottom, 0px));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .rgd-drawer-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 18px 0 6px;
  }
  .rgd-drawer-label:first-child { margin-top: 6px; }
  .rgd-drawer-link {
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    color: var(--forest);
    text-decoration: none;
    padding: 14px 0;
    min-height: 44px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(47, 61, 42, 0.08);
  }
  .rgd-drawer-link:active { color: var(--terracotta); }
  .rgd-drawer-link--primary { font-size: 26px; }
  .rgd-drawer-link--sub { font-size: 18px; }

  /* Inline language picker (grid of locales, no dropdown) */
  .rgd-drawer-langs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-top: 4px;
  }
  .rgd-drawer-lang {
    display: flex; align-items: center;
    min-height: 44px;
    padding: 10px 14px;
    border: 1px solid rgba(47, 61, 42, 0.18);
    border-radius: 999px;
    font-family: 'General Sans', sans-serif;
    font-size: 14px;
    color: var(--forest);
    text-decoration: none;
    background: transparent;
    transition: background 0.15s, border-color 0.15s;
  }
  .rgd-drawer-lang:active { background: rgba(47, 61, 42, 0.06); }
  .rgd-drawer-lang.is-active {
    background: var(--forest);
    border-color: var(--forest);
    color: var(--paper, #faf7f0);
    font-weight: 600;
  }

  .rgd-drawer-controls {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(47, 61, 42, 0.12);
  }
  .rgd-drawer-dark {
    display: flex; align-items: center; gap: 10px;
    min-height: 44px;
    padding: 10px 14px;
    background: transparent;
    border: 1px solid rgba(47, 61, 42, 0.18);
    border-radius: 10px;
    font-family: 'General Sans', sans-serif;
    font-size: 14px;
    color: var(--forest);
    cursor: pointer;
    width: 100%;
  }
  .rgd-drawer-dark:active { background: rgba(47, 61, 42, 0.06); }

  body.rgd-menu-open { overflow: hidden; }

  /* Mobile (<= 767px): hide desktop nav + controls, show hamburger, keep brand centred */
  @media (max-width: 767px) {
    .rgd-nav-inner {
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      padding: 16px 0 14px;
    }
    .rgd-left-nav, .rgd-right-nav { display: none; }
    .rgd-hamburger { display: inline-flex; }
    .rgd-mobile-spacer { display: block; width: 38px; height: 38px; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  const openMenu = () => {
    if (!menu || !backdrop) return;
    menu.removeAttribute('hidden');
    backdrop.removeAttribute('hidden');
    // rAF so the transition plays on the first paint after display change
    requestAnimationFrame(() => {
      menu.classList.add('is-open');
      backdrop.classList.add('is-open');
    });
    btn?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    document.body.classList.add('rgd-menu-open');
  };
  const closeMenu = () => {
    if (!menu || !backdrop) return;
    menu.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    // hide after transition completes so display:none doesn't cut animation
    setTimeout(() => {
      if (!menu.classList.contains('is-open')) {
        menu.setAttribute('hidden', '');
        backdrop.setAttribute('hidden', '');
      }
    }, 240);
    btn?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.classList.remove('rgd-menu-open');
  };

  btn?.addEventListener('click', () => {
    if (menu?.classList.contains('is-open')) closeMenu();
    else openMenu();
  });
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  // Close when a drawer link is tapped (except language — user might want to cancel)
  menu?.querySelectorAll('.rgd-drawer-link').forEach((a) => {
    a.addEventListener('click', closeMenu);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('is-open')) closeMenu();
  });

  const toggleDark = () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };
  document.getElementById('dark-mode-toggle')?.addEventListener('click', toggleDark);
  document.getElementById('dark-mode-toggle-mobile')?.addEventListener('click', toggleDark);

  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header?.style.setProperty('box-shadow', '0 4px 16px rgba(47,61,42,0.06)');
    } else {
      header?.style.removeProperty('box-shadow');
    }
  }, { passive: true });
</script>
