---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((l) => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const all = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const recent = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 4);

const getSlug = (post: any) => {
  const id = post.id as string;
  const s = id.includes('/') ? id.split('/').slice(1).join('/') : id;
  return s.replace(/\.mdx?$/, '');
};
const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Letter — Rooted Glow newsletter',
  url: 'https://rooted-glow.com/newsletter/',
  description: 'One Sunday letter. Gut-skin science, ancestral food, honest wellness. No hype.',
});
---

<Base
  title="Letter — Rooted Glow"
  description="One Sunday letter. Gut-skin science, ancestral food, honest wellness. No hype."
  jsonLd={[schema]}
  locale={locale}
>
  <Header locale={locale} />
  <main class="rg-newsletter">
    <div class="kicker">
      <span class="pill">✳ THE LETTER</span>
      <span>Sundays · 4,100 readers</span>
    </div>

    <h1>A Sunday <em>letter.</em><br />Gut, food, skin.</h1>

    <p class="lede">
      One considered email every Sunday. Something we've been eating, reading, moving through, or testing on our own skin. Slow ideas, long-form thinking, nothing from our affiliate list.
    </p>

    <div class="signup">
      <form class="form newsletter-form" data-locale={locale}>
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe →</button>
      </form>
      <p class="fine">No spam. Unsubscribe any time. Free forever.</p>
    </div>

    {recent.length > 0 && (
      <section class="recent">
        <h2>Recent issues</h2>
        <div class="list">
          {recent.map((p, i) => (
            <a href={localePath(`/${getSlug(p)}/`, locale)} class="row">
              <div class="num">№{String(i + 1).padStart(2, '0')}</div>
              <div class="body">
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
              </div>
              <div class="date">{formatDate(p.data.date)}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer locale={locale} />
  <BackToTop />
</Base>

<style is:global>
  .rg-newsletter {
    max-width: 820px;
    margin: 60px auto;
    padding: 0 32px 80px;
    color: var(--forest);
  }
  .rg-newsletter .kicker {
    display: flex; gap: 10px; align-items: center;
    margin-bottom: 18px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--forest);
  }
  .rg-newsletter .kicker .pill {
    padding: 4px 10px;
    border: 1.3px solid var(--forest);
    border-radius: 999px;
  }

  .rg-newsletter h1 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(56px, 9vw, 96px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 18px 0 24px;
    color: var(--forest);
  }
  .rg-newsletter h1 em {
    font-style: italic;
    color: var(--terracotta);
  }

  .rg-newsletter .lede {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 19px;
    line-height: 1.55;
    color: var(--forest-soft);
    max-width: 680px;
    margin: 0 0 34px;
  }

  .rg-newsletter .signup {
    background: var(--sage-light, #e8ecdf);
    border: 1.5px solid var(--forest);
    border-radius: 8px;
    padding: 30px;
    box-shadow: 6px 6px 0 var(--forest);
  }
  .rg-newsletter .signup .form {
    display: flex; gap: 10px;
  }
  .rg-newsletter .signup input {
    flex: 1;
    padding: 14px 18px;
    border: 1.5px solid var(--forest);
    border-radius: 999px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    outline: none;
    background: var(--paper, #faf7f0);
    color: var(--forest);
  }
  .rg-newsletter .signup input::placeholder {
    color: rgba(47, 61, 42, 0.4);
  }
  .rg-newsletter .signup button {
    background: var(--terracotta);
    color: #fff;
    border: 1.5px solid var(--forest);
    padding: 14px 26px;
    border-radius: 999px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    min-height: 44px;
  }
  .rg-newsletter .signup .fine {
    color: var(--forest-soft);
    font-size: 12px;
    margin: 14px 0 0;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .rg-newsletter .recent { margin-top: 56px; }
  .rg-newsletter .recent h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 40px;
    letter-spacing: -0.01em;
    font-weight: 400;
    margin: 0 0 20px;
    color: var(--forest);
  }
  .rg-newsletter .list { display: grid; gap: 0; }
  .rg-newsletter .row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 18px 0;
    border-top: 1.5px solid rgba(47, 61, 42, 0.2);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .rg-newsletter .row:hover { background: rgba(47, 61, 42, 0.03); }
  .rg-newsletter .row .num {
    font-family: 'Instrument Serif', serif;
    font-size: 44px;
    color: var(--terracotta);
  }
  .rg-newsletter .row h3 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.1;
    margin: 0 0 4px;
    color: var(--forest);
  }
  .rg-newsletter .row p {
    font-size: 14px;
    color: var(--forest-soft);
    margin: 0;
  }
  .rg-newsletter .row .date {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--forest-soft);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .rg-newsletter { margin: 24px auto; padding: 0 20px 80px; }
    .rg-newsletter h1 { font-size: 44px; }
    .rg-newsletter .signup { padding: 22px; }
    .rg-newsletter .signup .form { flex-direction: column; }
    .rg-newsletter .signup button { padding: 14px 18px; }
    .rg-newsletter .recent h2 { font-size: 32px; }
    .rg-newsletter .row { grid-template-columns: 60px 1fr; gap: 14px; }
    .rg-newsletter .row .num { font-size: 32px; }
    .rg-newsletter .row h3 { font-size: 20px; }
    .rg-newsletter .row .date { display: none; }
  }
</style>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const input = f.querySelector('input[type="email"]') as HTMLInputElement;
      const btn = f.querySelector('button') as HTMLButtonElement;
      const email = input.value.trim();
      if (!email) return;
      btn.disabled = true;
      try {
        await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, locale: (f as HTMLElement).dataset.locale || 'en' }),
        });
        btn.textContent = 'Done';
      } catch {
        btn.textContent = 'Retry';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
</content>
