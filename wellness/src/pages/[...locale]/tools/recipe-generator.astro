---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BackToTop from '../../../components/BackToTop.astro';
import { locales, defaultLocale, type Locale } from '../../../i18n/locales';
import { t, localePath } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: 'https://rooted-glow.com/' },
    { '@type': 'ListItem', position: 2, name: t(locale, 'recipeGenerator.title'), item: 'https://rooted-glow.com/tools/recipe-generator/' },
  ],
});
---

<Base
  title={t(locale, 'recipeGenerator.title') + ' — Rooted Glow'}
  description={t(locale, 'recipeGenerator.description')}
  jsonLd={[breadcrumbSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <main class="flex-1">
    <!-- Breadcrumb -->
    <div class="max-w-3xl mx-auto px-5 sm:px-8 pt-8">
      <nav class="flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.1em] text-sage-400">
        <a href={localePath('/', locale)} class="hover:text-sage-600 transition-colors">{t(locale, 'common.home')}</a>
        <span>/</span>
        <span class="text-sage-600">{t(locale, 'recipeGenerator.title')}</span>
      </nav>
    </div>

    <div class="max-w-3xl mx-auto px-5 sm:px-8 py-12">
      <!-- Intro -->
      <div class="text-center mb-12 animate-fade-in-up">
        <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-sage-400 mb-4">{t(locale, 'recipeGenerator.toolLabel')}</span>
        <h1 class="font-heading text-4xl sm:text-5xl text-charcoal tracking-tight mb-4">{t(locale, 'recipeGenerator.title')}</h1>
        <p class="text-sage-500 leading-relaxed max-w-lg mx-auto">{t(locale, 'recipeGenerator.description')}</p>
      </div>

      <!-- Form -->
      <div id="rg-form">
        <!-- Step 1: Meal Type -->
        <div class="mb-10">
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-5">{t(locale, 'recipeGenerator.stepMeal')}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="rg-meals">
            <button data-value="breakfast" class="rg-meal group text-center p-5 rounded-2xl border border-sage-200/60 bg-white hover:border-sage-300 hover:shadow-md transition-all duration-200">
              <span class="block text-2xl mb-2">&#x1F373;</span>
              <span class="block text-sm font-medium text-charcoal group-hover:text-sage-700 transition-colors">{t(locale, 'recipeGenerator.mealBreakfast')}</span>
            </button>
            <button data-value="lunch" class="rg-meal group text-center p-5 rounded-2xl border border-sage-200/60 bg-white hover:border-sage-300 hover:shadow-md transition-all duration-200">
              <span class="block text-2xl mb-2">&#x1F957;</span>
              <span class="block text-sm font-medium text-charcoal group-hover:text-sage-700 transition-colors">{t(locale, 'recipeGenerator.mealLunch')}</span>
            </button>
            <button data-value="dinner" class="rg-meal group text-center p-5 rounded-2xl border border-sage-200/60 bg-white hover:border-sage-300 hover:shadow-md transition-all duration-200">
              <span class="block text-2xl mb-2">&#x1F35D;</span>
              <span class="block text-sm font-medium text-charcoal group-hover:text-sage-700 transition-colors">{t(locale, 'recipeGenerator.mealDinner')}</span>
            </button>
            <button data-value="snack" class="rg-meal group text-center p-5 rounded-2xl border border-sage-200/60 bg-white hover:border-sage-300 hover:shadow-md transition-all duration-200">
              <span class="block text-2xl mb-2">&#x1F34E;</span>
              <span class="block text-sm font-medium text-charcoal group-hover:text-sage-700 transition-colors">{t(locale, 'recipeGenerator.mealSnack')}</span>
            </button>
          </div>
        </div>

        <!-- Step 2: Goals (multi-select) -->
        <div class="mb-10 hidden" id="rg-goals-section">
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-1">{t(locale, 'recipeGenerator.stepGoals')}</h2>
          <p class="text-xs text-sage-400 mb-4">{t(locale, 'recipeGenerator.stepGoalsDesc')}</p>
          <div class="flex flex-wrap gap-3" id="rg-goals">
            <button data-value="high-protein" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalHighProtein')}</button>
            <button data-value="anti-inflammatory" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalAntiInflammatory')}</button>
            <button data-value="gut-health" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalGutHealth')}</button>
            <button data-value="weight-loss" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalWeightLoss')}</button>
            <button data-value="energy" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalEnergy')}</button>
            <button data-value="recovery" class="rg-goal px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.goalRecovery')}</button>
          </div>
        </div>

        <!-- Step 3: Restrictions (multi-select, optional) -->
        <div class="mb-10 hidden" id="rg-restrictions-section">
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-1">{t(locale, 'recipeGenerator.stepRestrictions')}</h2>
          <p class="text-xs text-sage-400 mb-4">{t(locale, 'recipeGenerator.stepRestrictionsDesc')}</p>
          <div class="flex flex-wrap gap-3" id="rg-restrictions">
            <button data-value="gluten-free" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionGlutenFree')}</button>
            <button data-value="dairy-free" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionDairyFree')}</button>
            <button data-value="vegetarian" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionVegetarian')}</button>
            <button data-value="vegan" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionVegan')}</button>
            <button data-value="keto" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionKeto')}</button>
            <button data-value="paleo" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionPaleo')}</button>
            <button data-value="nut-free" class="rg-restriction px-4 py-2.5 rounded-full border border-sage-200/60 bg-white text-sm text-charcoal hover:border-sage-300 transition-all duration-200">{t(locale, 'recipeGenerator.restrictionNutFree')}</button>
          </div>
        </div>

        <!-- Step 4: Ingredients (optional) -->
        <div class="mb-10 hidden" id="rg-ingredients-section">
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-sage-400 mb-4">{t(locale, 'recipeGenerator.stepIngredients')}</h2>
          <input type="text" id="rg-ingredients" placeholder={t(locale, 'recipeGenerator.ingredientsPlaceholder')} class="w-full px-4 py-3 rounded-xl border border-sage-200/60 bg-white text-sm text-charcoal focus:outline-none focus:border-sage-400 focus:ring-1 focus:ring-sage-400/30 transition-all" />

          <!-- Generate button -->
          <div class="mt-8">
            <button id="rg-generate" class="inline-flex items-center gap-2 px-8 py-3.5 bg-sage-600 text-white text-sm font-semibold rounded-full hover:bg-sage-700 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z" /></svg>
              {t(locale, 'recipeGenerator.generateBtn')}
            </button>
          </div>
        </div>
      </div>

      <!-- Loading -->
      <div id="rg-loading" class="hidden text-center py-12">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="w-2 h-2 rounded-full bg-sage-500 animate-pulse-soft"></span>
          <span class="w-2 h-2 rounded-full bg-sage-500 animate-pulse-soft" style="animation-delay: 0.3s"></span>
          <span class="w-2 h-2 rounded-full bg-sage-500 animate-pulse-soft" style="animation-delay: 0.6s"></span>
        </div>
        <p class="text-sm text-sage-400">{t(locale, 'recipeGenerator.generating')}</p>
      </div>

      <!-- Results -->
      <div id="rg-results" class="hidden">
        <!-- Recipe content -->
        <div id="rg-content" class="prose prose-sm max-w-none rounded-2xl border border-sage-200/60 bg-white p-6 sm:p-8 mb-6"></div>

        <!-- Disclaimer -->
        <p class="text-xs text-sage-400 italic text-center mb-6">{t(locale, 'recipeGenerator.disclaimer')}</p>

        <!-- Actions -->
        <div class="flex items-center justify-center gap-4">
          <button id="rg-another" class="inline-flex items-center gap-2 px-6 py-3 bg-sage-600 text-white text-sm font-semibold rounded-full hover:bg-sage-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>
            {t(locale, 'recipeGenerator.generateAnother')}
          </button>
          <button id="rg-start-over" class="text-sm text-sage-400 hover:text-sage-600 transition-colors underline underline-offset-4 decoration-sage-300">
            {t(locale, 'runningPlan.startOver')}
          </button>
        </div>
      </div>

      <!-- Error -->
      <div id="rg-error" class="hidden text-center py-8">
        <p class="text-sm text-sage-500 mb-3">{t(locale, 'quiz.aiPlanError')}</p>
        <button id="rg-retry" class="text-sm text-sage-600 underline underline-offset-4 decoration-sage-300 hover:text-sage-800 transition-colors">{t(locale, 'quiz.tryAgain')}</button>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
  <BackToTop locale={locale} />
</Base>

<script is:inline>
(function() {
  'use strict';
  // NOTE: innerHTML usage here renders AI-generated markdown from our own API endpoint,
  // not user-supplied HTML. This matches the existing pattern in quiz/index.astro.

  let selectedMeal = null;
  let selectedGoals = [];
  let selectedRestrictions = [];

  const form = document.getElementById('rg-form');
  const goalsSection = document.getElementById('rg-goals-section');
  const restrictionsSection = document.getElementById('rg-restrictions-section');
  const ingredientsSection = document.getElementById('rg-ingredients-section');
  const loadingEl = document.getElementById('rg-loading');
  const resultsEl = document.getElementById('rg-results');
  const contentEl = document.getElementById('rg-content');
  const errorEl = document.getElementById('rg-error');

  // Meal selection (single)
  document.querySelectorAll('.rg-meal').forEach(btn => {
    btn.addEventListener('click', function() {
      selectedMeal = this.dataset.value;
      document.querySelectorAll('.rg-meal').forEach(b => {
        b.classList.remove('border-sage-500', 'bg-sage-50');
        b.classList.add('border-sage-200/60');
      });
      this.classList.remove('border-sage-200/60');
      this.classList.add('border-sage-500', 'bg-sage-50');
      goalsSection.classList.remove('hidden');
      goalsSection.classList.add('animate-fade-in-up');
    });
  });

  // Goals (multi-select, 1-3)
  document.querySelectorAll('.rg-goal').forEach(btn => {
    btn.addEventListener('click', function() {
      const val = this.dataset.value;
      const idx = selectedGoals.indexOf(val);
      if (idx > -1) {
        selectedGoals.splice(idx, 1);
        this.classList.remove('border-sage-500', 'bg-sage-50', 'text-sage-700');
        this.classList.add('border-sage-200/60', 'text-charcoal');
      } else if (selectedGoals.length < 3) {
        selectedGoals.push(val);
        this.classList.remove('border-sage-200/60', 'text-charcoal');
        this.classList.add('border-sage-500', 'bg-sage-50', 'text-sage-700');
      }
      if (selectedGoals.length > 0) {
        restrictionsSection.classList.remove('hidden');
        restrictionsSection.classList.add('animate-fade-in-up');
        ingredientsSection.classList.remove('hidden');
        ingredientsSection.classList.add('animate-fade-in-up');
      }
    });
  });

  // Restrictions (multi-select, optional)
  document.querySelectorAll('.rg-restriction').forEach(btn => {
    btn.addEventListener('click', function() {
      const val = this.dataset.value;
      const idx = selectedRestrictions.indexOf(val);
      if (idx > -1) {
        selectedRestrictions.splice(idx, 1);
        this.classList.remove('border-sage-500', 'bg-sage-50', 'text-sage-700');
        this.classList.add('border-sage-200/60', 'text-charcoal');
      } else {
        selectedRestrictions.push(val);
        this.classList.remove('border-sage-200/60', 'text-charcoal');
        this.classList.add('border-sage-500', 'bg-sage-50', 'text-sage-700');
      }
    });
  });

  // Generate
  function generate() {
    if (!selectedMeal || selectedGoals.length === 0) return;

    form.classList.add('hidden');
    loadingEl.classList.remove('hidden');
    resultsEl.classList.add('hidden');
    errorEl.classList.add('hidden');
    contentEl.textContent = '';

    const ingredients = document.getElementById('rg-ingredients').value;

    const payload = {
      mealType: selectedMeal,
      goals: selectedGoals,
      restrictions: selectedRestrictions,
    };
    if (ingredients.trim()) payload.ingredients = ingredients.trim();

    fetch('/api/recipe-generator', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    .then(response => {
      if (!response.ok) throw new Error('API error');
      loadingEl.classList.add('hidden');
      resultsEl.classList.remove('hidden');
      resultsEl.classList.add('animate-fade-in-up');

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let markdown = '';

      function pump() {
        return reader.read().then(({ done, value }) => {
          if (done) {
            contentEl.innerHTML = renderMarkdown(markdown);
            return;
          }
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed || !trimmed.startsWith('data: ')) continue;
            const data = trimmed.slice(6);
            if (data === '[DONE]') continue;
            try {
              const parsed = JSON.parse(data);
              if (parsed.content) {
                markdown += parsed.content;
                contentEl.innerHTML = renderMarkdown(markdown);
              }
            } catch {}
          }
          return pump();
        });
      }
      return pump();
    })
    .catch(() => {
      loadingEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
    });
  }

  // Renders markdown from our own AI API endpoint (not user HTML)
  function renderMarkdown(md) {
    return md
      .replace(/^#### (.+)$/gm, '<h5 class="font-heading text-sm font-semibold text-charcoal mt-3 mb-1">$1</h5>')
      .replace(/^### (.+)$/gm, '<h4 class="font-heading text-base text-charcoal mt-4 mb-1">$1</h4>')
      .replace(/^## (.+)$/gm, '<h3 class="font-heading text-lg text-charcoal mt-6 mb-2">$1</h3>')
      .replace(/^# (.+)$/gm, '<h2 class="font-heading text-2xl text-charcoal mt-6 mb-3">$1</h2>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/^- (.+)$/gm, '<li class="text-sm text-sage-600 ml-4 list-disc leading-relaxed">$1</li>')
      .replace(/(<li[^>]*list-disc[^>]*>.*<\/li>\n?)+/g, function(m) { return '<ul class="space-y-1 mb-3">' + m + '</ul>'; })
      .replace(/^\d+\. (.+)$/gm, '<li class="text-sm text-sage-600 ml-4 list-decimal leading-relaxed">$1</li>')
      .replace(/(<li[^>]*list-decimal[^>]*>.*<\/li>\n?)+/g, function(m) { return '<ol class="space-y-1 mb-3">' + m + '</ol>'; })
      .replace(/^(?!<[hulo])(\S.+)$/gm, '<p class="text-sm text-sage-600 leading-relaxed mb-3">$1</p>');
  }

  document.getElementById('rg-generate')?.addEventListener('click', generate);
  document.getElementById('rg-retry')?.addEventListener('click', function() {
    errorEl.classList.add('hidden');
    generate();
  });

  // Generate another (same inputs, new recipe)
  document.getElementById('rg-another')?.addEventListener('click', function() {
    resultsEl.classList.add('hidden');
    generate();
  });

  // Full reset
  document.getElementById('rg-start-over')?.addEventListener('click', function() {
    selectedMeal = null;
    selectedGoals = [];
    selectedRestrictions = [];
    resultsEl.classList.add('hidden');
    form.classList.remove('hidden');
    goalsSection.classList.add('hidden');
    restrictionsSection.classList.add('hidden');
    ingredientsSection.classList.add('hidden');
    contentEl.textContent = '';
    document.querySelectorAll('.rg-meal, .rg-goal, .rg-restriction').forEach(b => {
      b.classList.remove('border-sage-500', 'bg-sage-50', 'text-sage-700');
      b.classList.add('border-sage-200/60');
    });
    document.getElementById('rg-ingredients').value = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>
