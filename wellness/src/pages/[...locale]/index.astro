---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath, formatDateShort } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale && data.date <= now);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Load GSC-based featured articles (trending list)
let featuredData: { trending: any[]; rising: any[] } = { trending: [], rising: [] };
try {
  const raw = await import('../../data/featured.json');
  featuredData = (raw.default || raw) as { trending: any[]; rising: any[] };
} catch { /* no featured data yet */ }

const trendingSlugs = new Set(featuredData.trending.map((t: any) => t.slug));
const trendingPosts = featuredData.trending
  .map((t: any) => sortedPosts.find(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    const clean = slug.replace('.mdx', '').replace('.md', '');
    return clean === t.slug;
  }))
  .filter(Boolean) as typeof sortedPosts;

// Fall back to recent if we don't have trending
const featureSource = trendingPosts.length > 0 ? trendingPosts : sortedPosts;
const heroPost = featureSource[0];
const sidebarList = featureSource.slice(1, 5);

// Recent = latest 6 not in trending
const recent = sortedPosts
  .filter(p => {
    const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
    const clean = slug.replace('.mdx', '').replace('.md', '');
    return !trendingSlugs.has(clean);
  })
  .slice(0, 6);

const categoryMap = [
  { slug: 'nutrition', label: t(locale, 'categories.nutrition') },
  { slug: 'movement', label: t(locale, 'categories.movement') },
  { slug: 'k-beauty', label: t(locale, 'categories.kBeauty') },
  { slug: 'natural-health', label: t(locale, 'categories.naturalHealth') },
];
const categories = categoryMap.map(c => ({
  ...c,
  count: sortedPosts.filter(p => p.data.category === c.slug).length,
  href: localePath(`/category/${c.slug}/`, locale),
}));

function postSlug(p: any) {
  const slug = p.id.includes('/') ? p.id.split('/').slice(1).join('/') : p.id;
  return slug.replace('.mdx', '').replace('.md', '');
}
function postHref(p: any) {
  return localePath(`/${postSlug(p)}/`, locale);
}
function postCategoryLabel(p: any) {
  const map: Record<string, string> = {
    'nutrition': 'categories.nutrition',
    'movement': 'categories.movement',
    'k-beauty': 'categories.kBeauty',
    'natural-health': 'categories.naturalHealth',
  };
  return map[p.data.category] ? t(locale, map[p.data.category]) : p.data.category;
}

const totalPosts = sortedPosts.length;
const authorLabel = t(locale, 'article.editorial');

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
  logo: 'https://rooted-glow.com/logo.svg',
  description: 'Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
});
---

<Base
  title="Rooted Glow"
  description="Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <main class="flex-1 rgd-page linen paper-grain" style="padding-top:24px;">

    <!-- Masthead -->
    <section class="rgd-mast animate-fade-in-up">
      <div>
        <div class="kicker">
          <span class="dot"></span>
          <span>{t(locale, 'home.mastheadKicker')}</span>
        </div>
        <h1 set:html={t(locale, 'home.mastheadTitle')} />
        <p class="sub">{t(locale, 'home.mastheadSub')}</p>
      </div>
      <div class="rgd-mast-meta" set:html={t(locale, 'home.mastheadMeta')} />
    </section>

    {heroPost && (
      <!-- Featured article + sidebar list -->
      <section class="rgd-feature animate-fade-in-up stagger-1">
        <a href={postHref(heroPost)} class="rgd-feature-main" style="text-decoration:none;color:inherit;display:block;">
          <div class="img">
            <span class="seal">{t(locale, 'home.trending').toLowerCase()}</span>
            {heroPost.data.image && (
              <img src={heroPost.data.image} alt={heroPost.data.imageAlt || heroPost.data.title} loading="eager" width="1200" height="600" />
            )}
          </div>
          <div class="meta">
            <span>{postCategoryLabel(heroPost)}</span>
            <span>·</span>
            <span>{formatDateShort(heroPost.data.date, locale)}</span>
            <span>·</span>
            <span>{heroPost.data.author || authorLabel}</span>
          </div>
          <h2>{heroPost.data.title}</h2>
          <p>{heroPost.data.description}</p>
        </a>
        <aside class="rgd-feature-side">
          <h4>{t(locale, 'home.thisWeek')}</h4>
          {sidebarList.map((p, i) => (
            <a href={postHref(p)} class="rgd-side-item">
              <div class="n">{String(i + 2).padStart(2, '0')}</div>
              <div>
                <h5>{p.data.title}</h5>
                <div class="meta-s">{postCategoryLabel(p)} · {formatDateShort(p.data.date, locale)}</div>
              </div>
            </a>
          ))}
        </aside>
      </section>
    )}

    <!-- Categories -->
    <section class="animate-fade-in-up stagger-2">
      <div class="rgd-section-head">
        <h2 set:html={t(locale, 'home.byTitle')} />
        <div class="rule"></div>
        <div class="meta">{totalPosts} {t(locale, 'common.articles')} · 4 {t(locale, 'home.explore').toLowerCase()}</div>
      </div>
      <div class="rgd-cats">
        {categories.map((c) => (
          <a href={c.href} class="rgd-cat-card">
            <div>
              <small>{c.count} {c.count === 1 ? t(locale, 'common.article') : t(locale, 'common.articles')}</small>
              <h4 style="margin-top:8px;">{c.label}</h4>
            </div>
            <div class="num-big">{String(c.count).padStart(2, '0')}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Protocol promo -->
    <section class="rgd-protocol animate-fade-in-up stagger-3">
      <div>
        <div class="label">{t(locale, 'home.protocolLabel')}</div>
        <h3 set:html={t(locale, 'home.protocolTitle')} />
        <p>{t(locale, 'home.protocolDesc')}</p>
        <div class="cta-row">
          <a href={localePath('/tools/quiz/', locale)} class="btn-prim">{t(locale, 'home.protocolStart')}</a>
          <a href={localePath('/tools/', locale)} class="btn-sec">{t(locale, 'home.protocolSeeTools')}</a>
        </div>
      </div>
      <div class="steps">
        <div class="step"><div class="n">I.</div><div><h5>{t(locale, 'home.protocolStep1Title')}</h5><p>{t(locale, 'home.protocolStep1Desc')}</p></div></div>
        <div class="step"><div class="n">II.</div><div><h5>{t(locale, 'home.protocolStep2Title')}</h5><p>{t(locale, 'home.protocolStep2Desc')}</p></div></div>
        <div class="step"><div class="n">III.</div><div><h5>{t(locale, 'home.protocolStep3Title')}</h5><p>{t(locale, 'home.protocolStep3Desc')}</p></div></div>
      </div>
    </section>

    <!-- Article grid (All essays) -->
    {recent.length > 0 && (
      <section class="animate-fade-in-up" style="margin-top:20px;">
        <div class="rgd-section-head">
          <h2 set:html={t(locale, 'home.allEssays')} />
          <div class="rule"></div>
          <div class="meta">{t(locale, 'home.sectionMeta')}</div>
        </div>
        <div class="rgd-grid">
          {recent.slice(0, 6).map((p) => (
            <a href={postHref(p)} class="rgd-article-card">
              <div class="img rg-tint-sage">
                {p.data.image && (
                  <img src={p.data.image} alt={p.data.imageAlt || p.data.title} loading="lazy" width="600" height="400" />
                )}
                <span class="tag">{postCategoryLabel(p)}</span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <div class="byline">
                <span>{p.data.author || authorLabel}</span>
                <span>{formatDateShort(p.data.date, locale)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>

  <Footer locale={locale} />
  <BackToTop locale={locale} />
</Base>
