---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroSlideshow from '../../components/HeroSlideshow.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../../i18n/locales';
import { t, localePath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(l => ({
    params: { locale: l === defaultLocale ? undefined : l },
    props: { locale: l },
  }));
}

const { locale } = Astro.props as { locale: Locale };

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = sortedPosts.slice(0, 6);

const slides = [
  {
    image: '/images/hero-slide-1.jpg',
    title: t(locale, 'home.slideWellness'),
    subtitle: t(locale, 'home.slideWellnessDesc'),
    category: 'Welcome',
  },
  {
    image: '/images/ancestral-eating-hero.jpg',
    title: 'Complete Guide to Ancestral Eating',
    subtitle: 'How eating like our great-grandparents changed the way we think about food.',
    link: localePath('/complete-guide-ancestral-eating/', locale),
    category: t(locale, 'categories.nutrition'),
  },
  {
    image: '/images/hero-slide-2.jpg',
    title: t(locale, 'home.slideTable'),
    subtitle: t(locale, 'home.slideTableDesc'),
    category: t(locale, 'categories.nutrition'),
  },
  {
    image: '/images/hero-slide-3.jpg',
    title: t(locale, 'home.slideKBeauty'),
    subtitle: t(locale, 'home.slideKBeautyDesc'),
    link: localePath('/double-cleansing-why-and-how/', locale),
    category: t(locale, 'categories.kBeauty'),
  },
];

const categories = [
  { slug: 'nutrition', label: t(locale, 'categories.nutrition'), emoji: '\u{1F331}', desc: t(locale, 'categoryDescriptions.nutrition'), count: sortedPosts.filter(p => p.data.category === 'nutrition').length },
  { slug: 'movement', label: t(locale, 'categories.movement'), emoji: '\u{1F9D8}', desc: t(locale, 'categoryDescriptions.movement'), count: sortedPosts.filter(p => p.data.category === 'movement').length },
  { slug: 'k-beauty', label: t(locale, 'categories.kBeauty'), emoji: '\u{2728}', desc: t(locale, 'categoryDescriptions.kBeauty'), count: sortedPosts.filter(p => p.data.category === 'k-beauty').length },
  { slug: 'natural-health', label: t(locale, 'categories.naturalHealth'), emoji: '\u{1F33F}', desc: t(locale, 'categoryDescriptions.naturalHealth'), count: sortedPosts.filter(p => p.data.category === 'natural-health').length },
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
  logo: 'https://rooted-glow.com/logo.svg',
  description: 'Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
});
---

<Base
  title="Rooted Glow"
  description="Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience."
  jsonLd={[orgSchema, webSiteSchema]}
  locale={locale}
>
  <Header locale={locale} />

  <main class="flex-1">
    <!-- Hero -->
    <div class="pt-6 animate-fade-in">
      <HeroSlideshow slides={slides} locale={locale} />
    </div>

    <!-- Fresh from the Journal -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 mb-16 sm:mb-24">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.latest')}</span>
          <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">{t(locale, 'home.freshFromTheJournal')}</h2>
        </div>
        <a href={localePath('/category/nutrition/', locale)} class="hidden sm:inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/60 hover:text-sage-800 transition-colors">
          {t(locale, 'common.viewAll')}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((post, i) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id}
            image={post.data.image}
            type={post.data.type}
            locale={locale}
          />
        ))}
      </div>
    </section>

    <!-- Topics We Cover -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="border-t border-sage-200/40 pt-16">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="block text-[11px] font-semibold uppercase tracking-wide text-charcoal-light/50 mb-2">{t(locale, 'home.explore')}</span>
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">{t(locale, 'home.topicsWeCover')}</h2>
          </div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {categories.map((cat) => (
            <a
              href={localePath(`/category/${cat.slug}`, locale)}
              class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-sage-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-sage-600/0 to-sage-700/0 group-hover:from-sage-600/5 group-hover:to-sage-700/10 transition-all duration-500 rounded-2xl"></div>

              <div class="relative z-10 flex flex-col items-center">
                <span class="text-4xl mb-4" aria-hidden="true">{cat.emoji}</span>
                <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-sage-700 transition-colors">{cat.label}</h3>
                <p class="text-xs text-charcoal-light/50 leading-relaxed mb-4 max-w-[180px]">{cat.desc}</p>
                <span class="text-[11px] font-semibold uppercase tracking-wide text-sage-300 group-hover:text-charcoal-light/60 transition-colors">
                  {cat.count} {cat.count === 1 ? t(locale, 'common.article') : t(locale, 'common.articles')}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Quiz CTA -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="relative rounded-2xl sm:rounded-[2.5rem] bg-gradient-to-br from-sage-700 via-sage-800 to-sage-900 p-10 sm:p-16 text-center overflow-hidden">
        <div class="absolute top-[-60px] left-[-40px] w-48 h-48 bg-sage-500/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-[-80px] right-[-40px] w-64 h-64 bg-warm-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-sage-400/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.25em] text-sage-300/80 mb-4">{t(locale, 'home.new')}</span>
          <h2 class="font-heading text-4xl sm:text-5xl italic text-cream mb-4 leading-tight" set:html={t(locale, 'home.discoverArchetype').replace('\n', '<br />')} />
          <p class="text-sm sm:text-base text-sage-300 mb-8 max-w-lg mx-auto leading-relaxed">{t(locale, 'home.quizCtaDesc')}</p>
          <a href={localePath('/quiz/', locale)} class="inline-flex items-center gap-2.5 px-9 py-3.5 bg-cream text-sage-800 text-sm font-semibold rounded-full hover:bg-white hover:shadow-lg transition-all duration-300">
            {t(locale, 'home.takeTheQuiz')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-2xl bg-sage-50 p-10 sm:p-16">
        <div class="grid sm:grid-cols-2 gap-10 sm:gap-16 items-center">
          <div>
            <img src="/logo.svg" alt="Rooted Glow" class="w-32 h-32 mb-6" />
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight mb-4">{t(locale, 'home.aboutTitle')}</h2>
          </div>
          <div>
            <p class="text-sm sm:text-base text-charcoal-light/60 leading-relaxed mb-6">
              {t(locale, 'home.aboutDesc')}
            </p>
            <a href={localePath('/about/', locale)} class="inline-flex items-center gap-2 text-sm font-medium text-sage-700 hover:text-sage-900 transition-colors group">
              {t(locale, 'home.learnMore')}
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="max-w-4xl mx-auto px-5 sm:px-8 mb-20">
      <NewsletterSignup locale={locale} />
    </div>
  </main>

  <Footer locale={locale} />
  <BackToTop locale={locale} />
</Base>
