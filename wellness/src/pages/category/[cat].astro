---
import Pillar from '../../layouts/Pillar.astro';

const categories = ['nutrition', 'movement', 'k-beauty', 'natural-health'];

export function getStaticPaths() {
  return [
    { params: { cat: 'nutrition' } },
    { params: { cat: 'movement' } },
    { params: { cat: 'k-beauty' } },
    { params: { cat: 'natural-health' } },
  ];
}

const categoryMeta: Record<string, { title: string; description: string }> = {
  'nutrition': {
    title: 'Nutrition',
    description: 'Ancestral eating, whole foods, anti-seed-oil cooking, and the gut-skin connection.',
  },
  'movement': {
    title: 'Movement',
    description: 'Functional fitness, mobility work, walking, and outdoor activity. no gym required.',
  },
  'k-beauty': {
    title: 'K-Beauty',
    description: 'Korean skincare routines, ingredient guides, layering techniques, and honest product reviews.',
  },
  'natural-health': {
    title: 'Natural Health',
    description: 'Sleep, stress management, adaptogens, toxin-free living, and the wellness triangle.',
  },
};

const { cat } = Astro.params;
const meta = categoryMeta[cat!] || { title: cat, description: '' };
---

<Pillar title={meta.title} description={meta.description} category={cat!} />
