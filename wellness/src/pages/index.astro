---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import BackToTop from '../components/BackToTop.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = sortedPosts.slice(0, 6);

const slides = [
  {
    image: '/images/hero-slide-1.jpg',
    title: 'Wellness, grounded in what actually works.',
    subtitle: 'Clean eating, functional movement, K-Beauty routines, and natural health from people who live it.',
    category: 'Welcome',
  },
  {
    image: '/images/ancestral-eating-hero.jpg',
    title: 'Complete Guide to Ancestral Eating',
    subtitle: 'How eating like our great-grandparents changed the way we think about food.',
    link: '/complete-guide-ancestral-eating',
    category: 'Nutrition',
  },
  {
    image: '/images/hero-slide-2.jpg',
    title: 'From the Farmers Market to Your Table',
    subtitle: 'Seasonal, whole-food cooking that nourishes from the inside out.',
    category: 'Nutrition',
  },
  {
    image: '/images/hero-slide-3.jpg',
    title: 'K-Beauty Routines That Actually Work',
    subtitle: 'Korean skincare, simplified. Real routines from real people.',
    link: '/double-cleansing-why-and-how',
    category: 'K-Beauty',
  },
];

const categories = [
  { slug: 'nutrition', label: 'Nutrition', emoji: '\u{1F331}', desc: 'Ancestral eating, whole foods, and the gut-skin connection', count: sortedPosts.filter(p => p.data.category === 'nutrition').length },
  { slug: 'movement', label: 'Movement', emoji: '\u{1F9D8}', desc: 'Functional fitness, mobility, and outdoor activity', count: sortedPosts.filter(p => p.data.category === 'movement').length },
  { slug: 'k-beauty', label: 'K-Beauty', emoji: '\u{2728}', desc: 'Korean skincare routines and ingredient deep-dives', count: sortedPosts.filter(p => p.data.category === 'k-beauty').length },
  { slug: 'natural-health', label: 'Natural Health', emoji: '\u{1F33F}', desc: 'Sleep, stress, adaptogens, and toxin-free living', count: sortedPosts.filter(p => p.data.category === 'natural-health').length },
];

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
  logo: 'https://rooted-glow.com/logo.svg',
  description: 'Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience.',
});
const webSiteSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Rooted Glow', url: 'https://rooted-glow.com',
});
---

<Base
  title="Rooted Glow"
  description="Wellness, ancestral nutrition, movement, and K-Beauty grounded in real experience."
  jsonLd={[orgSchema, webSiteSchema]}
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <div class="pt-6 animate-fade-in">
      <HeroSlideshow slides={slides} />
    </div>

    <!-- Fresh from the Journal -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 mb-16 sm:mb-24">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-sage-400 mb-2">Latest</span>
          <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">Fresh from the Journal</h2>
        </div>
        <a href="/category/nutrition" class="hidden sm:inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-sage-500 hover:text-sage-800 transition-colors">
          View All
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((post, i) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            type={post.data.type}
          />
        ))}
      </div>
    </section>

    <!-- Topics We Cover -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="border-t border-sage-200/40 pt-16">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-sage-400 mb-2">Explore</span>
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight">Topics We Cover</h2>
          </div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {categories.map((cat) => (
            <a
              href={`/category/${cat.slug}`}
              class="group relative aspect-square flex flex-col items-center justify-center text-center p-7 rounded-2xl border border-sage-200/60 bg-white overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-xl"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-sage-600/0 to-sage-700/0 group-hover:from-sage-600/5 group-hover:to-sage-700/10 transition-all duration-500 rounded-2xl"></div>

              <div class="relative z-10 flex flex-col items-center">
                <span class="text-4xl mb-4" aria-hidden="true">{cat.emoji}</span>
                <h3 class="font-heading text-xl text-charcoal mb-2 group-hover:text-sage-700 transition-colors">{cat.label}</h3>
                <p class="text-xs text-sage-400 leading-relaxed mb-4 max-w-[180px]">{cat.desc}</p>
                <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-sage-300 group-hover:text-sage-500 transition-colors">
                  {cat.count} {cat.count === 1 ? 'article' : 'articles'}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Quiz CTA -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-20 sm:mb-32">
      <div class="relative rounded-2xl sm:rounded-[2.5rem] bg-gradient-to-br from-sage-700 via-sage-800 to-sage-900 p-10 sm:p-16 text-center overflow-hidden">
        <div class="absolute top-[-60px] left-[-40px] w-48 h-48 bg-sage-500/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-[-80px] right-[-40px] w-64 h-64 bg-warm-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-sage-400/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          <span class="inline-block text-[11px] font-semibold uppercase tracking-[0.25em] text-sage-300/80 mb-4">New</span>
          <h2 class="font-heading text-4xl sm:text-5xl italic text-cream mb-4 leading-tight">Discover Your<br />Wellness Archetype</h2>
          <p class="text-sm sm:text-base text-sage-300 mb-8 max-w-lg mx-auto leading-relaxed">10 questions across movement, sleep, stress, and nutrition. Takes 2 minutes.</p>
          <a href="/quiz/" class="inline-flex items-center gap-2.5 px-9 py-3.5 bg-cream text-sage-800 text-sm font-semibold rounded-full hover:bg-white hover:shadow-lg transition-all duration-300">
            Take the Quiz
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="max-w-[1400px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-2xl bg-sage-50 p-10 sm:p-16">
        <div class="grid sm:grid-cols-2 gap-10 sm:gap-16 items-center">
          <div>
            <img src="/logo.svg" alt="Rooted Glow" class="w-16 h-16 mb-6" />
            <h2 class="font-heading text-4xl italic text-charcoal tracking-tight mb-4">About Rooted Glow</h2>
          </div>
          <div>
            <p class="text-sm sm:text-base text-sage-500 leading-relaxed mb-6">
              We write about clean eating, functional movement, K-Beauty routines, and natural health. Everything here is based on personal experience and actual research, not trends or sponsorships.
            </p>
            <a href="/about" class="inline-flex items-center gap-2 text-sm font-medium text-sage-700 hover:text-sage-900 transition-colors group">
              Learn more about us
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="max-w-4xl mx-auto px-5 sm:px-8 mb-20">
      <NewsletterSignup />
    </div>
  </main>

  <Footer />
  <BackToTop />
</Base>
